#ifndef	_COM9001_H_
#define	_COM9001_H_

typedef struct _CCOM9001_R
{
	unsigned long temp_id           ;	// 컨테츠ID(T_CONTENTS_TEMP.id)
	char    user_id           [12+1];	// 사용자ID
	char    cont_gu           [ 2+1];	// 컨텐츠구분(WE:위디스크, MY:공개자료실, MD:내자료실)
	char    server_id         [ 5+1];	// 서버ID
	char    temp1             [   2];
	char    conn_ip           [19+1];	// 접속ID
	double upload_size		        ;
}CCOM9001_R, *LPCCOM9001_R;

/*
