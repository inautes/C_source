/******************************************************************************
 *   서브시스템 : CMD서버
 *   프로그램명 : cmds10041.cc (로그인인증)
 *         기능 : Disk서비스를 사용하기 위해 인증 절차를 한다.
 *         설명 :
 *       작성자 : 전봉구
 *       작성일 : 2004/02/16
 *     수정이력 :
********************************************************************************
1         2         3         4         5         6         7         8
12345678901234567890123456789012345678901234567890123456789012345678901234567890
*******************************************************************************/
#include <mysql.h>
#include <stdarg.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "apdefine.h"
#include "comcomm.h"
#include "commydb.h"
#include "cmds10041.h"

#define  MAX_ROWS	1
//#define  _DEBUG_
/******************************************************************************
** cmds10041 main
*******************************************************************************/
int cmds10041(char *pRecvHead, char *pRecvData, char* &pSendData)
{
	MYSQL     *con;
	MYSQL_RES *res;
	MYSQL_ROW  row;

	LPHEADER     p_headerr;
	LPCCMDS10041_R	p_cmds10041r;

	int nDataSize     ;
	char szQuery[1000];  // query string
	char ErrMsg  [256];  // error message
	int  ErrNum;         // error no
	int  nRowcnt;        // select row count

	// input variables
	char    user_id           [12+1];  // 사용자ID
	char    admin_id           [12+1];  // 사용자ID
	char    sess_id           [50+1];  // 세션ID

	int conn_cnt;
	/*--------------------------------------------------------------------*/
	/* start!!!                                                           */
	/*--------------------------------------------------------------------*/
	#ifdef __DEBUG
	printf("cmds10041-> start...\n");
	#endif
	p_headerr   = (LPHEADER) pRecvHead;
	p_cmds10041r = (LPCCMDS10041_R) pRecvData;

	// local 변수 Clear
	memset(&ErrMsg   , 0x00, sizeof(ErrMsg   )); // 오류메시지
	memset(&admin_id  , 0x00, sizeof(admin_id  )); // 관리자ID
	memset(&user_id  , 0x00, sizeof(user_id  )); // 사용자ID
	memset(&sess_id  , 0x00, sizeof(sess_id  )); // 세션ID

	//strcpy(admin_id, p_cmds10041r->user_id);
	memcpy(admin_id, p_cmds10041r->user_id,sizeof(p_cmds10041r->user_id));
	memcpy(user_id, p_headerr->szUserID,sizeof(p_headerr->szUserID));
	strcpy(sess_id, p_cmds10041r->sess_id);
	
	#ifdef _DEBUG_
	printf("userid  =(%s)\n", user_id  );
	printf("cmds10041->in admin_id  =(%s)\n", admin_id  );
	printf("cmds10041->in sess_id  =(%s)\n", sess_id  );
	#endif

	memset (szQuery, 0x00, sizeof(szQuery ));
	sprintf(szQuery, "select count(user_id) as conn_yn "
	                 "  from T_USER_STAT a      "
	                 " where a.user_id = '%s'          "
	                 ,admin_id
	                 );
/*
	sprintf(szQuery, "select count(user_id) as conn_yn "
	                 "  from T_USER_STAT a      "
	                 " where a.user_id = '%s'          "
	                 "   and a.sess_id = '%s'          "
	                 ,user_id
	                 ,sess_id
	                 );
*/
	// DB 연결
	
	if (!(con=db_connect("zangsi")))
	{
		ErrNum = -100401;
		sprintf(ErrMsg, "DB에 접속하지 못 하였습니다...\n");
		#ifdef _DEBUG_
		printf("cmds10041->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds10041->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
	
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
	   	return(ErrNum); 
	}
	

	if (mysql_query(con, szQuery)){
		ErrNum = -100402;
		sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
		#ifdef _DEBUG_
		printf("cmds10041->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds10041->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
	
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
	   	return(ErrNum); 
	}

	if (!(res = mysql_store_result(con)))
	{
		ErrNum = -999999;
		sprintf(ErrMsg, "자료가 없습니다.\n");
		#ifdef _DEBUG_
		printf("cmds10041->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds10041->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
	
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
	   	return(ErrNum); 
	}
 	if (mysql_num_rows(res)==0)
 	{
		ErrNum = -100403;
		sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
		
		#ifdef _DEBUG_
		printf("cmds10041->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds10041->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
	
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
	   	return(ErrNum); 
	}
	if (row = mysql_fetch_row(res))
	{
		conn_cnt = getint(row, 0);
	}
	#ifdef _DEBUG_
	printf("cmds10041s.conn_yn(%d)\n", getint(row, 0));
	#endif
	
	mysql_free_result(res);

	//임시버퍼생성
	LPCCMDS10041_S t_cmds10041s = new CCMDS10041_S[MAX_ROWS];//struct _FILEINFO;
	memset(t_cmds10041s, 0x00, (sizeof(CCMDS10041_S)*MAX_ROWS));

	if (conn_cnt > 0)
	{
		memset (szQuery, 0x00, sizeof(szQuery ));
		sprintf(szQuery, "select a.server_id,   b.server_ip,  "
		                 "       b.server_port, b.upsvr_port, "
		                 "       b.dnsvr_port,  a.free_yn,    "
		                 "       a.recv_cd,     a.share_cd,   "
		                 "       a.root_path,   a.end_date    "
		                 "  from T_MYDISK_INFO a       "
		                 "     , T_SERVER_INFO b       "
		                 " where a.user_id   = '%s'           "
		                 "   and a.server_id = b.server_id    "
		                 ,user_id
		                 );

		if (mysql_query(con, szQuery)){
			delete[] t_cmds10041s;

			ErrNum = -100404;
			sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
			goto cmds10041_err;
		}

		//질의 결과를 얻는다
		if (!(res = mysql_store_result(con))) {
			delete[] t_cmds10041s;
			
			ErrNum = -100405;
			sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
			goto cmds10041_err;
		}
		nRowcnt = 0;
	 	if (mysql_num_rows(res)!=0)
	 	{
			while((row = mysql_fetch_row(res))) {
				#ifdef _DEBUG_
				printf("cmds10041s[%d].server_id (%s)\n", nRowcnt, getstr(row, 0));
				printf("cmds10041s[%d].server_ip (%s)\n", nRowcnt, getstr(row, 1));
				printf("cmds10041s[%d].mys_port  (%d)\n", nRowcnt, getint(row, 2));
				printf("cmds10041s[%d].ups_port  (%d)\n", nRowcnt, getint(row, 3));
				printf("cmds10041s[%d].dns_port  (%d)\n", nRowcnt, getint(row, 4));
				printf("cmds10041s[%d].free_yn   (%d)\n", nRowcnt, getint(row, 5));
				printf("cmds10041s[%d].recv_cd   (%d)\n", nRowcnt, getint(row, 6));
				printf("cmds10041s[%d].share_cd  (%d)\n", nRowcnt, getint(row, 7));
				printf("cmds10041s[%d].root_path (%s)\n", nRowcnt, getstr(row, 8));
				printf("cmds10041s[%d].ed_date   (%s)\n", nRowcnt, getstr(row, 9));
				#endif
	
				strcpy(t_cmds10041s[nRowcnt].server_id, getstr(row, 0));
				strcpy(t_cmds10041s[nRowcnt].server_ip, getstr(row, 1));
				       t_cmds10041s[nRowcnt].mys_port = getint(row, 2);
				       t_cmds10041s[nRowcnt].ups_port = getint(row, 3);
				       t_cmds10041s[nRowcnt].dns_port = getint(row, 4);
				       t_cmds10041s[nRowcnt].free_yn  = getint(row, 5);
				       t_cmds10041s[nRowcnt].recv_cd  = getint(row, 6);
				       t_cmds10041s[nRowcnt].share_cd = getint(row, 7);
				strcpy(t_cmds10041s[nRowcnt].root_path, getstr(row, 8));
				strcpy(t_cmds10041s[nRowcnt].ed_date,   getstr(row, 9));
			
				nRowcnt++;
			
				// buffer크기 보다 큰경우
				if (nRowcnt >= MAX_ROWS)
					break;
			}
		}

		mysql_free_result(res);
	
		// 1: 인증실패, 2:인증성공, 3:인증성공 & MYDISK OK
		if (nRowcnt > 0)
			t_cmds10041s[0].my_stat = 3;
		else
		{
			t_cmds10041s[0].my_stat = 2;

			// [2]MY디스크 서버
			// 디스크 사용량중 50이하 이면서 사용자가 가장 적은 서버
			memset (szQuery, 0x00, sizeof(szQuery ));
			sprintf(szQuery, "select a.server_id ,  a.server_ip,                         "
			                 "       a.server_port, a.upsvr_port,     a.dnsvr_port,      "
			                 "       concat(a.root_path, '/',                            "
			                 "       if(mod(a.user_cnt,100)=0,                           "
			                 "          TRUNCATE(a.user_cnt/100,0) + 1000,               "
			                 "          TRUNCATE(a.user_cnt/100,0) + 1001)) as root_path "
			                 "  from T_SERVER_INFO a                              "
			                 " where a.server_gu = '02'                                  "
			                 "   and round((a.disk_use / a.disk_size) * 100) < 90        "
			                 " order by a.user_cnt asc limit 1                           ");

			if (mysql_query(con, szQuery)){
				delete[] t_cmds10041s;
	
				ErrNum = -100406;
				sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
				goto cmds10041_err;
			}

			//질의 결과를 얻는다
			if (!(res = mysql_store_result(con))) {
				delete[] t_cmds10041s;
				
				ErrNum = -100407;
				sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
				goto cmds10041_err;
			}
			nRowcnt = 0;
		 	if (mysql_num_rows(res)!=0)
		 	{
				while((row = mysql_fetch_row(res))) {
					#ifdef _DEBUG_
					printf("cmds10041s[%d].server_id (%s)\n", nRowcnt, getstr(row, 0));
					printf("cmds10041s[%d].server_ip (%s)\n", nRowcnt, getstr(row, 1));
					printf("cmds10041s[%d].mys_port  (%d)\n", nRowcnt, getint(row, 2));
					printf("cmds10041s[%d].ups_port  (%d)\n", nRowcnt, getint(row, 3));
					printf("cmds10041s[%d].dns_port  (%d)\n", nRowcnt, getint(row, 4));
					printf("cmds10041s[%d].root_path (%s)\n", nRowcnt, getstr(row, 5));
					#endif
		
					strcpy(t_cmds10041s[nRowcnt].server_id, getstr(row, 0));
					strcpy(t_cmds10041s[nRowcnt].server_ip, getstr(row, 1));
					       t_cmds10041s[nRowcnt].mys_port = getint(row, 2);
					       t_cmds10041s[nRowcnt].ups_port = getint(row, 3);
					       t_cmds10041s[nRowcnt].dns_port = getint(row, 4);
					strcpy(t_cmds10041s[nRowcnt].root_path, getstr(row, 5));
				
					nRowcnt++;
				
					// buffer크기 보다 큰경우
					if (nRowcnt >= MAX_ROWS)
						break;
				}
			}
	
			mysql_free_result(res);
		}
	}
	else
	{
		t_cmds10041s[0].my_stat = 1;
	}

	db_disconnect(con);
	
	#ifdef _DEBUG_
	printf("cmds10041s.my_stat (%d) ip(%s)\n", t_cmds10041s[0].my_stat, t_cmds10041s[0].server_ip);
	#endif

	//전송할 버퍼생성
	nDataSize = HEADER_SIZE + sizeof(CCMDS10041_S) * 1;
	
	HEADER headers;
	memcpy(&headers, p_headerr, HEADER_SIZE); //header	
	headers.nDataCnt  = 1;
	headers.nDataSize = sizeof(CCMDS10041_S);

	pSendData = new char[nDataSize];
	memset(pSendData, 0x00, nDataSize);
	
	memcpy(pSendData, &headers, sizeof(HEADER)); //header	
	memcpy(pSendData+HEADER_SIZE, t_cmds10041s, nDataSize - HEADER_SIZE); //body
	delete[] t_cmds10041s;
	#ifdef _DEBUG_
	printf("cmds10041-> end sucess sendsize(%d)\n", nDataSize);
	#endif

	return (1);

//------------------------------------------------------------------------------
//  error 처리
//------------------------------------------------------------------------------
cmds10041_err:
	printf("cmds10041->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
	printf("cmds10041->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));

	db_disconnect(con);
	E_dump(ErrNum, ErrMsg, pSendData);
   	return(ErrNum); 

cmds10041_tran_err:
	printf("cmds10041->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
	printf("cmds10041->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));

	tran_rollback(con);
	db_disconnect(con);
	E_dump(ErrNum, ErrMsg, pSendData);
   	return(ErrNum);
}

/*------------------------------------------------------------------------------
select if(a.sess_id='1234567890',1,0) conn_yn
  from T_USER_STAT a
 where a.user_id = 'jbk'

select a.server_id,   b.server_ip,
       b.server_port, b.dnsvr_port,
       b.upsvr_port,  a.free_yn,
       a.recv_cd,     a.share_cd
  from T_MYDISK_INFO a
     , T_SERVER_INFO b
 where a.user_id   = 'jindogg'
   and a.server_id = b.server_id
------------------------------------------------------------------------------*/
