#ifndef	_CMDS1101_H_
#define	_CMDS1101_H_

#include "comhead.h"
/*----------------------------------------------------------------------------*/
/*   WE디스크 조회 요청                                                       */
/*----------------------------------------------------------------------------*/
typedef struct _CCMDS1101_R
{
	int    find_flag             ;  // 검색구분 [1]WE디스크  [2]MY디스크
	double total_file_size       ;  // 업로드하는 total size            
}CCMDS1101_R,*LPCCMDS1101_R;

/*----------------------------------------------------------------------------*/
/*   WE디스크 조회 응답                                                       */
/*----------------------------------------------------------------------------*/
typedef struct _CCMDS1101_S
{
	char server_id  [ 5+1];   // 서버ID
	char server_ip  [15+1];   // 서버IP
	char tmp        [ 2  ];   // filler
	long dn_port          ;   // 다운로드port
	long up_Port          ;   // 업로드  port
	char root_path [255+1];   // MY디스크시 생성될 패스
}CCMDS1101_S,*LPCCMDS1101_S;

int cmds1101(char *pRecvHead, char *pRecvData, char* &pSendData);

#endif

