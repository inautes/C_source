/*----------------------------------------------------------------------------*/
/*   파일다운로드시작 요청                                                    */
/*----------------------------------------------------------------------------*/
typedef struct _CFDNS3002_R
{
	char    dn_user          [12 +1];  // 다운로드 사용자
	char    sh_user          [12 +1];  // 공유자
	int     won_mega                ;  // 원당메가
	char    file_path        [255+1];  // 파일경로(서버)
	char    file_name        [255+1];  // 서버파일이름
	double  file_size               ;  // 파일크기(total)
	int     file_cnt                ;  // 파일갯수
}CFDNS3002_R,*LPCFDNS3002_R;

