#include "comhead.h"
/*----------------------------------------------------------------------------*/
/*   사이버머니조회 요청                                                      */
/*----------------------------------------------------------------------------*/
typedef struct _CFDNS3001_R
{
	char dn_user   [12+1];   // 다운로드 사용자
	char sh_user   [12+1];   // 공유자
}CFDNS3001_R,*LPCFDNS3001_R;

/*----------------------------------------------------------------------------*/
/*   사이버머니조회 응답                                                      */
/*----------------------------------------------------------------------------*/
typedef struct _CFDNS3001_S
{
	long hold_amt         ;   // 사용가능금액(다운로드사용자)
	long won_mega         ;   // 원당메가    (공유 사용자)
