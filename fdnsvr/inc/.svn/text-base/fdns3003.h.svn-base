#ifndef	_FDNS3003_H_
#define	_FDNS3003_H_

#include "comhead.h"
/*----------------------------------------------------------------------------*/
/*   파일다운로드종료 요청                                                    */
/*----------------------------------------------------------------------------*/
typedef struct _CFDNS3003_R
{
	int     seq_no                  ;  // 일련번호
	double  file_size               ;  // 파일크기(BYTE) (total)
	double  down_size               ;  // 다운로드크기   (total)
	char    dn_user          [12 +1];  // 다운로드 사용자
	char    sh_user          [12 +1];  // 공유자
	char    dn_date          [ 8 +1];  // 다운일자
	char    temp             [    1];
}CFDNS3003_R,*LPCFDNS3003_R;

int fdns3003(char *pRecvData, char* &pSendData);
