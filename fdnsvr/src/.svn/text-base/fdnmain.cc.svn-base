static void register_sigaltstack()
{
    stack_t newSS, oldSS;

    if(is_altstack_defined)
    {
        return;
    }

    newSS.ss_sp = tmp_stack;

    newSS.ss_size = STACK_SIZE;
    newSS.ss_flags = 0;

    if(sigaltstack(&newSS, &oldSS) < 0)
    {
        printf ("error altstack");
    }

    is_altstack_defined = 1;
 }

/*****************************************************************************
* CMDМ­Йі Main
* (I) 1. int argc    : Argument Count Мі
*     2. char **argv : Argunment Data Point
*****************************************************************************/

int main(int argc, char** argv)
{
    infMainRoutine(argc, argv);
    infTermProcess();
}
/*****************************************************************************
* ЧСЗЮБзЗЅ НУРл
* (I) 1. int argc    : Argument Count Мі
*     2. char **argv : Argunment Data Point
* (R) 1. СЄЛѓ : '0'
*     2. ПРЗљ : РНМі 
*****************************************************************************/
int     infInitProcess(int argc, char** argv) 
{
    infLOG(ALWAY, "================= ЧСЗЮБзЗЅ НУРл ====================\n"); 
    return RETOK;
}

/*****************************************************************************
* ЧСЗЮБзЗЅ СОЗс
* (I) void
* (R) void
*****************************************************************************/
void    infTermProcess()
{
    infLOG(ALWAY, "================= ЧСЗЮБзЗЅ СОЗс ====================\n"); 
    exit(0);
}

/*******************************************************************************
* SOCKET CLOSE
* (I) SUserParm_T *pUser : ЛчПыРк СЄРЧ КЏМі БИСЖУМ
* (R) int iSockId : Socket Connect ID
*******************************************************************************/
int     infReleaseSocket()
{
	
    return 0;
}


int infMainRoutine(int argc,char** argv)
{
    int servSock;                    /* Socket descriptor for server */
    int clntSock;                    /* Socket descriptor for client */
    unsigned short ServPort;     /* Server port */
    pthread_t threadID;              /* Thread ID from pthread_create() */
    
    struct ThreadArgs *threadArgs;   /* Pointer to argument structure for thread */

    if (argc != 2)     /* Test for correct number of arguments */
    {
        fprintf(stderr," ЛчПыЙцЙ§ : /М­ЙіАцЗЮ/fdnserver SERVER_PORT >\n");
        exit(1);
    }

/*	
	struct sigaction intsig; 
	
	intsig.sa_sigaction = infSigHandler; 
// 	signal(SIGPIPE, infSigHandler); // ДнШљ МвФЯПЁ ОВЗСДТ НУЕЕ..

	sigemptyset(&intsig.sa_mask); 
	intsig.sa_flags = SA_SIGINFO; 
	
	//SIGPIPE ПЁ ДыЧб ПЙПм УГИЎ , callback ЧдМі УГИЎ
	if (sigaction(SIGPIPE  , &intsig, 0) == -1) 
	{
		#ifdef __DEBUG
		printf("sigaction error\n");
		#endif
		infLOG(ERROR, "sigaction error\n"); 
	}
	if (sigaction(SIGSEGV  , &intsig, 0) == -1) 
	{
		#ifdef __DEBUG
		printf("sigaction error\n");
		#endif
		
	}	
	
	if (sigaction( SIGFPE  , &intsig, 0) == -1) 
	{
		#ifdef __DEBUG
		printf("sigaction error\n");
		#endif
		
	}
	*/
  
 
	signal(SIGPIPE, SIG_IGN);
    signal(SIGTERM, SIG_IGN);
    signal(SIGINT,  SIG_IGN);
//    signal(SIGQUIT, SIG_IGN);
    signal(SIGKILL, SIG_IGN);
    signal(SIGHUP,  SIG_IGN);
    signal(SIGTTIN, SIG_IGN);
    signal(SIGTTOU, SIG_IGN);
    
    
 
 	
	infSetUserParm(&gstUserParm, argc, argv);
	
	infLOG(ALWAY, "================= ЧСЗЮБзЗЅ НУРл ====================\n"); 	
	
	
	
	/*
	НЧСІ МвФЯ ПЌАсРќПЁ T_SERVER_INFO РЧ up_userПЭ up_sizeИІ 0РИЗЮ УЪБтШ­
	*/



    ServPort = atoi(argv[1]);  /* First arg:  local port */
    
    
    #ifdef __DEBUG
	/* ЗЮБз ГЛПЊРЬ АњЕЕЧЯАд НзПЉ РЯДм СпСіЧеДЯДй.
	pthread_create(&threadID,NULL,mon_thread,(void**)NULL);
	*/	
	#endif
	

    servSock = CreateTCPServerSocket(ServPort);
    if(servSock < 0)
    	return -1;
		

    for (;;) /* run forever */
    {
			/*
			1НУАЃИЖДй ЧбЙјОП СЂМгРкМі ШЎРЮ
			*/
	
	
			//////////////////////////////// accept //////////////////////////////
		
		    struct sockaddr_in ClntAddr; /* Client address */
		    unsigned int clntLen;            /* Length of client address data structure */
		
		    /* Set the size of the in-out parameter */
		    clntLen = sizeof(ClntAddr);
		    
		    /* Wait for a client to connect */
		    if ((clntSock = accept(servSock, (struct sockaddr *) &ClntAddr, &clntLen)) < 0)
		    { 
		        DieWithError("accept() failed");
		    }
		    /* clntSock is connected to a client! */
	
	 		///////////////////////////////accept end /////////////////////////////////
	
			LPUSERINFO pUserInfo = new USERINFO;
			sprintf(pUserInfo->thread.userIP ,"%s", inet_ntoa(ClntAddr.sin_addr));
			pUserInfo->thread.clntSock = clntSock;
	
	    /* Create client thread */
	    if (pthread_create(&threadID, NULL, ThreadMain, (void *) pUserInfo) != 0)
	    {
	  		infLOG(ERROR, " ] pthread_create() failed %s socket num == %d	\n", inet_ntoa(ClntAddr.sin_addr),clntSock);
	    }
			else
			{
				#ifdef __DEBUG
				printf("Create with thread %ld\n", (long int) threadID);
				#endif
	
			}
    }
    return 1;

}
