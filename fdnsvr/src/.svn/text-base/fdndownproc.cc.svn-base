}


int GetFileList(char* path,int nCount,FILEINFO* &pResult,char* pRecvData,char* pSrcPath)
{
	DIR *pdir = NULL;

	pdir = opendir(path);//strPath); 

	if(pdir == NULL)
	{
		infLOG(ALWAY, " ] GetFileList Error ( pdir == NULL )\n");		
		return -1;	
	}

	struct dirent *pent;
	struct stat64 statbuf;
	
	char fullpath[1024];
	
	while( (pent = readdir(pdir)) != NULL )
	{
		memset(fullpath,0x00,sizeof(fullpath));
		strcpyA(fullpath,path);//strPath);
		strcat(fullpath , "/");
		strcat(fullpath, pent->d_name);  
		
		int stat= stat64(fullpath,&statbuf); 
	 
	 	if((strcmp(".",pent->d_name) !=0 ) && (strcmp("..",pent->d_name) != 0) && (GetFistCharIndex(pent->d_name,'.') != 0))
		{
			if(S_ISDIR (statbuf.st_mode))
			{
				
				nCount = GetFileList( fullpath,nCount,pResult,pRecvData,pSrcPath);
				if(nCount == -1)
				{
                    infLOG(ERROR, " ]GetFileList: GetFileList Error ( nCount == -1 )\n");
					closedir(pdir);
					return -1;
				}
			}
			else
			{
				if(S_ISREG (statbuf.st_mode))
				{
					memcpy(&pResult[nCount],pRecvData,sizeof(FILEINFO));
					
					long len = strlen(path);
					long src_len = strlen(pSrcPath);
					
					if(len > src_len)
					{
						char szAddPath[512];
						memset(szAddPath,0x00,sizeof(char)*512);
						
						if(	GetRightString(path,len - src_len,szAddPath))
						{
							strcat(pResult[nCount].szDownPath,"\\");
							
							char szResult[512];
							memset(&szResult,0x00,sizeof(szResult));

							SetWordReplace(szAddPath,pResult[nCount].szFileName,pResult[nCount].szDownFileName,szResult);
							
							strcat(pResult[nCount].szDownPath,szResult);
							StrReplace(pResult[nCount].szDownPath,"/","\\");
						}
						
					}
					 
					pResult[nCount].nType = FT_FOLDER; //СОЗљ
					strcpyA(pResult[nCount].szFileName ,pent->d_name); // РЬИЇ
					pResult[nCount].dFileSize = (double)statbuf.st_size; // ХЉБт
					strcpyA(pResult[nCount].szSrcPath , path);
					
					//gridБзИЎЕх НУРл
					char szFullPath[1024];
					memset(szFullPath,0x00,sizeof(szFullPath));
					
					// full path ИИЕщБт.
					strcpyA(szFullPath,path);
					strcat(szFullPath,"/");
					strcat(szFullPath,pent->d_name);
					
					CMD5 md5;
	        char* pResultHash = md5.GetHashFromFile(szFullPath);
	        if( pResultHash != NULL)
	        {
	        	strcat(pResult[nCount].szSrcPath,"|");
	        	strcat(pResult[nCount].szSrcPath,pResultHash);
	        	strcat(pResult[nCount].szSrcPath,"|");
	        }
	        //БзИЎЕх ГЁ
			        
			        
					LPFILEINFO pFile = (LPFILEINFO)pRecvData;
					
					nCount++;
				}
				else
				{
					if(stat != 0 )
						nCount = -1;

					closedir(pdir);
                    infLOG(ERROR, " ]GetFileList: GetFileList Error\n");
					return -1;
				}
				
				//change
				if(nCount >= 2000)
				{
					nCount = 2000;
					break;
				}
			}
		}
	}
	
	
	closedir(pdir);
	
	return nCount;
}


int FileRequestList(int& Socket,char *pRecvHead, char *pRecvData, char* &pSendData)
{
	
	if( pRecvHead == NULL )
		infLOG(ERROR, "pRecvHead == NULL\n"); 
	if( pRecvData == NULL )
		infLOG(ERROR, "pRecvData == NULL\n"); 
			
	LPHEADER pHeader = (LPHEADER)pRecvHead;
	ERR_HEADER errheader;
	memset(&errheader,0x00,sizeof(ERR_HEADER));
	
	HEADER headers;
	memset(&headers,0x00,sizeof(HEADER));
	//com9005
	//ДйПюЗЮЕхНУ ФСХйУї СЄКИ СЖШИ
	if( com9005(pHeader->szUserID,pRecvData, errheader.errmsg) < 0)
	{
		//ПЙПмУГИЎ
		pSendData = new char[sizeof(ERR_HEADER)];
		memset(pSendData,0x00,sizeof(ERR_HEADER));
		errheader.header.nCmd = RS_ERR;
		errheader.header.nErrorCode = -RS_FILE_REQUEST_LIST;
		memcpy(pSendData, &errheader, sizeof(ERR_HEADER));

		return -RS_FILE_DATA_TRANSFER;		
	}

	LPFILEINFO pRecv = (LPFILEINFO)pRecvData;
	
	// ЦФРЯ ИёЗЯ ОђБт (ЦњДѕЗЮ КЮХЭ)
	#ifdef __DEBUG
	printf("nTypeDisk   	%d\n",pRecv->nTypeDisk	);
	printf("nType			%d\n",pRecv->nType		);
	printf("nDealType   	%d\n",pRecv->nDealType	);
	printf("DealID	    	%d\n",pRecv->dwDealID	);
	printf("szServerID   	%s\n",pRecv->szServerID);
	printf("szServerIP   	%s\n",pRecv->szServerIP);
	printf("dwServerPort   	%d\n",pRecv->dwServerPort);
	printf("nNumber			%lu\n",pRecv->nNumber);
	printf("szUserID      	%s\n", pRecv->szUserID     );
	printf("szFileOwnerID 	%s\n", pRecv->szFileOwnerID);
	printf("szDownFileName	%s\n", pRecv->szDownFileName);
	printf("szFileName    	%s\n", pRecv->szFileName   );
	printf("szSrcPath     	%s\n", pRecv->szSrcPath    );
	printf("szDownPath    	%s\n", pRecv->szDownPath   );
	printf("dFileSize     	%.0f\n",pRecv->dFileSize);
	#endif
	
	if( pRecv->nType == FT_FILE)
	{
		#ifdef __DEBUG	
		printf("FT_FILE \n");
		#endif			
		/*grid БзИЎЕхИІ РЇЧи md5 Л§МК */
		//БзИЎЕх НУРл
		char szFullPath[1024];
		memset(szFullPath,0x00,sizeof(szFullPath));
		
		// full path ИИЕщБт.
		strcpy(szFullPath,pRecv->szSrcPath);
		strcat(szFullPath,"/");
		strcat(szFullPath,pRecv->szFileName);
		
		#ifdef __DEBUG 
		printf("szFullPath [ %s ] \n",szFullPath);
		#endif
		
		CMD5 md5;
    char* pResult = md5.GetHashFromFile(szFullPath);
    
    if( pResult != NULL)
    {
    	#ifdef __DEBUG
    	printf("HASH [ %s ] \n",pResult);
    	#endif
    	strcat(pRecv->szSrcPath,"|");
    	strcat(pRecv->szSrcPath,pResult);
    	strcat(pRecv->szSrcPath,"|");
    }
    else
  	{
  		#ifdef __DEBUG	
			printf("HASH NULL \n");
			#endif			
  	}
        //БзИЎЕх ГЁ
        
		headers.nCmd = RS_FILE_REQUEST_LIST;
			
		headers.nDataCnt = 1;
		headers.nDataSize = sizeof(FILEINFO);
		headers.nErrorCode = 0;
		
		pSendData = new char[sizeof(HEADER) + headers.nDataCnt * headers.nDataSize];
	
		memset(pSendData,0x00,sizeof(HEADER) + headers.nDataCnt * headers.nDataSize);
		memcpy(pSendData,&headers,sizeof(HEADER)); //head
		memcpy(pSendData+sizeof(HEADER),pRecv,headers.nDataCnt * headers.nDataSize);
		
	}
	else
	{
		#ifdef __DEBUG	
		printf("FT_FOLDER \n");
		#endif			
				
		LPFILEINFO pResult = new FILEINFO[2001]; //2000АГРЧ ИёЗЯРЛ КИГОМі РжДй.
		memset(pResult,0x00,sizeof(FILEINFO)*2001);
		
		char szFullPath[1024];
		memset(szFullPath,0x00,sizeof(szFullPath));
		
		// full path ИИЕщБт.
		strcpyA(szFullPath,pRecv->szSrcPath);
		strcat(szFullPath,"/");
		strcat(szFullPath,pRecv->szFileName);
		
		headers.nDataCnt = GetFileList(szFullPath,0,pResult,pRecvData,pRecv->szSrcPath);
		if( headers.nDataCnt< 0 ) //ЦФРЯ ИЎНКЦЎ АЙМіИІ ОђДТДй.
		{
			pSendData = new char[sizeof(ERR_HEADER)];
			memset(pSendData,0x00,sizeof(ERR_HEADER));
			errheader.header.nCmd = RS_ERR;
			errheader.header.nErrorCode = -RS_FILE_REQUEST_LIST;
			strcat(errheader.errmsg,"М­ЙіУј ПЁМ­ ЦФРЯРЬ ОјАХГЊ П­Мі ОјНРДЯДй.");
			
			memcpy(pSendData, &errheader, sizeof(ERR_HEADER));
			
			infLOG(ALWAY, " ]FileRequestList: М­Йі ЦФРЯ ОјРН (%s)", szFullPath);
			
			delete[] pResult;
		
			return -RS_FILE_DATA_TRANSFER;
		}
		else if(headers.nDataCnt == 0) 
		{
			headers.nCmd = RS_EOL;
		
			headers.nDataCnt =0;
			headers.nDataSize = 0;
			headers.nErrorCode = 0;
			
			pSendData = new char[sizeof(HEADER) + headers.nDataCnt * headers.nDataSize];
		
			memset(pSendData,0x00,sizeof(HEADER) + headers.nDataCnt * headers.nDataSize);
			memcpy(pSendData,&headers,sizeof(HEADER)); //head
			delete[] pResult;
			return 1;
		}
		else if(headers.nDataCnt >= 2000)
		{
			pSendData = new char[sizeof(ERR_HEADER)];
			memset(pSendData,0x00,sizeof(ERR_HEADER));
			errheader.header.nCmd = RS_ERR;
			errheader.header.nErrorCode = -RS_FILE_REQUEST_LIST;
			strcat(errheader.errmsg,"ЧбЦњДѕ ОШПЁ 2000АГ РЬЛѓРЧ ИёЗЯРЛ РлМК ЧвМі ОјНРДЯДй..");
			
			memcpy(pSendData, &errheader, sizeof(ERR_HEADER));
	
			infLOG(ERROR, " ]FileRequestList: ИёЗЯ УЪАњ РлМК (%d)", headers.nDataCnt);
			
			delete[] pResult;
	
			return -RS_FILE_REQUEST_LIST;
		}
		headers.nCmd = RS_FILE_REQUEST_LIST;
	
		
		headers.nDataSize = sizeof(FILEINFO);
		headers.nErrorCode = 0;
		
	
		
		pSendData = new char[sizeof(HEADER) + headers.nDataCnt * headers.nDataSize];
	
		memset(pSendData,0x00,sizeof(HEADER) + headers.nDataCnt * headers.nDataSize);
		memcpy(pSendData,&headers,sizeof(HEADER)); //head
		memcpy(pSendData+sizeof(HEADER),pResult,headers.nDataCnt * headers.nDataSize);
		delete[] pResult;
	}

	
	return (HEADER_SIZE + (headers.nDataCnt * headers.nDataSize));
}



int FileRequestFile(int& Socket,char *pRecvHead, char *pRecvData, char* &pSendData)
{
	#ifdef __DEBUG
	printf("FileRequestFile\n");
	#endif
	LPHEADER pHeader = (LPHEADER)pRecvHead;
	
	ERR_HEADER errheader;
	memset(&errheader,0x00,sizeof(ERR_HEADER));
	
	HEADER headers;
	memset(&headers,0x00,sizeof(HEADER));
	
	LPFILEINFO pFileinfo = (LPFILEINFO)pRecvData;
	
	multimap<int,USERINFO>::iterator mi; //IP СЖШИ
	mi = m_UserList.find(Socket);
	if(mi != m_UserList.end())
	{
		#ifdef __DEBUG
		printf(" ] com9002 УЄХЉ : ( %lu ) == ( %lu )\n",mi->second.gCom9xxx.com9002_R.temp_id ,pFileinfo->nNumber );
		printf(" ] pFileinfo->nTypeDisk = ( %d )\n",pFileinfo->nTypeDisk );
		#endif
		
		
		if(mi->second.gCom9xxx.com9002_R.temp_id != pFileinfo->nNumber || mi->second.gCom9xxx.nStatus == 0 )
		{
			//DB ОїЕЅРЬЦЎ , ЛѕЗЮПю ФСХйУїРЧ НУРл
	
			strcpyA(mi->second.gCom9xxx.com9002_R.server_id , pFileinfo->szServerID);
			
			strcpyA(mi->second.gCom9xxx.com9102_R.server_id , pFileinfo->szServerID);
			mi->second.gCom9xxx.com9002_R.temp_id = pFileinfo->nNumber;
			
			mi->second.gCom9xxx.com9102_R.temp_id = pFileinfo->nNumber;
			
			if(pFileinfo->nTypeDisk == 0x003)//ФСХйУїБИКа(WE:РЇЕ№НКХЉ(0x004), MY:АјАГРкЗсНЧ(0x003), MD:ГЛРкЗсНЧ(0x005))
			{
				strcpyA(mi->second.gCom9xxx.com9002_R.cont_gu,"FD");
				
				strcpyA(mi->second.gCom9xxx.com9102_R.cont_gu,"FD");
			}
			else if(pFileinfo->nTypeDisk == 0x005) 
			{
				strcpyA(mi->second.gCom9xxx.com9002_R.cont_gu,"MD");
				
				strcpyA(mi->second.gCom9xxx.com9102_R.cont_gu,"MD");
			}
			else if(pFileinfo->nTypeDisk == 0x004)
			{
				strcpyA(mi->second.gCom9xxx.com9002_R.cont_gu,"WE");
				
				strcpyA(mi->second.gCom9xxx.com9102_R.cont_gu,"WE");		
			}
			else //exception
			{
				strcpyA(mi->second.gCom9xxx.com9002_R.cont_gu,"ER");
				
				strcpyA(mi->second.gCom9xxx.com9102_R.cont_gu,"ER");
			}
			
			if(mi->second.gCom9xxx.nStatus == 0)
			{
				#ifdef __DEBUG
				printf("ЛчПыРкМі СѕАЁ ++ \n");
				#endif		
				
				com9002(mi->second.gCom9xxx.com9002_R,1); //М­Йі ЛчПыРкМі СѕАЁ
			}
			else
			{
				com9002(mi->second.gCom9xxx.com9002_R,0); //ЛчПыРк МіСЄ
			}
				
			mi->second.gCom9xxx.nStatus = 1;
		}
	}


	
	
	long seq_no; // ПЙУы ..ЕЗАшЛъРЛ РЇЧб НУФіНК ЙјШЃ
	int nError;// ПЁЗЏ СЄКИ РњРх
//	CFDNS3003_R cfdn; //ЛчРЬЙі ИгДЯ АшЛъ
	
	#ifdef __DEBUG
	printf("	ЦФРЯ СЄКИ ШЎРЮ \n"
		   "    file name 		: %s\n"
		   "	file size 		: %.0f\n"
		   "	file path 		: %s\n"
		   "	file DealID     : %d\n"
		   "	file deal_type  : %d\n"
		   "	file owner id   : %s"
		   "	file dndate 	: %d\n"
		   ,pFileinfo->szFileName
		   ,pFileinfo->dFileSize
		   ,pFileinfo->szDownPath
		   ,pFileinfo->dwDealID
		   ,pFileinfo->nDealType
		   ,pFileinfo->szFileOwnerID
		   ,pFileinfo->GroupInfo.DnDate);
	#endif


	
	memset(&headers,0x00,HEADER_SIZE);
	headers.nCmd = RS_FILE_REQUEST_FILE; //ЦФРЯ ПфУЛ
	
	if( pHeader->nCmd == RS_FILE_REQUEST_FILE_GRID )
	{
		headers.nCmd = RS_FILE_REQUEST_FILE_GRID; //ЦФРЯ СЄКИ ПфУЛ
		#ifdef __DEBUG
		printf("RS_FILE_REQUEST_FILE_GRID (%d)\n", headers.nCmd);
		#endif
	

	}
	else
	{
		headers.nCmd = RS_FILE_REQUEST_FILE; //ЦФРЯ СЄКИ ПфУЛ
		#ifdef __DEBUG
		printf("RS_FILE_REQUEST_FILE (%d)\n", headers.nCmd);
		#endif
		
	}
	
	headers.nDataCnt = 0;
	headers.nDataSize = 0;
	
	if(SendData(Socket,(char*)&headers,HEADER_SIZE)<0)  //struct _PACKET == PACKET
	{
		infLOG(ALWAY, " ] SendData Error(RS_FILE_REQUEST_FILE)\n");										
		#ifdef __DEBUG
		printf(" ] SendData Error(RS_FILE_REQUEST_FILE)\n");				
		#endif
		//com9102(mi->second.gCom9xxx.com9102_R);
		return 0;
	}


	
	memset(&headers,0x00,sizeof(HEADER));	
	
			
	if(RecvData(Socket,(char*)&headers,HEADER_SIZE ) < 0)
	{
		infLOG(ERROR, " ]FileRequestFile: RecvData head Error\n");
		return 0;
	}

	if(headers.nCmd == RS_EOL)
	{
		memset(&headers,0x00,HEADER_SIZE);
		
		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));
		
		headers.nCmd = RS_EOL;
		headers.nDataCnt = 0;
		headers.nDataSize = 0;
		
		memcpy(pSendData,&headers,sizeof(HEADER));
		
		infLOG(ERROR, " ]FileRequestFile: ПРЗљ headers.nCmd == RS_EOL (return END)\n");
	
		//com9102(mi->second.gCom9xxx.com9102_R);
		return END;
	}
	else if (headers.nCmd == RS_FILE_REQUEST_NEXT_FILE)
	{
		pHeader->nCmd = RS_FILE_REQUEST_NEXT_FILEINFO; // send ЧЯАд КЏАц
	
		infLOG(ALWAY, " ]FileRequestFile: ДйРН ЦФРЯ ПфУЛ \n");
	
		
		memset(&headers,0x00,HEADER_SIZE);
		
		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));
		
		headers.nCmd = RS_FILE_REQUEST_NEXT_FILEINFO; //ЦФРЯ СЄКИ ПфУЛ
		headers.nDataCnt = 0;
		headers.nDataSize = 0;
		
		memcpy(pSendData,&headers,sizeof(HEADER));
		
		return (HEADER_SIZE + (headers.nDataCnt * headers.nDataSize));//return 1;
			
	}else if(headers.nCmd == RS_GRID_DATA_TRANSFER) //gridБзИЎЕх НУРл
	{
		infLOG(ALWAY, " ]FileRequestFile: БзИЎЕх ЦФРЯ УГИЎ RS_GRID_DATA_TRANSFER \n");
		memset(&headers,0x00,HEADER_SIZE);

		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));

		pHeader->nCmd = RS_GRID_DATA_TRANSFER; // send ЧЯАд КЏАц
		
		
		headers.nCmd = RS_GRID_DATA_TRANSFER; //ЦФРЯ СЄКИ ПфУЛ
		headers.nDataCnt = 0;
		headers.nDataSize = 0;

		memcpy(pSendData,&headers,sizeof(HEADER));

		return (HEADER_SIZE + (headers.nDataCnt * headers.nDataSize));//return 1;
	} //БзИЎЕх ГЁ

	//ПЙПм ЛѓШВ А­Ш­ ХзНКЦЎ ЧиОп Чд
	
	LPFILEHEAD pFileHead = new FILEHEAD;  //head РќМл
	memset(pFileHead,0x00,sizeof(FILEHEAD));

	#ifdef __DEBUG
	printf("FILEHEAD\n");
	#endif
	
	
	infLOG(ALWAY, " ]FileRequestFile: ЦФРЯ РќМл СиКё - ЧиДѕ МіНХ \n");			
	
	if(RecvData(Socket,(char*)pFileHead,sizeof(FILEHEAD))<0)
	{
		infLOG(ERROR, " ]FileRequestFile: ЦФРЯ ЧиДѕ МіНХ ПРЗљ\n");							
		delete pFileHead;
		return 0;
	}
	
	#ifdef __DEBUG	
	printf("	ЦФРЯ ЧиДѕ УЄХЉ  \n"
		   "    file name : %s"
		   "    file size : %.0f"
		   "	sizeof	  : %d\n"
		   ,    pFileHead->szFullFileName
		   ,	pFileHead->dCurrentSize
		   ,	sizeof(FILEHEAD));
	#endif	 
	
	infLOG(ALWAY, "	]FileRequestFile: ЦФРЯ ЧиДѕ УЄХЉ  \n"
				  "    file name : %s\n"
				  "    current get file size : %.0f\n"
				  ,    pFileHead->szFullFileName
				  ,	   pFileHead->dCurrentSize );
	   
	  
	FILE* UploadFile;
	UploadFile = NULL;
	
	double dFileLen = 0;

	
	double nTotalnRecvLen = 0;
	
		//////////ЕЅРЬХЭ РќМл ЗчЦО
	//БзИЎЕхЗЮ РЮЧб МіСЄ
	char szFileFullName[1024];
	memset(szFileFullName,0x00,sizeof(szFileFullName));
	//memcpy(szFileFullName,pFileHead->szFullFileName , strlen(pFileHead->szFullFileName)-32);
	
	char* pFindStr = strchr(pFileinfo->szSrcPath,'|');
	
	if( pFindStr)
	{
		memcpy(szFileFullName,pFileinfo->szSrcPath ,strlen( pFileinfo->szSrcPath) - strlen(pFindStr) );
		strcat(szFileFullName,"/");
		strcat(szFileFullName,pFileinfo->szFileName);
	}
	else
		strcpy(szFileFullName,pFileHead->szFullFileName);
				
	// file open

		
	UploadFile = fopen64(szFileFullName,"rb");
	
	if(UploadFile == NULL)
	{
		infLOG(ERROR, " ]FileRequestFile: UploadFile == NULL ЦФРЯ ОјРН. (%s)\n",pFileHead->szFullFileName);
		
		#ifdef __DEBUG
		printf(" ] FileRequestFile : UploadFile == NULL: <client СзРН>\n");
		printf(" ] file open error : %s \n",pFileHead->szFullFileName);
		#endif
					
		pSendData = new char[sizeof(ERR_HEADER)];
		memset(pSendData,0x00,sizeof(ERR_HEADER));
		errheader.header.nCmd = RS_ERR;
		errheader.header.nErrorCode = -RS_FILE_DATA_TRANSFER;
		strcat(errheader.errmsg,"М­ЙіУј ПЁМ­ ЦФРЯРЬ ОјАХГЊ П­Мі ОјНРДЯДй.");
		
		memcpy(pSendData, &errheader, sizeof(ERR_HEADER));

		delete pFileHead;
		
		pHeader->nCmd = RS_ERR;
		return -RS_FILE_DATA_TRANSFER;

	}
	#ifdef __DEBUG
	printf("Open File [ %s ]\n",szFileFullName);
	#endif
	
	//set file head , РќУМ ЛчРЬСю , ЦФРЯ РЬИЇ
	struct stat64 statbuf;
	
	//БзИЎЕхЗЮ РЮЧб МіСЄ
	int stat = stat64(szFileFullName,&statbuf);
	//int stat = stat64(pFileHead->szFullFileName,&statbuf);


	if(stat != 0) //error
	{
		if(pFileHead != NULL)
			delete pFileHead;
			
		if(errno == ENOENT) //ЦФРЯРЬГЊ ЦаНКАЁ ОјРН
		{
			infLOG(ERROR, " ]FileRequestFile: ЦФРЯ ПРЗљ  errno == ENOENT ( %s ) \n",pFileHead->szFullFileName);				
			
			#ifdef __DEBUG
			printf("Open File ERROR [ %s ]\n",szFileFullName);
			#endif

			pSendData = new char[sizeof(ERR_HEADER)];
			memset(pSendData,0x00,sizeof(ERR_HEADER));
			errheader.header.nCmd = RS_ERR;
			errheader.header.nErrorCode = -RS_FILE_DATA_TRANSFER;
			strcat(errheader.errmsg,"М­ЙіУј ПЁМ­ ЦФРЯРЬ ОјАХГЊ П­Мі ОјНРДЯДй.");
			
			memcpy(pSendData, &errheader, sizeof(ERR_HEADER));
	
			pHeader->nCmd = RS_ERR;
			return -RS_FILE_DATA_TRANSFER;
		}
		return 0;
	}
		
	// ЧіСІ clientПЁ РжДТ ЛчРЬСю ИИХ­ РЬЕП ЧЯБт
//	unsigned long dCurrentLen = pFileHead->dCurrentSize;
	double dCurrentLen = pFileHead->dCurrentSize;

	off64_t current_set = (off64_t)dCurrentLen;

	fseeko64(UploadFile,current_set,SEEK_SET);
	
	 // ЧиДѕ РќМл  НЧСІ ЛчРЬСюПЭ РЬИЇ.
		 
///////////////////////////////////////////////////////////////////////
		 	//ПЙУы РќШЏ.  КЙ
	char DnDate[9];
	memset(DnDate,0x00,9);

	memset(pFileHead,0x00,sizeof(FILEHEAD));

	dFileLen  = (double)statbuf.st_size;
	if(dFileLen < 0 )
		dFileLen = 0;
	
	
	pFileHead->dwID = seq_no;
	if(pFileinfo->GroupInfo.nMode == 3 || pFileinfo->GroupInfo.nMode == 1)
	{
		pFileinfo->GroupInfo.dwID = seq_no;
		strcpyA(pFileinfo->GroupInfo.DnDate,DnDate);
	}
		
	strcpyA(pFileHead->DnDate,DnDate);
	
	pFileHead->dCurrentSize = dFileLen;
	strcpyA(pFileHead->szFullFileName ,pFileinfo->szFileName);
	
	#ifdef __DEBUG
	printf("	ЦФРЯ ШЎРЮ\n"
		   "    file seq = %lu : file name : %s  : dn date = %s :"
		   "    file size : %.0f\n"
		   ,	pFileHead->dwID
		   ,    pFileHead->szFullFileName
		   ,	DnDate
		   ,	pFileHead->dCurrentSize);
	#endif

	infLOG(ALWAY, " ]FileRequestFile: ЦФРЯ ШЎРЮ\n"                          
				  "   file seq = %lu : file name : %s  : dn date = %s \n"
				  "   file size : %.0f\n"                            
				,	pFileHead->dwID                                  
				,    pFileHead->szFullFileName                        
				,	DnDate                                           
				,	pFileHead->dCurrentSize);                        
				
		

	                                                  
                                                      
		//ЕЅРЬХЭ РќМл	                                
		                                              
			/////////////////////////////             
			                                          

		
		memset(&headers,0x00,HEADER_SIZE);
	
		headers.nCmd = RS_FILE_DATA_TRANSFER;
		headers.nDataCnt = 1;
		headers.nDataSize = sizeof(FILEHEAD);
	
	
		char* pSendBuffer = new char[HEADER_SIZE + headers.nDataCnt*headers.nDataSize ];
		memset(pSendBuffer, 0x00, HEADER_SIZE + headers.nDataCnt*headers.nDataSize );

		memcpy(pSendBuffer,&headers,sizeof(HEADER)); //head
		memcpy(pSendBuffer + HEADER_SIZE,pFileHead,headers.nDataCnt * headers.nDataSize); //body	
		

		
		infLOG(ALWAY, " ]FileRequestFile: ЦФРЯ ЧиДѕ МлНХ\n");
		if(	SendData(Socket,pSendBuffer,HEADER_SIZE + headers.nDataCnt*headers.nDataSize)<=0)  //struct _PACKET == PACKET
		{
			infLOG(ALWAY, " ]FileRequestFile: ЦФРЯ ЧиДѕ МлНХ ПРЗљ\n");
			
			#ifdef __DEBUG
			printf("SEND RS_FILE_DATA_TRANSFER ERROR\n");
			#endif

			
			delete[] pSendBuffer;
			delete pFileHead;

			//com9102(mi->second.gCom9xxx.com9102_R);
			return 0;
			
		}
		#ifdef __DEBUG
		printf("SEND RS_FILE_DATA_TRANSFER\n");
		#endif
				
		delete[] pSendBuffer;
		delete pFileHead;
	
		
		//////////ЕЅРЬХЭ РќМл ЗчЦО
		double dTotalLen = dFileLen;
		double dTempTotalLen = dTotalLen;
		dTotalLen = dTotalLen - dCurrentLen; //ЧіРч РЬЕПЧб ИИХ­ АшЛъ
		
		int nReadLen=0;
		int nSendLen=0;

		int nStop = 0;
	
		
		
//		char* szSendBuffer = new char[SENDBUF];
		char szSendBuffer[SENDBUF];
	
		
		
		////[][]
		
		
		#ifdef __DEBUG
		printf("Checking File (%s) : ЦФРЯ РќУМ БцРЬ (%.0f ) = ( %.0f - %.0f )\n",pFileinfo->szFileName , dTotalLen ,pFileinfo->dFileSize ,dCurrentLen);
		#endif
				
		infLOG(ALWAY," ]FileRequestFile: (%lu)"
					 "Checking File (%s) : ЦФРЯ РќУМ БцРЬ (%.0f ) = ( %.0f - %.0f )"
					 , pFileinfo->dwDealID
					 ,pFileinfo->szFileName , dTotalLen ,pFileinfo->dFileSize ,dCurrentLen);

		int fno = fileno(UploadFile);
	   

		//off_t offset = 0;
		
					
		while(dTotalLen > 0 && !nStop )
    	{   
	    	
			memset(szSendBuffer,0x00,SENDBUF);
			nReadLen = read(fno,szSendBuffer,SENDBUF);    
	    
	    	if(nReadLen > 0 )
	    		nSendLen = SendData(Socket,szSendBuffer,nReadLen);
	    	else
	    		nSendLen = 0;
	        
	        if(nSendLen <= 0)
	        {
	        	#ifdef __DEBUG
	        	printf("-=----------- ПЙПм ЛѓШВ ЦФРЯ ЙоБт ------11\n");
	        	#endif
	        	
	        	if(nSendLen < 0)
	        	{
	        		char szErrMsg[1024];
					memset(szErrMsg,0x00,sizeof(szErrMsg));
					GetErrMsg(-nSendLen,szErrMsg);
					infLOG(ERROR, " ]FileRequestFile: SendSocket Error ( %d ) ( %d )( %s )\n",nReadLen ,nSendLen,szErrMsg); 
					
					#ifdef __DEBUG
					printf(" ] SendSocket Error ( %d ) ( %d )( %s )\n",nReadLen ,nSendLen,szErrMsg); 
					#endif
					

	        	}
	        	else if(nSendLen == 0)
	        	{
	        		infLOG(ERROR, " ]FileRequestFile: SendSocket Error ( %d ) ( СЂМгРЛ ВїОњНРДЯДй. )\n",nReadLen ); 
					
					#ifdef __DEBUG
					printf(" ] SendSocket Error ( %d ) ( СЂМгРЛ ВїОњНРДЯДй. )\n",nReadLen );
					#endif
	        	}
	        	
	        	infLOG(ERROR, " ]FileRequestFile: ЦФРЯ РќМл УыМв \n"); 
	       
				//КИГЛДйАЁ ПРЗљАЁ ГЕРЛНУ...DBУГИЎ
				
				if(UploadFile)
					fclose(UploadFile);
				return 0;
	        	
	        }
	        
	        
	        dTotalLen = dTotalLen - (double)nSendLen;
	    	nTotalnRecvLen = nTotalnRecvLen + (double)nSendLen;

	   
	}

		#ifdef __DEBUG
	    printf("\r  ./dTotalLen = %.0f totalsend len = %.0f   send len = %d\n",dTotalLen, nTotalnRecvLen,nSendLen);
	    #endif

		//if(nReadLen != -1 && UploadFile)
		if(UploadFile)
			fclose(UploadFile);
		
		/*
		if(szSendBuffer)
			delete[] szSendBuffer;
		*/


	//infLOG(ERROR," ] ДйПюЗЮЕх ПЯЗс : user %s :  File (%s) \n",mi->second.gCom9xxx.com9102_R.user_id, pFileinfo->szFileName);

	#ifdef __DEBUG
	printf("ДйПюЗЮЕх ПЯЗс : DealId (%lu) : user %s :  File (%s) \n",pFileinfo->dwDealID ,mi->second.gCom9xxx.com9102_R.user_id, pFileinfo->szFileName);
	#endif


	unsigned long ulDealID = pFileinfo->dwDealID;
	
	char szUserID[20];
	memset(szUserID, 0x00, sizeof(szUserID));
	
	sprintf(szUserID, "%s", mi->second.gCom9xxx.com9102_R.user_id);
	
	char szFileNM[1024];
	memset(szFileNM, 0x00, sizeof(szFileNM));
	
	sprintf(szFileNM, "%s", pFileinfo->szFileName);

	infLOG(ALWAY," > ДйПюЗЮЕх ПЯЗс : DealId (%lu) : user %s :  File (%s) \n",ulDealID , szUserID, szFileNM);

	return 1;
}















//
//СЄОзСІ УГРН ХИДТ КЮКа

int FileRequestFileWithHoldTime(int& Socket,char *pRecvHead, char *pRecvData, char* &pSendData)
{
	//infLOG(ALWAY, " ] СЄОзСІ ЙоБт \n\n\n");	

	/////////////// ОЦРЬЕ№ РЮСѕ РлОї ЧЯБт //////////////////////
	// fileinfoИІ ОђБт РЇЧи ...
	//////////////////////////////////////////////////////////
	
	LPHEADER pHeader = (LPHEADER)pRecvHead;
	
	ERR_HEADER errheader;
	memset(&errheader,0x00,sizeof(ERR_HEADER));
	
	HEADER headers;
	memset(&headers,0x00,sizeof(HEADER));
	
	LPFILEINFO pFileinfo = (LPFILEINFO)pRecvData;
	
	//9002 ДйПюЗЮЕх НУРл
	//9102 ДйПюЗЮЕх ГЁ

	multimap<int,USERINFO>::iterator mi; //IP СЖШИ
	//mi = m_UserList.begin();
	mi = m_UserList.find(Socket);
	if(mi != m_UserList.end())
	{	
		#ifdef __DEBUG
		printf(" ] com9002 УЄХЉ : ( %lu ) == ( %lu )\n",mi->second.gCom9xxx.com9002_R.temp_id ,pFileinfo->nNumber );
		printf(" ] pFileinfo->nTypeDisk = ( %d )\n",pFileinfo->nTypeDisk );
		#endif
		
		if(mi->second.gCom9xxx.com9002_R.temp_id != pFileinfo->nNumber || mi->second.gCom9xxx.nStatus == 0 )
		{
			//DB ОїЕЅРЬЦЎ , ЛѕЗЮПю ФСХйУїРЧ НУРл
			#ifdef __DEBUG
			printf(" ] com9002 НУРл\n");
			#endif		
			
			strcpyA(mi->second.gCom9xxx.com9002_R.server_id , pFileinfo->szServerID);
			strcpyA(mi->second.gCom9xxx.com9102_R.server_id , pFileinfo->szServerID);
			mi->second.gCom9xxx.com9002_R.temp_id = pFileinfo->nNumber;
			mi->second.gCom9xxx.com9102_R.temp_id = pFileinfo->nNumber;
			
			if(pFileinfo->nTypeDisk == 0x003)//ФСХйУїБИКа(WE:РЇЕ№НКХЉ(0x004), MY:АјАГРкЗсНЧ(0x003), MD:ГЛРкЗсНЧ(0x005))
			{
				strcpyA(mi->second.gCom9xxx.com9002_R.cont_gu,"FD");
				strcpyA(mi->second.gCom9xxx.com9102_R.cont_gu,"FD");
			}
			else if(pFileinfo->nTypeDisk == 0x005) 
			{
				strcpyA(mi->second.gCom9xxx.com9002_R.cont_gu,"MD");
				strcpyA(mi->second.gCom9xxx.com9102_R.cont_gu,"MD");
			}
			else if(pFileinfo->nTypeDisk == 0x004)
			{
				strcpyA(mi->second.gCom9xxx.com9002_R.cont_gu,"WE");
				strcpyA(mi->second.gCom9xxx.com9102_R.cont_gu,"WE");		
			}
			else //exception
			{
				strcpyA(mi->second.gCom9xxx.com9002_R.cont_gu,"ER");
				strcpyA(mi->second.gCom9xxx.com9102_R.cont_gu,"ER");
			}
			
	
			
			if(mi->second.gCom9xxx.nStatus == 0)
			{
				#ifdef __DEBUG
				printf(" ] ЛчПыРкМі СѕАЁ ++ \n");
				#endif		
				
				com9002(mi->second.gCom9xxx.com9002_R,1); //М­Йі ЛчПыРкМі СѕАЁ , ЛчПыРк МіСЄ
				////com9102(mi->second.gCom9xxx.com9102_R);	
			}
			else
			{
				com9002(mi->second.gCom9xxx.com9002_R,0); //ЛчПыРк МіСЄ
			}
				
			mi->second.gCom9xxx.nStatus = 1;
	
						
	
		}

	}
	
	
	long seq_no; // ПЙУы ..ЕЗАшЛъРЛ РЇЧб НУФіНК ЙјШЃ
	int nError;// ПЁЗЏ СЄКИ РњРх

	if(pFileinfo->nDealType)
	{
		
		char szSendData[HEADER_SIZE + sizeof(HOLDTIME)];
		memset(szSendData,0x00,sizeof(HEADER) + sizeof(HOLDTIME));

		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));
		
		HOLDTIME hold_time;
		
		memset(&headers,0x00,sizeof(HEADER));		
		if( pHeader->nCmd == RS_FILE_REQUEST_FILE_WITH_HOLD_TIME_GRID )
		{
			#ifdef __DEBUG
			printf("RS_FILE_REQUEST_FILE_WITH_HOLD_TIME_GRID\n");
			#endif
			
			
			headers.nCmd = RS_FILE_REQUEST_FILE_WITH_HOLD_TIME_GRID; //ЦФРЯ СЄКИ ПфУЛ
		}
		else
		{
			#ifdef __DEBUG
			printf("RS_FILE_REQUEST_FILE_WITH_HOLD_TIME\n");
			#endif
			
			
			headers.nCmd = RS_FILE_REQUEST_FILE_WITH_HOLD_TIME; //ЦФРЯ СЄКИ ПфУЛ
		}
		headers.nDataCnt = 1;
		headers.nDataSize = sizeof(HOLDTIME);			
		headers.nErrorCode = 0;
		/*
		char szErrMsg[255];
		memset(szErrMsg,0x00,sizeof(szErrMsg));
		*/
		//СЄОзСІ ЧіРч НУАЃ КИГЛБт
		#ifdef __DEBUG
		printf("pFileinfo->nDealType [ %d ]\n",pFileinfo->nDealType);
		#endif
		
		if( com9006(pFileinfo->dwDealID ,(char*)&hold_time,errheader.errmsg) < 0 )
		{
			pSendData = new char[sizeof(ERR_HEADER)];
			memset(pSendData,0x00,sizeof(ERR_HEADER));
			errheader.header.nCmd = RS_ERR;
			errheader.header.nErrorCode = -RS_FILE_REQUEST_FILE_WITH_HOLD_TIME;
			
			memcpy(pSendData, &errheader, sizeof(ERR_HEADER));
	
			pHeader->nCmd = RS_ERR;
			return -RS_FILE_REQUEST_FILE_WITH_HOLD_TIME;
					
		}
		
		int nRet = 0;
		
	

		#ifdef __DEBUG
		printf("hold_time.nHoldTimeMode [ %d ] != 0 \n",hold_time.nHoldTimeMode);
		#endif
			
		memcpy(szSendData,&headers,sizeof(HEADER)); //head
		memcpy(szSendData+sizeof(HEADER),(char*)&hold_time,headers.nDataCnt * headers.nDataSize);
		
		if(SendData(Socket,szSendData,HEADER_SIZE + headers.nDataCnt * headers.nDataSize )<0)  //struct _PACKET == PACKET
		{
			infLOG(ERROR, " ]FileRequestFileWithHoldTime:  ERROR Exception ) SendData (RS_FILE_REQUEST_FILE)\n");										
			#ifdef __DEBUG
			printf("RS_FILE_REQUEST_FILE_WITH_HOLD_TIME : send ПЁЗЏ 1 : <client СзРН>\n");
			#endif
			return 0;
		}
		
		
						
	}
	else
	{
		
		#ifdef __DEBUG
		printf("//-----------------------------------------------\n"
			   "//СЄОзСІ ЙќРЇ ЙўОюГВ 							 \n"
			   "//-----------------------------------------------\n");
		#endif
		
		memset(&headers,0x00,HEADER_SIZE);
		headers.nCmd = RS_FILE_REQUEST_FILE; //ЦФРЯ ПфУЛ
		headers.nDataCnt = 0;
		headers.nDataSize = 0;

		if(SendData(Socket,(char*)&headers,HEADER_SIZE)<0)  //struct _PACKET == PACKET
		{
			infLOG(ALWAY, " ]FileRequestFileWithHoldTime:  ERROR Exception ) SendData (RS_FILE_REQUEST_FILE)\n");										
			#ifdef __DEBUG
			printf("FileRequestFile : send ПЁЗЏ 1 : <client СзРН>\n");
			#endif
			//com9102(mi->second.gCom9xxx.com9102_R);
			return 0;
		}		
	}

	infLOG(ALWAY, " ]FileRequestFileWithHoldTime: SendData (RS_FILE_REQUEST_FILE)\n");								
	
	#ifdef __DEBUG
	printf("SEND FileRequestFileWithHoldTime\n");
	#endif
	// clientПЁМ­ headerРЛ МіНХ


	
	memset(&headers,0x00,sizeof(HEADER));

	infLOG(ALWAY, " ]FileRequestFileWithHoldTime: Recv Header  \n");								
		
	if(RecvData(Socket,(char*)&headers,HEADER_SIZE ) < 0)
	{
		infLOG(ERROR, " ]FileRequestFileWithHoldTime: ERROR Recv Header < 0 \n");								
		
		#ifdef __DEBUG
		printf("FileRequestFile : recv ПЁЗЏ 1 : <client СзРН>\n");
		#endif
		//com9102(mi->second.gCom9xxx.com9102_R);
		return 0;
	}
	#ifdef __DEBUG
	printf("Recv headers.nCmd (%d) \n",headers.nCmd);	
	#endif
	
	infLOG(ALWAY, " ]FileRequestFileWithHoldTime: headers.nCmd (%d) \n",headers.nCmd);								

	if(headers.nCmd == RS_EOL)
	{
		#ifdef __DEBUG
		printf("RS_EOL\n");
		#endif
				
		memset(&headers,0x00,HEADER_SIZE);
		
		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));
		
		headers.nCmd = RS_EOL;
		headers.nDataCnt = 0;
		headers.nDataSize = 0;
		
		memcpy(pSendData,&headers,sizeof(HEADER));
		
		infLOG(ALWAY, " ]FileRequestFileWithHoldTime: headers.nCmd == RS_EOL (return END)\n");								
	
		return END;
		
	}
	else if (headers.nCmd == RS_FILE_REQUEST_NEXT_FILE)
	{

		#ifdef __DEBUG
		printf("RS_FILE_REQUEST_NEXT_FILE\n");
		#endif
				
		pHeader->nCmd = RS_FILE_REQUEST_NEXT_FILEINFO; // send ЧЯАд КЏАц
	
		infLOG(ALWAY, " ]FileRequestFileWithHoldTime: RS_FILE_REQUEST_NEXT_FILEINFO \n");	
	
		
		memset(&headers,0x00,HEADER_SIZE);
		
		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));
		
		headers.nCmd = RS_FILE_REQUEST_NEXT_FILEINFO; //ЦФРЯ СЄКИ ПфУЛ
		headers.nDataCnt = 0;
		headers.nDataSize = 0;
		
		memcpy(pSendData,&headers,sizeof(HEADER));
		
		#ifdef __DEBUG
		printf("  ./sucessed FileRequestNextFile...\n");
		#endif
		return (HEADER_SIZE + (headers.nDataCnt * headers.nDataSize));//return 1;
			
	}else if(headers.nCmd == RS_GRID_DATA_TRANSFER) //БзИЎЕх НУРл
	{
		#ifdef __DEBUG
		printf("RS_GRID_DATA_TRANSFER\n");
		#endif

		infLOG(ALWAY, " ]FileRequestFileWithHoldTime: БзИЎЕх ЦФРЯ УГИЎ RS_GRID_DATA_TRANSFER \n");
		memset(&headers,0x00,HEADER_SIZE);

		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));

		pHeader->nCmd = RS_GRID_DATA_TRANSFER; // send ЧЯАд КЏАц
		
		
		headers.nCmd = RS_GRID_DATA_TRANSFER; //ЦФРЯ СЄКИ ПфУЛ
		headers.nDataCnt = 0;
		headers.nDataSize = 0;

		memcpy(pSendData,&headers,sizeof(HEADER));

		return (HEADER_SIZE + (headers.nDataCnt * headers.nDataSize));//return 1;
	}

		
	//ПЙПм ЛѓШВ А­Ш­ ХзНКЦЎ ЧиОп Чд
	
	LPFILEHEAD pFileHead = new FILEHEAD;  //head РќМл
	memset(pFileHead,0x00,sizeof(FILEHEAD));


	infLOG(ALWAY, " ]FileRequestFileWithHoldTime: Recv FILEHEAD \n");								
	
	if(RecvData(Socket,(char*)pFileHead,sizeof(FILEHEAD))<0)
	{
		infLOG(ERROR, " ]FileRequestFileWithHoldTime: ERROR Exception ) Recv FILEHEAD \n");								

		#ifdef __DEBUG
		printf("FileRequestFile : recv filehead ПЁЗЏ : <client СзРН>\n");
		#endif
		
		delete pFileHead;
		//com9102(mi->second.gCom9xxx.com9102_R);
		return 0;
	}
	
	#ifdef __DEBUG	
	printf("	ЦФРЯ ЧиДѕ УЄХЉ HOLD  \n"
		   "    file name : %s"
		   "    file size : %.0f"
		   "	sizeof	  : %d\n"
		   ,    pFileHead->szFullFileName
		   ,	pFileHead->dCurrentSize
		   ,	sizeof(FILEHEAD));
	#endif	 
	
	infLOG(ALWAY, " ]FileRequestFileWithHoldTime: ЦФРЯ ЧиДѕ УЄХЉ\n"
				  "    file name : %s\n"
				  "    current get file size : %.0f\n"
				  ,    pFileHead->szFullFileName
				  ,	   pFileHead->dCurrentSize );
	   
	  
	FILE* UploadFile;
	UploadFile = NULL;
	
	double dFileLen = 0;

	
	double nTotalnRecvLen = 0;
	
		//////////ЕЅРЬХЭ РќМл ЗчЦО
		
	//БзИЎЕхЗЮ РЮЧб МіСЄ
	char szFileFullName[1024];
	memset(szFileFullName,0x00,sizeof(szFileFullName));
	//memcpy(szFileFullName,pFileHead->szFullFileName , strlen(pFileHead->szFullFileName)-32);
	char* pFindStr = strchr(pFileinfo->szSrcPath,'|');
	if( pFindStr)
	{
		memcpy(szFileFullName,pFileinfo->szSrcPath ,strlen( pFileinfo->szSrcPath) - strlen(pFindStr) );
		strcat(szFileFullName,"/");
		strcat(szFileFullName,pFileinfo->szFileName);
	}
	else
		strcpy(szFileFullName,pFileHead->szFullFileName);
	
		
	UploadFile = fopen64(szFileFullName,"rb");
	//UploadFile = fopen64(pFileHead->szFullFileName,"rb");
	//БзИЎЕхЗЮ РЮЧб МіСЄ
		
	if(UploadFile == NULL)
	{
		infLOG(ERROR, " ]FileRequestFileWithHoldTime: ERROR Exception ) UploadFile == NULL (%s)\n",pFileHead->szFullFileName);
		
		#ifdef __DEBUG
		printf("FileRequestFile : UploadFile == NULL: <client СзРН>\n");
		printf("  ./file open error : %s \n",pFileHead->szFullFileName);
		#endif
		
		ERR_HEADER errheader;
		memset(&errheader,0x00,sizeof(ERR_HEADER));
		pSendData = new char[sizeof(ERR_HEADER)];
		memset(pSendData,0x00,sizeof(ERR_HEADER));
		errheader.header.nCmd = RS_ERR;
		errheader.header.nErrorCode = -RS_FILE_DATA_TRANSFER;
		strcat(errheader.errmsg,"М­ЙіУј ПЁМ­ ЦФРЯРЬ ОјАХГЊ П­Мі ОјНРДЯДй.");
		
		memcpy(pSendData, &errheader, sizeof(ERR_HEADER));

		delete pFileHead;
		
		pHeader->nCmd = RS_ERR;
		//com9102(mi->second.gCom9xxx.com9102_R);
		return -RS_FILE_DATA_TRANSFER;
	
	}
		
	#ifdef __DEBUG
	printf("Open File [ %s ]\n",szFileFullName);
	#endif
			
		
	//set file head , РќУМ ЛчРЬСю , ЦФРЯ РЬИЇ
	
	
	struct stat64 statbuf;
	
	//grid
	//int stat = stat64(pFileHead->szFullFileName,&statbuf);
	int stat = stat64(szFileFullName,&statbuf);


	if(stat != 0) //error
	{
		infLOG(ERROR, " ]FileRequestFileWithHoldTime: Exception ) stat != 0\n");
		
		if(pFileHead != NULL)
			delete pFileHead;
			
		if(errno == ENOENT) //ЦФРЯРЬГЊ ЦаНКАЁ ОјРН
		{
			infLOG(ALWAY, " ]FileRequestFileWithHoldTime: ERROR Exception ) errno == ENOENT \n");				
			
			#ifdef __DEBUG
			printf("  ./file create error : %s \n",pFileHead->szFullFileName);
			#endif
							
							
			
			pSendData = new char[sizeof(ERR_HEADER)];
			memset(pSendData,0x00,sizeof(ERR_HEADER));
			errheader.header.nCmd = RS_ERR;
			errheader.header.nErrorCode = -RS_FILE_DATA_TRANSFER;
			strcat(errheader.errmsg,"М­ЙіУј ПЁМ­ ЦФРЯРЬ ОјАХГЊ П­Мі ОјНРДЯДй.");
			
			memcpy(pSendData, &errheader, sizeof(ERR_HEADER));
	
			pHeader->nCmd = RS_ERR;
			//com9102(mi->second.gCom9xxx.com9102_R);
			return -RS_FILE_DATA_TRANSFER;

			
		}
		//com9102(mi->second.gCom9xxx.com9102_R);
		return 0;
		
	}
	
		

	
	// ЧіСІ clientПЁ РжДТ ЛчРЬСю ИИХ­ РЬЕП ЧЯБт
	//	unsigned long dCurrentLen = pFileHead->dCurrentSize;
	double dCurrentLen = pFileHead->dCurrentSize;

	off64_t current_set = (off64_t)dCurrentLen;

/*	
	#ifdef __DEBUG
	printf("  ./ check size 64 bit : %.0f / %.0f\n",(double)current_set,dCurrentLen);
	#endif
*/	
	fseeko64(UploadFile,current_set,SEEK_SET);
	
	 // ЧиДѕ РќМл  НЧСІ ЛчРЬСюПЭ РЬИЇ.
	 
		 
		 
///////////////////////////////////////////////////////////////////////
		 	//ПЙУы РќШЏ.  КЙ
	char DnDate[9];
	memset(DnDate,0x00,9);

	memset(pFileHead,0x00,sizeof(FILEHEAD));

	dFileLen  = (double)statbuf.st_size;;
	if(dFileLen < 0 )
		dFileLen = 0;
		
	pFileHead->dwID = seq_no;
	if(pFileinfo->GroupInfo.nMode == 3 || pFileinfo->GroupInfo.nMode == 1)
	{
		pFileinfo->GroupInfo.dwID = seq_no;
		strcpyA(pFileinfo->GroupInfo.DnDate,DnDate);
	}
		
	strcpyA(pFileHead->DnDate,DnDate);
	
	pFileHead->dCurrentSize = dFileLen;
	strcpyA(pFileHead->szFullFileName ,pFileinfo->szFileName);

	
	#ifdef __DEBUG
	printf("	ЦФРЯ ШЎРЮ\n"
		   "    file seq = %lu : file name : %s  : dn date = %s :"
		   "    file size : %.0f\n"
		   ,	pFileHead->dwID
		   ,    pFileHead->szFullFileName
		   ,	DnDate
		   ,	pFileHead->dCurrentSize);
	#endif

	infLOG(ALWAY, " ]FileRequestFileWithHoldTime: ЦФРЯ ШЎРЮ\n"                          
				  "   file seq = %lu : file name : %s  : dn date = %s \n"
				  "   file size : %.0f\n"                            
				,	pFileHead->dwID                                  
				,    pFileHead->szFullFileName                        
				,	DnDate                                           
				,	pFileHead->dCurrentSize);                        
				
				

	                                                  
                                                      
	//ЕЅРЬХЭ РќМл	                                
	                                              
		/////////////////////////////             
		                                          
	#ifdef __DEBUG
	printf("  ./make file head\n");
	#endif
	
	memset(&headers,0x00,HEADER_SIZE);

	headers.nCmd = RS_FILE_DATA_TRANSFER;
	headers.nDataCnt = 1;
	headers.nDataSize = sizeof(FILEHEAD);


	char* pSendBuffer = new char[HEADER_SIZE + headers.nDataCnt*headers.nDataSize ];
	memset(pSendBuffer, 0x00, HEADER_SIZE + headers.nDataCnt*headers.nDataSize );

	memcpy(pSendBuffer,&headers,sizeof(HEADER)); //head
	memcpy(pSendBuffer + HEADER_SIZE,pFileHead,headers.nDataCnt * headers.nDataSize); //body	
	
	#ifdef __DEBUG
	printf("  ./send head size : %d \n",HEADER_SIZE + headers.nDataCnt*headers.nDataSize);
	#endif
	
	
	infLOG(ALWAY, " ]FileRequestFileWithHoldTime: Send File Head\n");
   		
	if(	SendData(Socket,pSendBuffer,HEADER_SIZE + headers.nDataCnt*headers.nDataSize)<=0)  //struct _PACKET == PACKET
	{
		infLOG(ERROR, " ]FileRequestFileWithHoldTime: ERROR Exception )Send File Head");
		
		#ifdef __DEBUG
		printf("FileRequestFile : send ПЁЗЏ ПЙУыБн КЙПј 1: <client СзРН>");
		#endif
		
		delete[] pSendBuffer;
		delete pFileHead;

		//com9102(mi->second.gCom9xxx.com9102_R);
		return 0;
		
	}
	
	delete[] pSendBuffer;
	delete pFileHead;

	
	//////////ЕЅРЬХЭ РќМл ЗчЦО
	double dTotalLen = dFileLen;
	double dTempTotalLen = dTotalLen;
	dTotalLen = dTotalLen - dCurrentLen; //ЧіРч РЬЕПЧб ИИХ­ АшЛъ
	
	int nReadLen=0;
	int nSendLen=0;

	int nStop = 0;

	
	
	//char* szSendBuffer = new char[SENDBUF];
	char szSendBuffer[SENDBUF];
	
	
	////[][]
	
	infLOG(ALWAY, " ] Send File Data\n");
	#ifdef __DEBUG
	printf("Checking File (%s) : ЦФРЯ РќУМ БцРЬ (%.0f ) = ( %.0f - %.0f )\n",pFileinfo->szFileName , dTotalLen ,pFileinfo->dFileSize ,dCurrentLen);
	#endif


	infLOG(ALWAY," ]FileRequestFileWithHoldTime: (%lu)\n"
	             "   Checking File (%s) : ЦФРЯ РќУМ БцРЬ (%.0f ) = ( %.0f - %.0f )\n"
	             , pFileinfo->dwDealID
	             ,pFileinfo->szFileName , dTotalLen ,pFileinfo->dFileSize ,dCurrentLen);


	int fno = fileno(UploadFile);
   

	//off_t offset = 0;
	
				
	while(dTotalLen > 0 && !nStop )
	{   
    	
		memset(szSendBuffer,0x00,SENDBUF);
		nReadLen = read(fno,szSendBuffer,SENDBUF);    
    
    	if(nReadLen > 0 )
    		nSendLen = SendData(Socket,szSendBuffer,nReadLen);
    	else
    		nSendLen = 0;
        
        if(nSendLen <= 0)
        {
        	#ifdef __DEBUG
        	printf("-=----------- ПЙПм ЛѓШВ ЦФРЯ ЙоБт ------11\n");
        	#endif
        	if(nSendLen < 0)
        	{
        		char szErrMsg[1024];
				memset(szErrMsg,0x00,sizeof(szErrMsg));
				GetErrMsg(-nSendLen,szErrMsg);
				infLOG(ERROR, " ]FileRequestFileWithHoldTime: Check ) RecvSocket Error ( %d ) ( %d )( %s )\n",nReadLen ,nSendLen,szErrMsg); 
				
				#ifdef __DEBUG
				printf("RecvSocket Error ( %d ) ( %d )( %s )\n",nReadLen ,nSendLen,szErrMsg); 
				#endif
				

        	}
        	else if(nSendLen == 0)
        	{
        		infLOG(ERROR, " ]FileRequestFileWithHoldTime: Check ) RecvSocket Error ( %d ) ( СЂМгРЛ ВїОњНРДЯДй. )\n",nReadLen ); 
				
				#ifdef __DEBUG
				printf("RecvSocket Error ( %d ) ( СЂМгРЛ ВїОњНРДЯДй. )\n",nReadLen );
				#endif
        	}   
        	
			infLOG(ERROR, " ]FileRequestFileWithHoldTime: ЦФРЯ РќМл УыМв\n");	        	
       
			//КИГЛДйАЁ ПРЗљАЁ ГЕРЛНУ...DBУГИЎ
			
			if(UploadFile)
				fclose(UploadFile);
			/*
			if(szSendBuffer != NULL)
				delete[] szSendBuffer;
			*/
			//com9102(mi->second.gCom9xxx.com9102_R);
			return 0;
        	
        }
        
        
        dTotalLen = dTotalLen - (double)nSendLen;
    	nTotalnRecvLen = nTotalnRecvLen + (double)nSendLen;
	}

	#ifdef __DEBUG
    printf("\r  ./dTotalLen = %.0f totalsend len = %.0f   send len = %d\n",dTotalLen, nTotalnRecvLen,nSendLen);
    #endif

	if(UploadFile)
		fclose(UploadFile);



	#ifdef __DEBUG
	printf(" FileRequestFileWithHoldTime > \n ДйПюЗЮЕх ПЯЗс : DealId (%lu) : user %s :  File (%s) \n",pFileinfo->dwDealID ,mi->second.gCom9xxx.com9102_R.user_id, pFileinfo->szFileName);
	#endif

	unsigned long ulDealID = pFileinfo->dwDealID;
	
	char szUserID[20];
	memset(szUserID, 0x00, sizeof(szUserID));
	
	sprintf(szUserID, "%s", mi->second.gCom9xxx.com9102_R.user_id);
	
	char szFileNM[1024];
	memset(szFileNM, 0x00, sizeof(szFileNM));
	
	sprintf(szFileNM, "%s", pFileinfo->szFileName);
	

	infLOG(ALWAY," FileRequestFileWithHoldTime >\n > ДйПюЗЮЕх ПЯЗс : DealId (%lu)  user %s :  File (%s) \n",pFileinfo->dwDealID,mi->second.gCom9xxx.com9102_R.user_id, pFileinfo->szFileName);
	
	//com9102(mi->second.gCom9xxx.com9102_R);	
	return 1;

	
}
