extern multimap<int,USERINFO>m_UserList;

int FileRequestNextFile(int& Socket,char *pRecvHead, char *pRecvData, char* &pSendData)
{
	#ifdef __DEBUG	
	printf("  ./loading FileRequestNextFile...\n");
	#endif

	infLOG(ALWAY, "Input ) FileRequestNextFile\n");	

	HEADER headers;
	memset(&headers,0x00,HEADER_SIZE);
	
	pSendData = new char[sizeof(HEADER)];
	memset(pSendData,0x00,sizeof(HEADER));
	
	headers.nCmd = RS_FILE_REQUEST_NEXT_FILEINFO; //파일 정보 요청
	headers.nDataCnt = 0;
	headers.nDataSize = 0;
	
	memcpy(pSendData,&headers,sizeof(HEADER));
	
	#ifdef __DEBUG
	printf("  ./sucessed FileRequestNextFile...\n");
	#endif
	
	infLOG(ALWAY, "Ouput ) FileRequestNextFile\n");	
	return (HEADER_SIZE + (headers.nDataCnt * headers.nDataSize));//return 1;
		
}


int GetFileList(char* path,int nCount,FILEINFO* &pResult,char* pRecvData,char* pSrcPath)
{
	DIR *pdir = NULL;
	//struct stat64 statbuf;
//	int stat = stat64(path,&statbuf); 
/*	
	if(S_ISREG (statbuf.st_mode))
	{
		printf("   ../  %d input file : %s\n ",nCount,pent->d_name);
		
		memcpy(&pResult[nCount],pRecvData,sizeof(FILEINFO));
		
		printf("   ../ port num is : %d  : %d\n",pResult[nCount].dwServerPort,((LPFILEINFO)pRecvData)->dwServerPort);
		pResult[nCount].nType = FT_FILE; //종류
		strcpyA(pResult[nCount].szFileName ,pent->d_name); // 이름
		pResult[nCount].dFileSize = (double)statbuf.st_size; // 크기
		strcpyA(pResult[nCount].szSaveDate , ctime(&statbuf.st_ctime)); //수정날짜
		strcpyA(pResult[nCount].szSrcPath , path);
		
		return 1;
	}
		
*/

	pdir = opendir(path);//strPath); 
	
	
	
	if(pdir == NULL)
	{
		infLOG(ALWAY, " > ERROR Exception ) GetFileList Error ( pdir == NULL )\n");		
		return -1;	
	}
	
	
	
	struct dirent *pent;
	struct stat64 statbuf;
	
	
	char fullpath[612];
	
	
	while( (pent = readdir(pdir)) != NULL )
	{
		memset(fullpath,0x00,sizeof(fullpath));
		strcpyA(fullpath,path);//strPath);
		strcat(fullpath , "/");
		strcat(fullpath, pent->d_name);  
		
		
		int stat= stat64(fullpath,&statbuf); 
	 
	 	if((strcmp(".",pent->d_name) !=0 ) && (strcmp("..",pent->d_name) != 0) && (GetFistCharIndex(pent->d_name,'.') != 0))
		{
	 
			if(S_ISDIR (statbuf.st_mode))
			{
				
				nCount = GetFileList( fullpath,nCount,pResult,pRecvData,pSrcPath);
				if(nCount == -1)
				{
infLOG(ALWAY, " > ERROR Exception ) GetFileList Error ( nCount == -1 )\n");					
					closedir(pdir);
					return -1;
				}
			}
			else
			{
				if(S_ISREG (statbuf.st_mode))
				{
					
					
					memcpy(&pResult[nCount],pRecvData,sizeof(FILEINFO));
					
					long len = strlen(path);
					long src_len = strlen(pSrcPath);
					
					
					if(len > src_len)
					{
						char szAddPath[200];
						memset(szAddPath,0x00,sizeof(char)*200);
						
						if(	GetRightString(path,len - src_len,szAddPath))
						{

							strcat(pResult[nCount].szDownPath,"\\");
							strcat(pResult[nCount].szDownPath,szAddPath);
							StrReplace(pResult[nCount].szDownPath,"/","\\");
							#ifdef __DEBUG
							printf("--> list Down Path (%s)\n",pResult[nCount].szDownPath);
							#endif
							
						}
						
					}
					
					 
					pResult[nCount].nType = FT_FOLDER; //종류
					strcpyA(pResult[nCount].szFileName ,pent->d_name); // 이름
					pResult[nCount].dFileSize = (double)statbuf.st_size; // 크기
				//	strcpyA(pResult[nCount].szSaveDate , ctime(&statbuf.st_ctime)); //수정날짜
					strcpyA(pResult[nCount].szSrcPath , path);
					
					LPFILEINFO pFile = (LPFILEINFO)pRecvData;
					memcpy(&pResult[nCount].GroupInfo,&pFile->GroupInfo,sizeof(FILEGROUPINFO));
					
					nCount++;
				}
				else
				{
				
					
					if(stat != 0 )
						nCount = -1;
					//return -1;
					closedir(pdir);
infLOG(ALWAY, " > ERROR Exception ) GetFileList Error ( S_ISREG (statbuf.st_mode) )\n");										
					return -1;
				}
				
				//change
				if(nCount >= 2000)
				{
					nCount = 2000;
					break;
				}
			}
		}
	}
	
	
	closedir(pdir);
	
	return nCount;
}


int FileRequestList(int& Socket,char *pRecvHead, char *pRecvData, char* &pSendData)
{
	
	LPHEADER pHeader = (LPHEADER)pRecvHead;
	ERR_HEADER errheader;
	memset(&errheader,0x00,sizeof(ERR_HEADER));
	
	HEADER headers;
	memset(&headers,0x00,sizeof(HEADER));
	
	LPFILEINFO pRecv = (LPFILEINFO)pRecvData;
	
	// 파일 목록 얻기 (폴더로 부터)
	
	LPFILEINFO pResult = new FILEINFO[2000]; //2000개의 목록을 보낼수 있다.
	memset(pResult,0x00,sizeof(FILEINFO)*2000);
	
	char szFullPath[612];
	memset(szFullPath,0x00,sizeof(szFullPath));
	
	
	// full path 만들기.
	strcpyA(szFullPath,pRecv->szSrcPath);
	strcat(szFullPath,"/");
	strcat(szFullPath,pRecv->szFileName);
	
	headers.nDataCnt = GetFileList(szFullPath,0,pResult,pRecvData,pRecv->szSrcPath);
	if( headers.nDataCnt< 0 ) //파일 리스트 갯수를 얻는다.
	{
		
		pSendData = new char[sizeof(ERR_HEADER)];
		memset(pSendData,0x00,sizeof(ERR_HEADER));
		errheader.header.nCmd = RS_ERR;
		errheader.header.nErrorCode = -RS_FILE_REQUEST_LIST;
		strcat(errheader.errmsg,"서버측 에서 파일이 없거나 열수 없습니다.");
		
		memcpy(pSendData, &errheader, sizeof(ERR_HEADER));

infLOG(ALWAY, " > ERROR Exception ) FileRequestList Error ( S_ISREG (statbuf.st_mode) )\n");

		delete[] pResult;
	
infLOG(ALWAY, " > ERROR Exception ) GetFileList Error ( S_ISREG (statbuf.st_mode) )\n");

		return -RS_FILE_DATA_TRANSFER;
	}
	else if(headers.nDataCnt == 0) //파일 리스트 갯수를 얻는다.
	{
		
		
		headers.nCmd = RS_EOL;
	
		headers.nDataCnt =0;
		headers.nDataSize = 0;
		headers.nErrorCode = 0;
		
		pSendData = new char[sizeof(HEADER) + headers.nDataCnt * headers.nDataSize];
	
		memset(pSendData,0x00,sizeof(HEADER) + headers.nDataCnt * headers.nDataSize);
		memcpy(pSendData,&headers,sizeof(HEADER)); //head
		delete[] pResult;
		return 1;
	}
	else if(headers.nDataCnt >= 2000)
	{
		pSendData = new char[sizeof(ERR_HEADER)];
		memset(pSendData,0x00,sizeof(ERR_HEADER));
		errheader.header.nCmd = RS_ERR;
		errheader.header.nErrorCode = -RS_FILE_REQUEST_LIST;
		strcat(errheader.errmsg,"한폴더 안에 2000개 이상의 목록을 작성 할수 없습니다..");
		
		memcpy(pSendData, &errheader, sizeof(ERR_HEADER));

infLOG(ALWAY, " > ERROR Exception ) FileRequestList Error ( S_ISREG (statbuf.st_mode) )\n");

		delete[] pResult;
	
infLOG(ALWAY, " > ERROR Exception ) GetFileList Error ( S_ISREG (statbuf.st_mode) )\n");

		return -RS_FILE_REQUEST_LIST;
		
	}
	

	
	  
	headers.nCmd = RS_FILE_REQUEST_LIST;

	
	headers.nDataSize = sizeof(FILEINFO);
	headers.nErrorCode = 0;
	
	pSendData = new char[sizeof(HEADER) + headers.nDataCnt * headers.nDataSize];

	memset(pSendData,0x00,sizeof(HEADER) + headers.nDataCnt * headers.nDataSize);
	memcpy(pSendData,&headers,sizeof(HEADER)); //head
	memcpy(pSendData+sizeof(HEADER),pResult,headers.nDataCnt * headers.nDataSize);
	delete[] pResult;

	
	return (HEADER_SIZE + (headers.nDataCnt * headers.nDataSize));
}



int FileRequestFile(int& Socket,char *pRecvHead, char *pRecvData, char* &pSendData)
{
	infLOG(ALWAY, "Input FileRequestFile \n");								

	#ifdef __DEBUG
	printf("  ./loading .... FileREQUESTFILE\n");
	#endif
	
	/////////////// 아이디 인증 작업 하기 //////////////////////
	// fileinfo를 얻기 위해 ...
	//////////////////////////////////////////////////////////
	
	LPHEADER pHeader = (LPHEADER)pRecvHead;
	
	ERR_HEADER errheader;
	memset(&errheader,0x00,sizeof(ERR_HEADER));
	
	HEADER headers;
	memset(&headers,0x00,sizeof(HEADER));
	
	LPFILEINFO pFileinfo = (LPFILEINFO)pRecvData;
	
	//9002 다운로드 시작
	//9102 다운로드 끝
	
	CCOM9002_R com9002_R;
	memset(&com9002_R , 0x00 , sizeof(CCOM9002_R));
	
	CCOM9102_R com9102_R;
	memset(&com9102_R , 0x00 , sizeof(CCOM9102_R));
	
	multimap<int,USERINFO>::iterator mi; //IP 조회
	//mi = m_UserList.begin();
	mi = m_UserList.find(Socket);
	if(mi != m_UserList.end())
	{		
		strcpyA(com9002_R.conn_ip ,mi->second.thread.userIP);
		//memcpy(com9002_R.conn_ip , mi->first,mi->second.thread.userIP,sizeof(mi->first,mi->second.thread.userIP));
	}
	
	
	memcpy(com9002_R.user_id,pHeader->szUserID,sizeof(pHeader->szUserID));
	strcpyA(com9002_R.server_id , pFileinfo->szServerID);
	com9002_R.temp_id = pFileinfo->nNumber;
	
	#ifdef __DEBUG
	printf("DEBUG > pFileinfo->nTypeDisk = ( %d )\n",pFileinfo->nTypeDisk );
	#endif
		
	if(pFileinfo->nTypeDisk == 0x003)//컨텐츠구분(WE:위디스크(0x004), MY:공개자료실(0x003), MD:내자료실(0x005))
	{
		strcpyA(com9002_R.cont_gu,"FD");
		strcpyA(com9102_R.cont_gu,"FD");
	}
	else if(pFileinfo->nTypeDisk == 0x005) 
	{
		strcpyA(com9002_R.cont_gu,"MD");
		strcpyA(com9102_R.cont_gu,"MD");
	}
	else if(pFileinfo->nTypeDisk == 0x004)
	{
		strcpyA(com9002_R.cont_gu,"WE");
		strcpyA(com9102_R.cont_gu,"WE");		
	}
	else //exception
	{
		strcpyA(com9002_R.cont_gu,"ER");
		strcpyA(com9102_R.cont_gu,"ER");
	}
	
	strcpyA(com9102_R.user_id , com9002_R.user_id);
	strcpyA(com9102_R.server_id , com9002_R.server_id);
	strcpyA(com9102_R.conn_ip , com9002_R.conn_ip);
	com9102_R.temp_id = com9002_R.temp_id;
	
	com9002(com9002_R);
	
	
	
	
	long seq_no; // 예취 ..돈계산을 위한 시퀀스 번호
	int nError;// 에러 정보 저장
//	CFDNS3003_R cfdn; //사이버 머니 계산
	
	#ifdef __DEBUG
	printf("  ./check in file info ...\n"
		   "    file name : %s\n"
		   "	file size : %15.0f\n"
		   "	file path : %s\n"
		   "	file t_m  : %d\n"
		   "	file money: %d\n"
		   "	file owner id : %s"
		   "	file dndate : %d\n"
		   ,pFileinfo->szFileName
		   ,pFileinfo->dFileSize
		   ,pFileinfo->szDownPath
		   ,pFileinfo->nMoneyType 
		   ,pFileinfo->dwMoney
		   ,pFileinfo->szFileOwnerID
		   ,pFileinfo->GroupInfo.DnDate);
	#endif


	memset(&headers,0x00,HEADER_SIZE);
	headers.nCmd = RS_FILE_REQUEST_FILE; //파일 요청
	headers.nDataCnt = 0;
	headers.nDataSize = 0;

infLOG(ALWAY, "->SendData (RS_FILE_REQUEST_FILE)\n");								

	if(SendData(Socket,(char*)&headers,HEADER_SIZE)<0)  //struct _PACKET == PACKET
	{
infLOG(ALWAY, " >ERROR Exception ) SendData (RS_FILE_REQUEST_FILE)\n");										
		#ifdef __DEBUG
		printf("FileRequestFile : send 에러 1 : <client 죽음>\n");
		#endif
		com9102(com9102_R);
		return 0;
	}
	#ifdef __DEBUG
	printf("  ./ send file_request\n");
	#endif
	

//recv 111

	// client에서 header을 수신
	#ifdef __DEBUG
	printf("  ./wait for request\n");
	#endif
	memset(&headers,0x00,sizeof(HEADER));

infLOG(ALWAY, "->Recv Header  \n");								
		
	if(RecvData(Socket,(char*)&headers,HEADER_SIZE ) < 0)
	{
infLOG(ALWAY, " > ERROR Recv Header < 0 \n");								
		
		#ifdef __DEBUG
		printf("FileRequestFile : recv 에러 1 : <client 죽음>\n");
		#endif
		com9102(com9102_R);
		return 0;
	}

infLOG(ALWAY, "->headers.nCmd (%d) \n",headers.nCmd);								

	if(headers.nCmd == RS_EOL)
	{
		#ifdef __DEBUG
		printf("  ./eol\n");
		#endif
	
	
		memset(&headers,0x00,HEADER_SIZE);
		
		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));
		
		headers.nCmd = RS_EOL;
		headers.nDataCnt = 0;
		headers.nDataSize = 0;
		
		memcpy(pSendData,&headers,sizeof(HEADER));
		
infLOG(ALWAY, " > ERROR Exception ) headers.nCmd == RS_EOL (return END)\n");								
	
		com9102(com9102_R);
		return END;
		
	}
	else if (headers.nCmd == RS_FILE_REQUEST_NEXT_FILE)
	{
		#ifdef __DEBUG	
		printf("  ./loading FileRequestNextFile...\n");
		#endif
		pHeader->nCmd = RS_FILE_REQUEST_NEXT_FILEINFO; // send 하게 변경
	
		infLOG(ALWAY, "Input ) FileRequestNextFile\n");	
	
		
		memset(&headers,0x00,HEADER_SIZE);
		
		pSendData = new char[sizeof(HEADER)];
		memset(pSendData,0x00,sizeof(HEADER));
		
		headers.nCmd = RS_FILE_REQUEST_NEXT_FILEINFO; //파일 정보 요청
		headers.nDataCnt = 0;
		headers.nDataSize = 0;
		
		memcpy(pSendData,&headers,sizeof(HEADER));
		
		#ifdef __DEBUG
		printf("  ./sucessed FileRequestNextFile...\n");
		#endif
		
		infLOG(ALWAY, "Ouput ) FileRequestNextFile\n");	
		com9102(com9102_R);
		return (HEADER_SIZE + (headers.nDataCnt * headers.nDataSize));//return 1;
			
	}

	//예외 상황 강화 테스트 해야 함
	
	LPFILEHEAD pFileHead = new FILEHEAD;  //head 전송
	memset(pFileHead,0x00,sizeof(FILEHEAD));

	#ifdef __DEBUG
	printf("  ./loading RECV RS_FILE_REQUEST_Transfer\n");	
	#endif

infLOG(ALWAY, "->Recv FILEHEAD \n");								
	
	if(RecvData(Socket,(char*)pFileHead,sizeof(FILEHEAD))<0)
	{
infLOG(ALWAY, " > ERROR Exception ) Recv FILEHEAD \n");								

		#ifdef __DEBUG
		printf("FileRequestFile : recv filehead 에러 : <client 죽음>\n");
		#endif
		
		delete pFileHead;
		com9102(com9102_R);
		return 0;
	}
	#ifdef __DEBUG	
	printf("  ./recv pFileHead\n");
	
	printf("  ./check in file head \n"
		   "    file name : %s"
		   "    file size : %15.0f"
		   "	sizeof	  : %d\n"
		   ,    pFileHead->szFullFileName
		   ,	pFileHead->dCurrentSize
		   ,	sizeof(FILEHEAD));
	#endif	 
	
infLOG(ALWAY, " <  check in file head \n"
			  "    file name : %s\n"
			  "    file size : %15.0f\n"
			  "    sizeof	  : %d >\n"
			  ,    pFileHead->szFullFileName
			  ,	   pFileHead->dCurrentSize
			  ,    sizeof(FILEHEAD));
   
	  
	FILE* UploadFile;
	UploadFile = NULL;
	
	double dFileLen = 0;

	
	double nTotalnRecvLen = 0;
	
		//////////데이터 전송 루틴
		
		// file open
		UploadFile = fopen64(pFileHead->szFullFileName,"rtb");

	
infLOG(ALWAY, "->Check ) UploadFile \n");
		
		if(UploadFile == NULL)
		{
infLOG(ALWAY, " > ERROR Exception ) UploadFile == NULL (%s)\n",pFileHead->szFullFileName);

#ifdef __DEBUG
printf("FileRequestFile : UploadFile == NULL: <client 죽음>\n");
printf("  ./file open error : %s \n",pFileHead->szFullFileName);
#endif
			
			pSendData = new char[sizeof(ERR_HEADER)];
			memset(pSendData,0x00,sizeof(ERR_HEADER));
			errheader.header.nCmd = RS_ERR;
			errheader.header.nErrorCode = -RS_FILE_DATA_TRANSFER;
			strcat(errheader.errmsg,"서버측 에서 파일이 없거나 열수 없습니다.");
			
			memcpy(pSendData, &errheader, sizeof(ERR_HEADER));

			delete pFileHead;
			
			pHeader->nCmd = RS_ERR;
			com9102(com9102_R);
			return -RS_FILE_DATA_TRANSFER;
	
		}
#ifdef __DEBUG
printf("  ./file create : %s \n",pFileHead->szFullFileName);
#endif
		
		//set file head , 전체 사이즈 , 파일 이름
		
		
		struct stat64 statbuf;
		
		int stat = stat64(pFileHead->szFullFileName,&statbuf);


		if(stat != 0) //error
		{
infLOG(ALWAY, "->Exception ) stat != 0\n");
			if(pFileHead != NULL)
				delete pFileHead;
				
			if(errno == ENOENT) //파일이나 패스가 없음
			{
				
infLOG(ALWAY, " > ERROR Exception ) errno == ENOENT \n");				

#ifdef __DEBUG
printf("  ./file create error : %s \n",pFileHead->szFullFileName);
#endif
				
				
				
				pSendData = new char[sizeof(ERR_HEADER)];
				memset(pSendData,0x00,sizeof(ERR_HEADER));
				errheader.header.nCmd = RS_ERR;
				errheader.header.nErrorCode = -RS_FILE_DATA_TRANSFER;
				strcat(errheader.errmsg,"서버측 에서 파일이 없거나 열수 없습니다.");
				
				memcpy(pSendData, &errheader, sizeof(ERR_HEADER));
		
				pHeader->nCmd = RS_ERR;
				com9102(com9102_R);
				return -RS_FILE_DATA_TRANSFER;

				
			}
			com9102(com9102_R);
			return 0;
			
		}
		
		

		
		// 현제 client에 있는 사이즈 만큼 이동 하기
	//	unsigned long dCurrentLen = pFileHead->dCurrentSize;
		double dCurrentLen = pFileHead->dCurrentSize;
	
		off64_t current_set = (off64_t)dCurrentLen;
		
		#ifdef __DEBUG
		printf("  ./ check size 64 bit : %15.0f / %15.0f\n",(double)current_set,dCurrentLen);
		#endif
		fseeko64(UploadFile,current_set,SEEK_SET);
		
		 // 해더 전송  실제 사이즈와 이름.
		 
		 
		 
///////////////////////////////////////////////////////////////////////
		 	//예취 전환.  복
	char DnDate[9];
	memset(DnDate,0x00,9);

	memset(pFileHead,0x00,sizeof(FILEHEAD));

	dFileLen  = (double)statbuf.st_size;;
	if(dFileLen < 0 )
		dFileLen = 0;
	
	#ifdef __DEBUG
	printf("  ./file size double : %15.0f \n",dFileLen);
	#endif
	
	pFileHead->dwID = seq_no;
	if(pFileinfo->GroupInfo.nMode == 3 || pFileinfo->GroupInfo.nMode == 1)
	{
		pFileinfo->GroupInfo.dwID = seq_no;
		strcpyA(pFileinfo->GroupInfo.DnDate,DnDate);
	}
		
	strcpyA(pFileHead->DnDate,DnDate);
	
	pFileHead->dCurrentSize = dFileLen;
	strcpyA(pFileHead->szFullFileName ,pFileinfo->szFileName);
	
	#ifdef __DEBUG
	printf("  ./check in file head \n"
		   "    file seq = %ld : file name : %s  : dn date = %s :"
		   "    file size : %15.0f\n"
		   ,	pFileHead->dwID
		   ,    pFileHead->szFullFileName
		   ,	DnDate
		   ,	pFileHead->dCurrentSize);
	#endif

	infLOG(ALWAY, "-> check ) file head \n"                           
		"    file seq = %ld : file name : %s  : dn date = %s \n"
		"    file size : %15.0f\n"                            
		,	pFileHead->dwID                                  
		,    pFileHead->szFullFileName                        
		,	DnDate                                           
		,	pFileHead->dCurrentSize);                        
		
		

	                                                  
                                                      
		//데이터 전송	                                
		                                              
			/////////////////////////////             
			                                          
		#ifdef __DEBUG
		printf("  ./make file head\n");
		#endif
		
		memset(&headers,0x00,HEADER_SIZE);
	
		headers.nCmd = RS_FILE_DATA_TRANSFER;
		headers.nDataCnt = 1;
		headers.nDataSize = sizeof(FILEHEAD);
	
	
		char* pSendBuffer = new char[HEADER_SIZE + headers.nDataCnt*headers.nDataSize ];
		memset(pSendBuffer, 0x00, HEADER_SIZE + headers.nDataCnt*headers.nDataSize );

		memcpy(pSendBuffer,&headers,sizeof(HEADER)); //head
		memcpy(pSendBuffer + HEADER_SIZE,pFileHead,headers.nDataCnt * headers.nDataSize); //body	
		
		#ifdef __DEBUG
		printf("  ./send head size : %d \n",HEADER_SIZE + headers.nDataCnt*headers.nDataSize);
		#endif
		
		
infLOG(ALWAY, "->Send File Head\n");
	   		
		if(	SendData(Socket,pSendBuffer,HEADER_SIZE + headers.nDataCnt*headers.nDataSize)<=0)  //struct _PACKET == PACKET
		{
infLOG(ALWAY, " > ERROR Exception )Send File Head");
			
			#ifdef __DEBUG
			printf("FileRequestFile : send 에러 예취금 복원 1: <client 죽음>");
			#endif
			
			delete[] pSendBuffer;
			delete pFileHead;

			com9102(com9102_R);
			return 0;
			
		}
		
		delete[] pSendBuffer;
		delete pFileHead;
	
		
		//////////데이터 전송 루틴
		double nTotalLen = dFileLen;
		double nTempTotalLen = nTotalLen;
		nTotalLen = nTotalLen - dCurrentLen; //현재 이동한 만큼 계산
		
		int nReadLen=0;
		int nSendLen=0;
		int count=0;
		int nStop = 0;
	
		
		
		char* szSendBuffer = new char[SENDBUF];
	
		
		
		////[][]
		
		infLOG(ALWAY, "->input ) Send File Data\n");
		#ifdef __DEBUG
		printf("Checking File (%s) : 파일 전체 길이 (%15.0f ) = ( %15.0f - %15.0f )",pFileinfo->szFileName , nTotalLen ,pFileinfo->dFileSize ,dCurrentLen);
		#endif
				
		infLOG(ALWAY,"Checking File (%s) : 파일 전체 길이 (%15.0f ) = ( %15.0f - %15.0f )",pFileinfo->szFileName , nTotalLen ,pFileinfo->dFileSize ,dCurrentLen);


		int fno = fileno(UploadFile);
	   

		//off_t offset = 0;
		
					
		while(nTotalLen > 0 && !nStop )
    	{   
	    	
			memset(szSendBuffer,0x00,SENDBUF);
			nReadLen = read(fno,szSendBuffer,SENDBUF);    
	    
	    	if(nReadLen > 0 )
	    		nSendLen = SendData(Socket,szSendBuffer,nReadLen);
	    	else
	    		nSendLen = 0;
	        #ifdef __DEBUG
	        //printf("send file recvlen( %d ) nTotalLen ( %15.0f) sendlen( %d )   \n",nReadLen  , nTotalLen,nSendLen);
	        #endif
	        
	        if(nSendLen <= 0)
	        {
	        	#ifdef __DEBUG
	        	printf("-=----------- 예외 상황 파일 받기 ------11\n");
	        	#endif
	        	if(nSendLen < 0)
	        	{
	        		char szErrMsg[1024];
					memset(szErrMsg,0x00,sizeof(szErrMsg));
					GetErrMsg(-nSendLen,szErrMsg);
					infLOG(ALWAY, " > ERROR Check ) RecvSocket Error ( %d ) ( %d )( %s )\n",nReadLen ,nSendLen,szErrMsg); 
					
					#ifdef __DEBUG
					printf("RecvSocket Error ( %d ) ( %d )( %s )\n",nReadLen ,nSendLen,szErrMsg); 
					#endif
					

	        	}
	        	else if(nSendLen == 0)
	        	{
	        		infLOG(ERROR, " Check ) RecvSocket Error ( %d ) ( 접속을 끊었습니다. )\n",nReadLen ); 
					
					#ifdef __DEBUG
					printf("RecvSocket Error ( %d ) ( 접속을 끊었습니다. )\n",nReadLen );
					#endif
	        	}   
	        	
infLOG(ERROR, "->Exception ) Send File Data\n");	        	
	        	infLOG(ERROR, "File전송 : 파일 받기 취소 : <메세지 & client 죽음>\n"); 
	       
				//보내다가 오류가 났을시...DB처리
				
				if(UploadFile)
					fclose(UploadFile);
				if(szSendBuffer != NULL)
					delete[] szSendBuffer;
				com9102(com9102_R);
				return 0;
	        	
	        }
	        
	        
	        nTotalLen = nTotalLen - (double)nSendLen;
	    	nTotalnRecvLen = nTotalnRecvLen + (double)nSendLen;
	    	count++;
	   
	}

		#ifdef __DEBUG
	    printf("\r  ./nTotalLen = %15.0f totalsend len = %15.0f   send len = %d\n",nTotalLen, nTotalnRecvLen,nSendLen);
	    #endif
	
		//if(nReadLen != -1 && UploadFile)
		if(UploadFile)
			fclose(UploadFile);
		
		if(szSendBuffer)
			delete[] szSendBuffer;


//	if(seq_no > 0)
	#ifdef __DEBUG
	printf("  ./예금취환 정보2 :  GroupInfo.mode = %d == 2,3 : GroupInfo.count = %d = 1\n"
			,pFileinfo->GroupInfo.nMode,pFileinfo->GroupInfo.nFileCount);
	#endif
	

	
	com9102(com9102_R);	
	return 1;

	
}


