	{
		db_disconnect(con);
	}

	infLOG(ALWAY," ]cfups4001 등록 성공. 구분:[%s]--임시ID:[%lu]--ID:[%lu]--분류:[%s]--가격:(%d)--상태:cy[%s]Realcy[%s]my[%s]--등록자:[%s]--szCompID[%s] \n", cont_gu, pfups4001->id, dwId, sect_code, lTotalPriceAmt, pfups4001->copyright_yn ,szTempCopyright_yn,szMobServiceYn, reg_user,szCompID);
	//종료

	req_header.nCmd = 1 ;
	pSendData = new char[HEADER_SIZE];
	memcpy(pSendData,&req_header,HEADER_SIZE);

   	return HEADER_SIZE;

	//------------------------------------------------------------------------------
fups4001_err:
	infLOG(ERROR, " FUPS4001 Error Msg   ] fups4001_err\n");

	//tran_end(con);
	if( bCprCloseDB )
		db_disconnect(cpr_con);

	if( bCloseDB )
		db_disconnect(con);

	req_header.nCmd = ErrNum ;
	if( ErrNum > 0 )
		req_header.nCmd = -1;
	//pSendData = new char [ERR_HEADER_SIZE];
	pSendData = new char [HEADER_SIZE];
	memcpy(pSendData,&req_header,HEADER_SIZE);

	return HEADER_SIZE;

fups4001_tran_err:
	infLOG(ERROR, " FUPS4001 Error Msg   ] fups4001_tran_err\n");

	tran_rollback(con);
	tran_end(con);

	if(bCprTrans) //20081217 - HCS. 제휴아이디 보류처리
	{
		tran_rollback(cpr_con);
		tran_end(cpr_con);
	}

	if( bCloseDB )
		db_disconnect(con);

	if( bCprCloseDB )
		db_disconnect(cpr_con);

	//	E_dump(ErrNum, ErrMsg, pSendData);
	req_header.nCmd = ErrNum ;
	if( ErrNum > 0 )
		req_header.nCmd = -1;
	pSendData = new char [HEADER_SIZE];
	memcpy(pSendData,&req_header,HEADER_SIZE);

	return HEADER_SIZE;
}

