	}

	infLOG(ALWAY, "szQuery = %s \n",szQuery);

	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}


	return 1;
}


/* 문자열 치환 */
char *replaceAll(char *s, const char *olds, const char *news)      // 2013.11.26 add by Lee 문자열 치환 함수..
{
	char *result, *sr;
	size_t i, count = 0;
	size_t oldlen = strlen(olds); if (oldlen < 1) return s;
	size_t newlen = strlen(news);

	if (newlen != oldlen) {
		for (i = 0; s[i] != '\0';) {
			if (memcmp(&s[i], olds, oldlen) == 0) count++, i += oldlen;
			else i++;
		}
	} else i = strlen(s);


	result = (char *) malloc(i + 1 + count * (newlen - oldlen));
	if (result == NULL) return NULL;


	sr = result;
	while (*s) {
		if (memcmp(s, olds, oldlen) == 0) {
			memcpy(sr, news, newlen);
			sr += newlen;
			s  += oldlen;
		} else *sr++ = *s++;
	}
	*sr = '\0';

	return result;
}

/* 문자열 치환 */
char *replaceMemo(char *s, const char *olds1,const char *olds2,const char *olds3,const char *news1,const char *news2,const char *news3)
{
	infLOG(ALWAY,"replaceMemo --> s  : %s\n",s);
	infLOG(ALWAY,"replaceMemo --> olds1  : %s\n",olds1);
	infLOG(ALWAY,"replaceMemo --> olds2  : %s\n",olds2);
	infLOG(ALWAY,"replaceMemo --> olds3  : %s\n",olds3);
	infLOG(ALWAY,"replaceMemo --> news1  : %s\n",news1);
	infLOG(ALWAY,"replaceMemo --> news2  : %s\n",news2);
	infLOG(ALWAY,"replaceMemo --> news3  : %s\n",news3);
	char *s2;

	if(olds1 != NULL)
	{
		s2 = replaceAll(s,olds1,news1);
		if(s2!= NULL)   //[[a]]  치환
		{
			if(olds2 != NULL)
			{
				s2=replaceAll(s2,olds2,news2);
				if(s2 != NULL)
				{
					if(olds3 != NULL)
					{
						s2=replaceAll(s2,olds3,news3);
						if(s2 != NULL)
						{
							return s2;
						}
						else
							return NULL;
					}
					else
						return s2;
				}
				else NULL;
			}
			else
				return s2;
		}
		else
			return NULL;
	}
	return NULL;
}

