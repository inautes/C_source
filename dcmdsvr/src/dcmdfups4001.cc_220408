						return ErrNum;
					}
				}

			}
		}

		infLOG(ALWAY, "item_bold_yn a4 = %s \n",item_bold_yn);
		// 제목 관련
		if( ( item_bold_cnt > 0 || free_item_bold_cnt > 0 ) && strcmp(item_bold_yn,"N") != 0  && strcmp(item_bold_yn,"F") != 0 )
