/* 5. item 정보 업데이트 */
int User_ItemCheck(MYSQL* pCon, CMysqlCon pMysqlCon, char* cont_gu,unsigned long dwId);

void Update_comp_cd(MYSQL* pCon, CMysqlCon pMysqlCon,MYSQL* pCprCon, CMysqlCon pCprMysqlCon,char* cont_gu,unsigned long uContId);
int Check_Event_Contents(MYSQL* pCon, CMysqlCon pMysqlCon,char* cont_gu,unsigned long uContId);
int Chech_Event_CPContents(MYSQL* pCprCon, CMysqlCon pCprMysqlCon,char* cont_gu,unsigned long uContId);
void InsertHoldLog(MYSQL *cpr_con, CMysqlCon MysqlCprCon, int nRet, LPCFUPS4001 pfups4001, char* pRegDate, char* pRegTime,unsigned long dwId=0);

void InsertHoldLog(MYSQL *cpr_con, CMysqlCon MysqlCprCon, int nRet, LPCFUPS4001 pfups4001, char* pRegDate, char* pRegTime,unsigned long dwId)
{
	infLOG(ALWAY,"InsertHoldLog nRet copy_right (B) = [%d]\n",nRet);

	int err_type = 0;

	if(nRet == -61 )
		err_type = 10; // 블록 목록 있음.
	if(nRet == -62 )
		err_type = 11; // 제휴사 2개 이상
	if(nRet == -63 )
		err_type = 12; // 제휴정보 제휴 정보 없음
	if(nRet == -64 )
		err_type = 13; // LIMIT X.
	if(nRet == -65 )
		err_type = 14; // temp B
	if(nRet == -66 )
		err_type = 15; // sub_sect = 02,03, szMurekaCode == 2
	if(nRet == -67 )
		err_type = 16; //  목록
	if(nRet == -68 )
		err_type = 17; // 제휴 유저
	if(nRet == -69 )
		err_type = 18; // 바이러스
	if(nRet == -70 )
		err_type = 19; //제휴 인제 제휴 정보 없음

	char szQuery[10000];	memset (szQuery , 0x00, sizeof(szQuery ));
	char szSysErrMsg[255];		memset(szSysErrMsg	,0x00,sizeof(szSysErrMsg));

	infLOG(ERROR, "InsertHoldLog Ret(%d)\n",nRet);

	memset (szQuery , 0x00, sizeof(szQuery ));
	sprintf(szQuery, "insert into zangsi_cpr.T_CONTENTS_UPLOAD_HOLD "
					 " ( err_type, reg_date, reg_time,tmp_id, cont_id )"
		             " values ( %d ,'%s', '%s', %lu , %lu ) ; "
		                 , err_type , pRegDate, pRegTime,pfups4001->id,dwId);

	infLOG(ALWAY,"szQuery = %s \n",szQuery);

	if(MysqlCprCon.MysqlQuery(cpr_con, szSysErrMsg, szQuery))
	{
		infLOG(ERROR, "T_CONTENTS_UPLOAD_HOLD Insert 오류.\n");
		return ;
	}

}

/* 1. 모바일만 서비스 체크*/
bool MobServiceCheck(MYSQL* pCon, CMysqlCon pMysqlCon,MYSQL* pCprCon, CMysqlCon pCprMysqlCon,char* cont_gu,unsigned long dwId)
{

	char szMgr_group[21*100] = {0,};
	char mobile_chk[2] = {0,};

	// ===================================

	char szQuery[10000]; 	memset(szQuery, 0x00, sizeof(szQuery));
	char szSysErrMsg[255];	memset(szSysErrMsg,0x00,sizeof(szSysErrMsg));
	MYSQL_RES   *res;
	MYSQL_ROW    row;

	// 1. mgr_cd 값 조회

	if(strcmp(cont_gu,"WE") == 0)
	{
			sprintf(szQuery," select  GROUP_CONCAT(DISTINCT a.mgr_cd SEPARATOR '\\\',\\\'') AS mgr_group from zangsi.T_CONTENTS_CP_FILELIST a where a.cont_gu = 'WE' and a.id = %lu; "	,dwId);
	}
	else if(strcmp(cont_gu,"FD") == 0)
	{
			sprintf(szQuery," select  GROUP_CONCAT(DISTINCT a.mgr_cd SEPARATOR '\\\',\\\'') AS mgr_group from zangsi.T_CONTENTS_CP_FILELIST a where a.cont_gu = 'FD' and a.id = %lu; "	,dwId);
	}
	else
	{
		return false;
	}

	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		return false;
	}
	if(!(res = mysql_store_result(pCon)))
	{
		mysql_free_result(res);
		return false;
	}

	if(mysql_num_rows(res)<=0)
	{
		mysql_free_result(res);
		return false;
	}

	if(row = mysql_fetch_row(res))
	{
		strcat(szMgr_group,"'");
		strcat(szMgr_group, getstr(row,0));
		strcat(szMgr_group,"'");
	}
	else
	{
		infLOG(ALWAY,"szMgr_group = null \n");
		mysql_free_result(res);
		return false;
	}
	mysql_free_result(res);

	infLOG(ALWAY,"szMgr_group = %s \n",szMgr_group);

	if(strcmp(szMgr_group,"") == 0)
		return false;



	// ===================================

	// 2. mobile_chk 값 조회 T_CPR_MOB_CONT_LIST_SUB
	// 컨텐츠 목록에서 하나라도 모바일 서비스가 있으면 게시물 yn으로 변경.
	MYSQL_RES   *cpr_res;
	MYSQL_ROW    cpr_row;

	memset(szQuery, 0x00, sizeof(szQuery));
	memset(szSysErrMsg,0x00,sizeof(szSysErrMsg));

	sprintf(szQuery," SELECT a.mobile_chk FROM zangsi_cpr.T_CPR_MOB_CONT_LIST a "
					" WHERE a.mgr_cd IN (%s) and a.mobile_chk = 'Y' ; ",szMgr_group); // y의 개수를 파악.

	if(pCprMysqlCon.MysqlQuery(pCprCon,szSysErrMsg, szQuery))
	{
		infLOG(ALWAY,"MobServiceCheck szSysErrMsg = %s \n",szSysErrMsg);
		return false;
	}
	if(!(cpr_res = mysql_store_result(pCprCon)))
	{
		infLOG(ALWAY,"MobServiceCheck mysql_store_result error = N \n");
		mysql_free_result(cpr_res);
		return false;
	}

	if(mysql_num_rows(cpr_res)<=0)
	{
		infLOG(ALWAY,"MobServiceCheck szMgr_group Count 0 \n");
		mysql_free_result(cpr_res);
		return false;
	}


	if(cpr_row = mysql_fetch_row(cpr_res))
	{
		infLOG(ALWAY,"MobServiceCheck  = 'Y' \n");

		memset(szQuery, 0x00, sizeof(szQuery));
		sprintf(szQuery," update zangsi.T_CONTENTS_VIR_ID  set mobile_chk = 'Y' where id = %lu ; /*dcmd 4001*/", dwId);
		if (pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
		{
			infLOG(ERROR, " FUPS4001 Error Info  ] %s (%d)(%s)\n",szQuery,mysql_errno(pCon), mysql_error(pCon));
		}
		mysql_store_result(pCon);

		memset(szQuery, 0x00, sizeof(szQuery));
		sprintf(szQuery," update zangsi.T_CONTENTS_VIR_ID2 set mobile_chk = 'Y' where id = %lu ; /*dcmd 4001*/", dwId);
		if (pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
		{
			infLOG(ERROR, " FUPS4001 Error Info  ] %s (%d)(%s)\n",szQuery,mysql_errno(pCon), mysql_error(pCon));
		}
		mysql_store_result(pCon);
	}
	else
	{
		mysql_free_result(cpr_res);
		return false;
	}
	mysql_free_result(cpr_res);

	return true;

}

/* 2. 신규 컨텐츠 체크*/
int CheckNewContents(MYSQL* pCon, CMysqlCon pMysqlCon, char* pUserId, unsigned long nId, char* pSectCode)
{

	MYSQL_RES   *res;
	MYSQL_ROW    row;

	char szQuery[1000];
	memset(szQuery, 0x00, sizeof(szQuery));

	char szSysErrMsg[255];
	memset(szSysErrMsg, 0x00, sizeof(szSysErrMsg));

	char szPermGu[1+1];
	memset(szPermGu, 0x00, sizeof(szPermGu));

	char szAuthNum[7+1];
	memset(szAuthNum, 0x00, sizeof(szAuthNum));

	sprintf(szQuery, "select perm_gu, auth_num from zangsi.T_PERM_UPLOAD_AUTH where user_id = '%s'", pUserId);


	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ERROR," FUPS4001 ] CheckNewContents : perm_gu select 실패(1). user_id : (%s) ID : (%lu)\n", pUserId, nId);
		infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);

		return -1;
	}
	if(!(res = mysql_store_result(pCon)))
	{
		infLOG(ERROR," FUPS4001 ] CheckNewContents : perm_gu select 실패(2). user_id : (%s) ID : (%lu)\n", pUserId, nId);
		infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}
	if(mysql_num_rows(res)<=0)
	{
		mysql_free_result(res);
		infLOG(ALWAY," FUPS4001 ] user_id : (%s) ID : (%d) 의 값이 없습니다.\n", pUserId, nId);
		return -1;
	}
	row = mysql_fetch_row(res);

	strcpyA(szPermGu, getstr(row,0));
	strcpyA(szAuthNum, getstr(row,1));


	mysql_free_result(res);

	memset(szQuery, 0x00, sizeof(szQuery));

	//교육 / 지식
	if(strcmp(pSectCode, "12") == 0 || strcmp(pSectCode, "13") == 0)
		sprintf(szQuery, " select file_size, default_hash from zangsi.T_CONTENTS_FILELIST_SUB where id = %lu ;", nId);
	else
		sprintf(szQuery, " select file_size, default_hash from zangsi.T_CONTENTS_FILELIST_SUB where id = %lu and file_size >= 512000 ;", nId);

	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ERROR,"CheckNewContents : 원본 해쉬정보 조회 실패(1). user_id : (%s) ID : (%d)\n", pUserId, nId);
		infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}
	if(!(res = mysql_store_result(pCon)))
	{
		infLOG(ERROR,"CheckNewContents : 원본 해쉬정보 조회 실패(2). user_id : (%s) ID : (%d)\n", pUserId, nId);
		infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}
	if(mysql_num_rows(res)<=0)
	{
		mysql_free_result(res);
		infLOG(ALWAY,"user_id : (%s) ID : (%d) 의 값이 없습니다.\n", pUserId, nId);
		return -1;
	}
	while(row = mysql_fetch_row(res))
	{
		MYSQL_RES   *res2;
		MYSQL_ROW    row2;

		int nCnt = 0;
		double dFileSize =(double)getnum(row,0); // (double)atoi64(getstr(row,0));// getint(row,0);

		char szDefaultHash[58];
		memset(szDefaultHash, 0x00, sizeof(szDefaultHash));

		strcpyA(szDefaultHash, getstr(row,1));


		memset(szQuery, 0x00, sizeof(szQuery));
		sprintf(szQuery, " select count(seq_no) "
			" from zangsi.T_CONTENTS_FILELIST_SUB "
			" where file_size = %15.0f and default_hash = '%s' "
			, dFileSize, szDefaultHash);

		if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
		{
			mysql_free_result(res);
			infLOG(ERROR,"CheckNewContents : 해쉬정보 조회 실패(1). user_id : (%s) ID : (%lu)\n", pUserId, nId);
			infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
			return -1;
		}
		if(!(res2 = mysql_store_result(pCon)))
		{
			mysql_free_result(res);
			infLOG(ERROR,"CheckNewContents : 해쉬정보 조회 실패(2). user_id : (%s) ID : (%lu)\n", pUserId, nId);
			infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);

			return -1;
		}
		if(mysql_num_rows(res2) <= 0)
		{
			mysql_free_result(res);
			mysql_free_result(res2);
			infLOG(ERROR,"CheckNewContents : 해쉬정보 조회 실패(3). user_id : (%s) ID : (%lu)\n", pUserId, nId);
			infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);

			return -1;
		}

		row2 = mysql_fetch_row(res2);

		nCnt = getint(row2,0);

		mysql_free_result(res2);

		if(nCnt > 1)
		{
			mysql_free_result(res);
			infLOG(ALWAY, " FUPS4001 Error Info  ] (%d) 같은 해쉬 있음\n", nCnt);
			return 0;
		}

		memset(szQuery, 0x00, sizeof(szQuery));
		sprintf(szQuery, " select count(seq_no) "
			" from zangsi.T_CONTENTS_FILELIST_SUB "
			" where file_size = %15.0f and default_hash = '%s' "
			, dFileSize, szDefaultHash);

		if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
		{
			mysql_free_result(res);
			infLOG(ERROR,"CheckNewContents : 해쉬정보 조회 실패(4). user_id : (%s) ID : (%lu)\n", pUserId, nId);
			infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
			return -1;
		}
		if(!(res2 = mysql_store_result(pCon)))
		{
			mysql_free_result(res);
			infLOG(ERROR,"CheckNewContents : 해쉬정보 조회 실패(5). user_id : (%s) ID : (%lu)\n", pUserId, nId);
			infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
			return -1;
		}
		if(mysql_num_rows(res2) <= 0)
		{
			mysql_free_result(res);
			mysql_free_result(res2);
			infLOG(ERROR,"CheckNewContents : 해쉬정보 조회 실패(6). user_id : (%s) ID : (%lu)\n", pUserId, nId);
			infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
			return -1;
		}

		row2 = mysql_fetch_row(res2);

		nCnt = getint(row2,0);

		mysql_free_result(res2);

		if(nCnt > 1)
		{
			infLOG(ALWAY, " FUPS4001 Error Info  ] (%d) 같은 해쉬 있음\n", nCnt);
			//infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);

			mysql_free_result(res);
			return 0;
		}

	}
	mysql_free_result(res);

	memset(szQuery, 0x00, sizeof(szQuery));
	sprintf(szQuery, " insert into zangsi.T_CONTENTS_NEWHASH_ID values (%lu, '%s') ", nId, pUserId);
	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ERROR,"CheckNewContents : T_CONTENTS_NEWHASH_ID 인서트 실패. user_id : (%s) ID : (%lu)\n", pUserId, nId);
		infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	return 0;
}

/* 3. 보류 목록 체크 */
int CheckBlockList(MYSQL* pCon, CMysqlCon pMysqlCon, unsigned long nId)
{

	MYSQL_RES   *res;
	MYSQL_ROW    row;

	char szQuery[1000];
	memset(szQuery, 0x00, sizeof(szQuery));

	char szSysErrMsg[255];
	memset(szSysErrMsg, 0x00, sizeof(szSysErrMsg));

	char copyright_yn[1+1];
	memset(copyright_yn, 0x00, sizeof(copyright_yn));

	sprintf(szQuery, "select a.copyright_yn from zangsi.T_CONTENTS_TEMPLIST_SUB a where a.id = %lu and a.copyright_yn not in ('C','N','Y','H') ;", nId);

	infLOG(ALWAY, "CheckBlockList szQuery [ %s ] \n",szQuery);

	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ERROR, " FUPS4001 CheckCopyrightList Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	if(!(res = mysql_store_result(pCon)))
	{
		infLOG(ERROR, " FUPS4001 CheckBlockList Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	int nCopyright_yn = 0 ;
	nCopyright_yn =  mysql_num_rows(res);

	if(nCopyright_yn <= 0)
	{
		return -1;
	}

	infLOG(ALWAY, " FUPS4001 nCopyright_yn [%lu] count = %d \n", nId,nCopyright_yn);

	while(row = mysql_fetch_row(res))
	{
		memset(copyright_yn, 0x00, sizeof(copyright_yn));
		strcpyA(copyright_yn, getstr(row,0));
		infLOG(ALWAY, " FUPS4001 [%lu], %s \n", nId,copyright_yn);
	}
	mysql_free_result(res);


	return nCopyright_yn;
}

/* 4. 관리자 블록 컨텐츠 체크  == 일반 처리는 안함. 막는것만 처리.
 1. mgr_cd 기준으로 게시물 관리.
 2. 아이디 기준으로 게시물 관리.
 3. comp_cd 기준으로 게시물 관리.
*/
int Admin_BlockCheck(MYSQL* pCon, CMysqlCon pMysqlCon, int select_code,char* cont_gu,unsigned long dwId)
{
	MYSQL_RES   *res;
	MYSQL_ROW    row;

	char temp_value[50];	memset(temp_value, 0x00, sizeof(temp_value));
	char szQuery[4096]; 	memset(szQuery, 0x00, sizeof(szQuery));
	char szSysErrMsg[255]; 	memset(szSysErrMsg, 0x00, sizeof(szSysErrMsg));

	char reg_user[20];			memset(reg_user, 0x00, sizeof(reg_user));
	char group_comp_cd[21*100];		memset(group_comp_cd, 0x00, sizeof(group_comp_cd));
	char group_mgr_cd[21*100];		memset(group_mgr_cd, 0x00, sizeof(group_mgr_cd));


	if(strcmp(cont_gu,"WE") == 0)
	{
			sprintf(szQuery,    " SELECT  a.reg_user, GROUP_CONCAT(DISTINCT b.comp_cd SEPARATOR '\\\',\\\'') AS comp_cd, GROUP_CONCAT(DISTINCT b.mgr_cd SEPARATOR '\\\',\\\'') AS mgr_group "
						" , GROUP_CONCAT(DISTINCT c.default_hash SEPARATOR '\\\',\\\'') AS default_hash "
						" FROM zangsi.T_CONTENTS_INFO a,zangsi.T_CONTENTS_CP_FILELIST b , zangsi.T_CONTENTS_FILELIST_SUB c"
						" WHERE a.id = b.id AND a.id=c.id AND b.cont_gu = '%s' AND a.id = %lu; "	,cont_gu, dwId);
	}
	else if(strcmp(cont_gu,"FD") == 0)
	{
			sprintf(szQuery,    " SELECT  a.reg_user, GROUP_CONCAT(DISTINCT b.comp_cd SEPARATOR '\\\',\\\'') AS comp_cd, GROUP_CONCAT(DISTINCT b.mgr_cd SEPARATOR '\\\',\\\'') AS mgr_group "
						" , GROUP_CONCAT(DISTINCT c.default_hash SEPARATOR '\\\',\\\'') AS default_hash "
						" FROM zangsi.T_CONTFLOG_INFO a,zangsi.T_CONTENTS_CP_FILELIST b , zangsi.T_CONTFLOG_FILELIST_SUB c"
						" WHERE a.id = b.id AND a.id=c.id AND b.cont_gu = '%s' AND a.id = %lu; "	,cont_gu, dwId);
	}
	else
	{
		return 0;
	}

	infLOG(ALWAY, "szQuery = %s\n",szQuery);

	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ERROR, " FUPS4001 Admin_etc_check Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	if(!(res = mysql_store_result(pCon)))
	{
		infLOG(ERROR, " FUPS4001 Admin_etc_check Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	if(  mysql_num_rows(res) <=  0 )
		return 0;

	if(row = mysql_fetch_row(res))
	{
		strcpyA(reg_user		, getstr(row,0));
		strcpyA(group_comp_cd	, getstr(row,1));
		strcpyA(group_mgr_cd	, getstr(row,2));
	}

	mysql_free_result(res);

	MYSQL_RES   *res2;
	MYSQL_ROW    row2;

	char key_type[100];		memset(key_type, 0x00, sizeof(key_type));
	char key1[100];			memset(key1, 0x00, sizeof(key1));
	int  nSelect_code=0;
	char value1[100];		memset(value1, 0x00, sizeof(value1));


	memset(szQuery, 0x00, sizeof(szQuery));

	sprintf(szQuery, "select  a.key_type, a.key1, a.select_code, a.value1 from zangsi.T_DAEMON_CONT_CFG a "
					" WHERE a.key1 in ('%s','%s','%s') and a.use_yn = 'Y' and a.select_code = %d order by a.reg_date  ; ", reg_user,group_mgr_cd,group_comp_cd,select_code);

	infLOG(ALWAY, "szQuery = %s\n",szQuery);


	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ERROR, " FUPS4001 Admin_etc_check Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	if(!(res2 = mysql_store_result(pCon)))
	{
		infLOG(ERROR, " FUPS4001 Admin_etc_check Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	if(  mysql_num_rows(res2) <= 0)
		return 0;

	// key_type : reg_user, mgr_cd, comp_cd, default_hash

	while(row2 = mysql_fetch_row(res2))
	{
		memset(key_type, 0x00, sizeof(key_type));
		memset(key1, 0x00, sizeof(key1));
		nSelect_code = 0;
		memset(value1, 0x00, sizeof(value1));

		strcpyA(key_type, getstr(row2,0));
		strcpyA(key1	, getstr(row2,1));
		nSelect_code = (int)getnum(row2,2);
		strcpyA(value1, getstr(row2,3));

		switch(select_code)
		{
			case 1:		// copyright_yn B
				infLOG(ALWAY, "key_type = '%s', key1 = %s, nSelect_code = %d ,copyright_yn = %s\n", key_type,key1,nSelect_code,value1 );
				if(strcmp(value1,"N")!=0)
					strcpyA(temp_value,value1);
				break;
			case 11:		// copyright_yn N->P
				infLOG(ALWAY, "key_type = '%s', key1 = %s, nSelect_code = %d ,copyright_yn = %s\n", key_type,key1,nSelect_code,value1 );
				if(strcmp(value1,"N")!=0)
					strcpyA(temp_value,value1);
				break;
			case 2:		// mobservice_yn Y,N
				infLOG(ALWAY, "key_type = '%s', key1 = %s, nSelect_code = %d ,mobservice_yn = %s\n", key_type,key1,nSelect_code,value1 );
				if(strcmp(value1,"Y")!=0)
					strcpyA(temp_value,value1);
				break;
			case 3:		// disp_end_date
				infLOG(ALWAY, "key_type = '%s', key1 = %s, nSelect_code = %d ,disp_end_date = %s\n", key_type,key1,nSelect_code,value1 );
				if(strcmp(value1,"")!=0)
					strcpyA(temp_value,value1);
				break;
			case 4:		// mobile_chk
				infLOG(ALWAY, "key_type = '%s', key1 = %s, nSelect_code = %d ,disp_end_date = %s\n", key_type,key1,nSelect_code,value1 );
				if(strcmp(value1,"N")!=0)
					strcpyA(temp_value,value1);
				break;
			default :
				break;
		}

	}
	mysql_free_result(res2);


	infLOG(ALWAY, "temp_value = %s\n", temp_value);


	if(strcmp(temp_value,"")!=0)
	{

		memset(szQuery, 0x00, sizeof(szQuery));
		if(strcmp(cont_gu,"WE") == 0)
		{
			switch(select_code)
			{

				case 1:
				case 11:
					sprintf(szQuery, "update zangsi.T_CONTENTS_VIR_ID a set a.copyright_yn = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
				case 2:
					sprintf(szQuery, "update zangsi.T_CONTENTS_VIR_ID a set a.mob_service_yn = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
				case 3:
					sprintf(szQuery, "update zangsi.T_CONTENTS_INFO a set a.disp_end_date = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
				case 4:
					sprintf(szQuery, "update zangsi.T_CONTENTS_VIR_ID a set a.mobile_chk = '%s' where a.id = %lu; ",temp_value, dwId);
				break;

			}
		}
		else if(strcmp(cont_gu,"FD") == 0)
		{
			switch(select_code)
			{

				case 1:
				case 11:
					sprintf(szQuery, "update zangsi.T_CONTFLOG_VIR_ID a set a.copyright_yn = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
				case 2:
				//	sprintf(szQuery, "update zangsi.T_CONTFLOG_VIR_ID a set a.mob_service_yn = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
				case 3:
					sprintf(szQuery, "update zangsi.T_CONTFLOG_INFO a set a.disp_end_date = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
			}
		}

		infLOG(ALWAY, "szQuery = %s \n",szQuery);

		if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
		{
			infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
			return -1;
		}

		//
		memset(szQuery, 0x00, sizeof(szQuery));
		if(strcmp(cont_gu,"WE") == 0)
		{
			switch(select_code)
			{

				case 1:
				case 11:
					sprintf(szQuery, "update zangsi.T_CONTENTS_VIR_ID2 a set a.copyright_yn = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
				case 2:
					sprintf(szQuery, "update zangsi.T_CONTENTS_VIR_ID2 a set a.mob_service_yn = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
				case 4:
					sprintf(szQuery, "update zangsi.T_CONTENTS_VIR_ID2 a set a.mobile_chk = '%s' where a.id = %lu; ",temp_value, dwId);
				break;

			}
		}
		else if(strcmp(cont_gu,"FD") == 0)
		{
			switch(select_code)
			{

				case 1:
				case 11:
					sprintf(szQuery, "update zangsi.T_CONTFLOG_VIR_ID2 a set a.copyright_yn = '%s' where a.id = %lu; ",temp_value, dwId);
				break;
			}
		}

		infLOG(ALWAY, "szQuery = %s \n",szQuery);

		if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
		{
			infLOG(ERROR, " FUPS4001 Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
			infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
			return -1;
		}
	}

	if((select_code == 1 && strcmp(temp_value,"B") == 0) ||
		select_code == 11 && strcmp(temp_value,"P") == 0 )
		return 2;
	else
		return 1;
}


int User_ItemCheck(MYSQL* pCon, CMysqlCon pMysqlCon, char* cont_gu,unsigned long dwId)
{

	char ErrMsg[255];    // error message
	int  ErrNum;         // error no

	MYSQL_RES   *res=NULL;
	MYSQL_ROW    row;

	char temp_value[50];	memset(temp_value, 0x00, sizeof(temp_value));
	char szQuery[1000]; 	memset(szQuery, 0x00, sizeof(szQuery));
	char szSysErrMsg[255]; 	memset(szSysErrMsg, 0x00, sizeof(szSysErrMsg));
	char copyright_yn[2];	memset(copyright_yn, 0x00, sizeof(copyright_yn));

	char reg_user      [12+1]; 	memset(reg_user, 0x00, sizeof(reg_user));
	char reg_date      [ 8+1]; 	memset(reg_date, 0x00, sizeof(reg_date));
	char reg_time      [ 6+1]; 	memset(reg_time, 0x00, sizeof(reg_time));
	char item_color[16];	memset(item_color, 0x00, sizeof(item_color));
	char item_bold_yn[2];	memset(item_bold_yn, 0x00, sizeof(item_bold_yn));

	if(strcmp(cont_gu,"WE") == 0)
	{
			sprintf(szQuery,    " select a.copyright_yn , b.item_color, b.item_bold_yn, b.reg_user ,b.reg_date,b.reg_time from zangsi.T_CONTENTS_VIR_ID a, zangsi.T_CONTENTS_INFO b WHERE a.id = b.id and a.id = %lu; "	, dwId);
	}
	else if(strcmp(cont_gu,"FD") == 0)
	{
			// 필로그는 아이템 없음.
			return 0;
	}
	else
	{
		return 0;
	}

	infLOG(ALWAY, "szQuery = %s\n",szQuery);

	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ERROR, " FUPS4001 Admin_etc_check Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	if(!(res = mysql_store_result(pCon)))
	{
		infLOG(ERROR, " FUPS4001 Admin_etc_check Error Info  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
		return -1;
	}

	if(  mysql_num_rows(res) <=  0 )
		return 0;

	if(row = mysql_fetch_row(res))
	{
		strcpy(copyright_yn	, getstr(row,0));
		strcpy(item_color		, getstr(row,1));
		strcpy(item_bold_yn	, getstr(row,2));
		strcpy(reg_user		, getstr(row,3));
		strcpy(reg_date		, getstr(row,4));
		strcpy(reg_time		, getstr(row,5));
	}

	mysql_free_result(res);


	infLOG(ALWAY, "User_ItemCheck = %s , %s, %s, %s, %s, %s\n",copyright_yn,item_color,item_bold_yn,reg_user,reg_date,reg_time);

//=================================================
	// 아이템 사용.

	unsigned int item_bold_cnt = 0;
	unsigned int item_color_cnt = 0;

	unsigned int free_item_color_cnt = 0;
	unsigned int free_item_bold_cnt = 0;


	int nBold = 0;
	int nColor = 0;

	if(strcmp(item_bold_yn,"Y")==0)
		nBold = 1;

	if(strcmp(item_color,"")!=0)
		nColor = 1;

	memset(szQuery, 0x00, sizeof(szQuery));
	if(strcmp(copyright_yn ,"Y") == 0 )//infLOG(ALWAY,"저작권 자료이므로 아이템을 사용하지 않습니다.\n");
	{
		strcpyA(item_bold_yn,"N");
		strcpyA(item_color,"");

		if(nBold > 0 || nColor > 0)
		{
			sprintf(szQuery, " insert into zangsi.T_SEND_MEMO (  memo_cd,  descript, send_user, del_yn, send_date, send_time ) "
								" values (  '04' "
								" ,'안녕하세요. 위디스크입니다.\r\n\r\n "
								"회원님께서 [%lu] 컨텐츠에 사용하신 아이템은 적용되지 않아 다시 지급되었습니다.\r\n\r\n "
								"지급된 아이템.\r\n "
								"컬러효과 : %d개 \r\n "
								"두껍게   : %d개 \r\n\r\n "
								"감사합니다. \r\n ' "
								" , '운영팀' ,'N', '%s', '%s' ) "
								, dwId , nColor, nBold, reg_date, reg_time);
			infLOG(ALWAY, "szQuery = %s\n",szQuery);

			if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
			{
				//
			}
			else
			{
				memset(szQuery , 0x00, sizeof(szQuery ));
				strcpy( szQuery, "SELECT last_insert_id() as send_seq_no" );

				if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
				{
					// 알림 쪽지 발송.
				}
				else
				{
					MYSQL_RES* myres = mysql_store_result(pCon);
					MYSQL_ROW myrow = mysql_fetch_row(myres);

					double send_seq_no  = getnum(myrow,0 );

					mysql_free_result(myres);

					memset(szQuery , 0x00, sizeof(szQuery ));
					sprintf(szQuery," insert into zangsi.T_RECV_MEMO "
									"  (memo_seq_no, recv_user, recv_date, recv_time, read_yn, del_yn, save_yn)  "
									" values "
									"  (%.0f, '%s' , '%s', '%s' , 'N', 'N', 'N') "
									,send_seq_no,reg_user,reg_date, reg_time);

					infLOG(ALWAY, "[%s]\n\n", szQuery);
					if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
					{
						// 알림 쪽지 발송.
					}
				}
			}
		}

	}
	else if(strcmp(copyright_yn ,"B") == 0 || strcmp(copyright_yn ,"X") == 0 || strcmp(copyright_yn ,"P") == 0 )
	{
		strcpyA(item_bold_yn,"N");
		strcpyA(item_color,"");

		if(nBold > 0 || nColor > 0)
		{
			sprintf(szQuery, " insert into zangsi.T_SEND_MEMO (  memo_cd,  descript, send_user, del_yn, send_date, send_time ) "
								" values (  '04' "
								" ,'안녕하세요. 위디스크입니다.\r\n\r\n "
								"회원님께서 [%lu] 컨텐츠에 사용하신 아이템은 적용되지 않아 다시 지급되었습니다.\r\n\r\n "
								"지급된 아이템.\r\n "
								"컬러효과 : %d개 \r\n "
								"두껍게   : %d개 \r\n\r\n "
								"감사합니다. \r\n ' "
								" , '운영팀' ,'N', '%s', '%s' ) "
								, dwId , nColor, nBold, reg_date, reg_time);
			infLOG(ALWAY, "szQuery = %s\n",szQuery);

			if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
			{
				//
			}
			else
			{
				memset(szQuery , 0x00, sizeof(szQuery ));
				strcpy( szQuery, "SELECT last_insert_id() as send_seq_no" );

				if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
				{
					// 알림 쪽지 발송.
				}
				else
				{
					MYSQL_RES* myres = mysql_store_result(pCon);
					MYSQL_ROW myrow = mysql_fetch_row(myres);

					double send_seq_no  = getnum(myrow,0 );

					mysql_free_result(myres);

					memset(szQuery , 0x00, sizeof(szQuery ));
					sprintf(szQuery," insert into zangsi.T_RECV_MEMO "
									"  (memo_seq_no, recv_user, recv_date, recv_time, read_yn, del_yn, save_yn)  "
									" values "
									"  (%.0f, '%s' , '%s', '%s' , 'N', 'N', 'N') "
									,send_seq_no,reg_user,reg_date, reg_time);

					infLOG(ALWAY, "[%s]\n\n", szQuery);
					if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
					{
						// 알림 쪽지 발송.
					}
				}
			}
		}
	}
	else
	{
		if( strcmp(item_color ,"") != 0 || ( strcmp(item_bold_yn,"N") != 0 && strcmp(item_bold_yn,"F") != 0) )
		{

			MYSQL_RES   *res_item=NULL;
			MYSQL_ROW    row_item;

			//13 보물 , 01 컬러 , 02 두껍게
			memset(szQuery , 0x00, sizeof(szQuery ));
			// 내가 보유한 칼라효과 아이템에 업로드중 정보 / temp_id기록한다.
			sprintf(szQuery," select  item_code , cur_item from zangsi.T_ITEM_INFO  "
							" where user_id = '%s' and item_code in ( '01','02','16','17') " ,reg_user );

			if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
			{
				ErrNum = -400125;
				strcpyA(ErrMsg, "아이템 정보 조회 오류입니다.");
				infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(pCon), mysql_error(pCon));
				return ErrNum;
			}
			else
			{
				infLOG(ALWAY, "item_bold_yn b2 = %s \n",item_bold_yn);

				if (!(res_item = mysql_store_result(pCon)))
				{
					ErrNum = -400102;
					strcpyA(ErrMsg, "아이템 정보 확인 오류입니다.");
					infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(pCon), mysql_error(pCon));
					return ErrNum;
				}
				else
				{
					infLOG(ALWAY, "item_bold_yn b1 = %s \n",item_bold_yn);

					while(row_item = mysql_fetch_row(res_item))
					{
						if( strcmp(getstr(row_item,0),"01") ==  0 )
						{
							item_color_cnt = (unsigned int)getint(row_item,1);
						}
						else if ( strcmp(getstr(row_item,0),"02") == 0 )
						{
							item_bold_cnt = (unsigned int)getint(row_item,1);
						}
						else if ( strcmp(getstr(row_item,0),"16") == 0 )
						{
							free_item_color_cnt = (unsigned int)getint(row_item,1);
						}
						else if ( strcmp(getstr(row_item,0),"17") == 0 )
						{
							free_item_bold_cnt = (unsigned int)getint(row_item,1);
						}
					}

					mysql_free_result(res_item);
				}
			}
		}

		infLOG(ALWAY, "item_color_cnt = %d,item_bold_cnt = %d,free_item_color_cnt = %d,free_item_bold_cnt = %d \n",item_color_cnt,item_bold_cnt,free_item_color_cnt,free_item_bold_cnt);


		// 색 관련
		if( (item_color_cnt > 0 || free_item_color_cnt > 0) && strcmp(item_color ,"") != 0 )
		{
			memset(szQuery , 0x00, sizeof(szQuery ));
			if(free_item_color_cnt > 0)
			{
				sprintf(szQuery , " update zangsi.T_ITEM_INFO set use_item = use_item +1 , cur_item =  cur_item -1 , last_udt_date = '%s' , last_udt_time = '%s' "
				  " where user_id = '%s' and item_code = '16'  "
				 , reg_date,reg_time ,reg_user  );


				infLOG(ALWAY, "szQuery = %s \n",szQuery);


				  if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
				{
					ErrNum = -400125;
					strcpyA(ErrMsg, "제목 색 넣기 아이템 갯수 정보 갱신 오류입니다.");
					infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(pCon), mysql_error(pCon));
					return ErrNum;
				}
				else
				{
					memset(szQuery , 0x00, sizeof(szQuery ));
					sprintf(szQuery , " insert into zangsi.T_ITEM_OUT (  user_id, item_code, out_code  , out_cnt, use_id, descript  , reg_date, reg_time ) "
										" values ( '%s','16','1',1, %lu, '컨텐츠 번호 %lu 사용' , '%s','%s') "
										,reg_user , dwId , dwId , reg_date,reg_time );

					infLOG(ALWAY, "szQuery = %s \n",szQuery);
					if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
					{
						ErrNum = -400125;
						strcpyA(ErrMsg, "제목 색 넣기 아이템 사용 정보 갱신 오류입니다.");
