		// 8. 제휴 컨텐츠 게시기간, 가격 등의 정보를 가져온다.
		bool bHaveCprInfo = false;
		if( strcmp(pfups4001->copyright_yn ,"C") == 0 )
		{

			//--------------------------------------------------------------------------
			// 제휴 컨텐츠가 있는지 검색.
			//--------------------------------------------------------------------------
			memset(szQuery, 0x00, sizeof(szQuery));
			//no.914
			sprintf(szQuery, " select a.comp_cd, substring(a.comp_cd,4), if(b.comp_cd is null, 1, if(a.comp_cd = b.comp_cd, 1, 0))  , a.file_type, ifnull(c.disp_end_date,'') "
				" from zangsi_cpr.T_CONTENTS_TEMPLIST_SUB a left outer join zangsi_cpr.T_CPR_USER_INFO b on a.reg_user = b.user_id "
				" left outer join zangsi_cpr.T_CPR_EVENT_COMP c ON a.comp_cd = c.comp_cd and c.use_yn='Y' "
				" where a.id = %lu and a.reg_user = '%s' and a.copyright_yn = 'C' "
				" group by comp_cd limit 2; "
				,pfups4001->id  , reg_user);

			infLOG(ALWAY, "szQuery [ %s ] \n",szQuery);

			if (MysqlCprCon.MysqlQuery(cpr_con,szSysErrMsg, szQuery))
			{
				ErrNum = -400111;
				sprintf(ErrMsg, "제휴 컨텐츠 정보를 생성 하지 못 하였습니다.\n");
				infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));
				goto fups4001_err;
			}

			if (!(cpr_res = mysql_store_result(cpr_con)))
			{
				infLOG(ERROR,"제휴 컨텐츠 데이터 추출 오류입니다.\n");
				infLOG(ERROR, " FUPS4001 Error Msg   ] [ %s ]\n",ErrMsg);
				infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));
				infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);

				goto fups4001_err;
			}


			// 제휴 제휴사가 2개 이상일 경우 보류 처리 ( 현재 시스템은 제휴사가 2개일 경우 처리가 되어있지 않음. )
			if(mysql_num_rows(cpr_res) >= 2 )
			{
				strcpyA(pfups4001->copyright_yn,"B");
				 InsertHoldLog(cpr_con, MysqlCprCon, -62, pfups4001  ,reg_date, reg_time);
				infLOG(ALWAY,"dcmdfups4001> copyright_yn 5 = [%lu][%s]\n",pfups4001->id, pfups4001->copyright_yn);

				cpr_row = mysql_fetch_row(cpr_res);
				nCompCnt = atoi(getstr(cpr_row,1));

				// 제휴 컨텐츠 인데 제휴사 정보 없을때
				infLOG(ERROR,"컨텐츠 변환 >> 보류- 제휴사가 2개 이상입니다.  [temp_id : %lu]\n", pfups4001->id);
				infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
				mysql_free_result(cpr_res);
			}
			else if( mysql_num_rows(cpr_res) == 1 )
			{

				bool bCPRUSER = false;

				cpr_row = mysql_fetch_row(cpr_res);

				if(strcmp(getstr(cpr_row,3), "") != 0)
				{
					strcpy(	szFileType , getstr(cpr_row,3) ); // file_type
				}
				if(strcmp(getstr(cpr_row,4), "") != 0)
				{
					strcpy(comp_disp_end_date, getstr(cpr_row,4)); // 이벤트 컨텐츠 게시기간 설정.
				}

				infLOG(ALWAY,"[ %s ],comp_disp_end_date = %s\n",szFileType,comp_disp_end_date);
				infLOG(ALWAY, "getstr [ %s ] \n",getstr(cpr_row,0));

				strcpy(szComp_cd, getstr(cpr_row,0));

				if( strlen(szFileType) <= 0 )
				{
					char szTemp[6];
					memset(szTemp,0x00,sizeof(szTemp));
					strcpy(szTemp , szComp_cd );

					if( strlen(szTemp) >= 6 )
					{
						memcpy(	szFileType , szTemp+1,5);
						infLOG(ALWAY,"szFileType = %s\n",szFileType);
					}

					if(strcmp(szComp_cd, "010022") == 0)
						strcpy(szFileType, "MBC");
					else if(strcmp(szComp_cd, "010030") == 0)
						strcpy(szFileType, "MBCP");
					else if(strcmp(szComp_cd, "010071") == 0)
						strcpy(szFileType, "MBCM");
					else if(strcmp(szComp_cd, "010037") == 0)
						strcpy(szFileType, "iMBC");
					else if(strcmp(szComp_cd, "010055") == 0)
						strcpy(szFileType, "MBCV");
					else if(strcmp(szComp_cd, "010041") == 0)
						strcpy(szFileType, "CJENM");
					else if(strcmp(szComp_cd, "010017") == 0)
						strcpy(szFileType, "CJETV");
					else if(strcmp(szComp_cd, "010097") == 0)
						strcpy(szFileType, "채널W");
					else if(strcmp(szComp_cd, "010021") == 0)
						strcpy(szFileType, "SBS");
					else if(strcmp(szComp_cd, "010020") == 0)
						strcpy(szFileType, "KBS");
					else if(strcmp(szComp_cd, "010032") == 0)
						strcpy(szFileType, "KBSI");
				}

				if( strcmp(szComp_cd, "CPR") == 0 )
				{
					bCPRUSER = true;
				}

				int nCprUserChk = (int)getint(cpr_row,2);

				mysql_free_result(cpr_res);

				if(nCprUserChk == 0)
				{
					infLOG(ERROR, "FUPS4001 제휴 업로드 오류] temp_id = [%lu]\n", pfups4001->id);
					strcpyA(pfups4001->copyright_yn ,"P"); // no.914
					infLOG(ALWAY,"dcmdfups4001> copyright_yn 6 = [%lu][%s]\n",pfups4001->id, pfups4001->copyright_yn);
				}
				else
				{
					//제휴 아이디 일경우 정보 조회하기 위한 쿼리 생성.
					if( bCPRUSER == true )
					{
						memset(szQuery, 0x00, sizeof(szQuery));
						sprintf(szQuery, "select substring(comp_cd, 4) from zangsi_cpr.T_CPR_USER_INFO where user_id = '%s'", reg_user);

						if (MysqlCprCon.MysqlQuery(cpr_con,szSysErrMsg, szQuery))
						{
							ErrNum = -400111;
							sprintf(ErrMsg, " 제휴 아이디의 제휴사 정보를 생성 하지 못 하였습니다.\n");
							infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));

							goto fups4001_err;
						}

						if (!(cpr_res = mysql_store_result(cpr_con)))
						{
							infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));
							goto fups4001_err;
						}

						if(mysql_num_rows(cpr_res) <= 0)
						{
							infLOG(ALWAY,"제휴 아이디의 제휴사 정보가 없습니다.\n");
							mysql_free_result(cpr_res);
							goto fups4001_err;
						}

						cpr_row = mysql_fetch_row(cpr_res);

						char szCompCd[7];
						memset(szCompCd, 0x00, sizeof(szCompCd));
						strcpyA(szCompCd, getstr(cpr_row,0));
						mysql_free_result(cpr_res);

						infLOG(ALWAY,"제휴 아이디 [ %s ] 업로드 입니다.\n",reg_user);

						memset(szQuery, 0x00, sizeof(szQuery));
						//query-1
						// 20140514
						sprintf(szQuery, " select a.comp_cd , a.chi_id , ifnull(a.price_amt) ,'%s', '%s' "
										" ,'%s' ,'%s' ,0 ,'-', ifnull(a.price_amt) " // ,a.file_type  , if ( c.event_amt is null , a.price_amt ,c.event_amt)
										" ,ifnull(a.mob_price_amt,0) , a.mob_service_yn "
										" , ifnull(b.pc_event_amt,0), ifnull(b.mobile_event_amt,0) "
										" from zangsi_cpr.T_CONTENTS_TEMPLIST_SUB a  "
										" left outer join zangsi_cpr.T_CPR_EVENT_COMP b ON a.comp_cd = b.comp_cd and b.use_yn='Y' "
										" where a.id = %lu and a.reg_user = '%s' and a.copyright_yn = 'C'  "
										" group by a.comp_cd, a.chi_id  "
										, sect_code ,sect_sub ,adult_yn,  szCompCd, pfups4001->id  , reg_user); // 20130410

						infLOG(ALWAY,"제휴 가격 쿼리 [temp_id : %lu] [ %s ]\n", pfups4001->id,szQuery);
					}
					else
					{
						memset(szQuery, 0x00, sizeof(szQuery));
						//파일별 제휴 가격 정보 가져오기
						//query-1
						//20120612
						// 20140514
						sprintf(szQuery, " select a.comp_cd , a.chi_id , a.price_amt ,b.sect_code, b.sect_sub "
										" ,b.adult_yn , substring(a.comp_cd, 4), b.list_id ,a.file_type  , if ( c.event_amt is null , a.price_amt ,c.event_amt) "
										" , a.mob_price_amt ,a.mob_service_yn "
										" , ifnull(d.pc_event_amt,0), ifnull(d.mobile_event_amt,0) "
										" from zangsi_cpr.T_CONTENTS_TEMPLIST_SUB a  left outer join  zangsi_cpr.T_CPR_HASH_INFO b on a.chi_id = b.chi_id "
										" left outer join zangsi_cpr.T_CPR_EVENT_CONT_LIST c on a.file_type = c.cont_type  and c.use_yn='Y' "
										" left outer join zangsi_cpr.T_CPR_EVENT_COMP d ON a.comp_cd = d.comp_cd and d.use_yn='Y' "
										" where a.id = %lu and a.reg_user = '%s' and a.copyright_yn = 'C' and b.proc_stat ='C' "
										" group by a.comp_cd, b.list_id order by b.adult_yn "
										,pfups4001->id  , reg_user); // 20130410
					}
					infLOG(ALWAY,"제휴 가격 쿼리 [temp_id : %lu] [ %s ]\n", pfups4001->id,szQuery);


					if(MysqlCprCon.MysqlQuery(cpr_con,szSysErrMsg, szQuery))
					{
						ErrNum = -400111;
						sprintf(ErrMsg, "제휴 컨텐츠 정보를 생성 하지 못 하였습니다.\n");
						infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));

						goto fups4001_err;
					}

					if (!(cpr_res = mysql_store_result(cpr_con)))
					{
						strcpy(ErrMsg,"제휴 컨텐츠 파일 리스트 조회 오류 입니다.\n");
						infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));
						goto fups4001_err;
					}

					if(mysql_num_rows(cpr_res) <= 0)
					{
						infLOG(ALWAY,"제휴 컨텐츠 파일 정보가 없습니다.\n");
						infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);

						mysql_free_result(cpr_res);
						goto fups4001_err;
					}
					bHaveCprInfo = true;
				}
			}
			else
			{
				mysql_free_result(cpr_res);
				// 제휴 컨텐츠 인데 제휴사 정보 없을때
				strcpyA(pfups4001->copyright_yn,"B");
