					strcpyA(ErrMsg, "제목 색 넣기 아이템 갯수 정보 갱신 오류입니다.");
					infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(pCon), mysql_error(pCon));
					return ErrNum;
				}
				else
				{
					memset(szQuery , 0x00, sizeof(szQuery ));
					sprintf(szQuery , " insert into zangsi.T_ITEM_OUT (  user_id, item_code, out_code  , out_cnt, use_id, descript  , reg_date, reg_time ) "
														" values ( '%s','17','1',1, %lu, '컨텐츠 번호 %lu 사용' , '%s','%s') "
														,reg_user , dwId , dwId , reg_date,reg_time );

					infLOG(ALWAY, "szQuery = %s \n",szQuery);
					if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
					{
						ErrNum = -400125;
						strcpyA(ErrMsg, "제목 두껍게 아이템 정보 갱신 오류입니다.");
						infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(pCon), mysql_error(pCon));
						return ErrNum;
					}
				}
			}
			else if(item_bold_cnt > 0)
			{
				sprintf(szQuery , " update zangsi.T_ITEM_INFO set use_item = use_item +1 , cur_item =  cur_item -1 , last_udt_date = '%s' , last_udt_time = '%s' "
							  " where user_id = '%s' and item_code = '02'  "
							 , reg_date,reg_time ,reg_user  );

				infLOG(ALWAY, "szQuery = %s \n",szQuery);


				if( pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery) )
				{
