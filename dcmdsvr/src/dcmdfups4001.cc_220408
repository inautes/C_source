						infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(pCon), mysql_error(pCon));
						return ErrNum;
					}
				}
			}
		}
	}

	if( item_bold_cnt <= 0 && free_item_bold_cnt <= 0 && strcmp(item_bold_yn,"Y") == 0 )
	{
		strcpyA(item_bold_yn,"N");
	}

	if( item_color_cnt <= 0 && free_item_color_cnt <= 0 && strcmp(item_color,"") != 0 )
	{
		strcpyA(item_color,"");
	}


// ===============================

	memset(szQuery, 0x00, sizeof(szQuery));
	if(strcmp(cont_gu,"WE") == 0)
	{
		sprintf(szQuery, "update zangsi.T_CONTENTS_INFO a set a.item_bold_yn = '%s', a.item_color = '%s' where a.id = %lu ; " ,item_bold_yn ,item_color, dwId);
