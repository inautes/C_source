/* 1. 모바일만 서비스 체크*/
bool MobServiceCheck(MYSQL* pCon, CMysqlCon pMysqlCon,MYSQL* pCprCon, CMysqlCon pCprMysqlCon,char* cont_gu,unsigned long dwId);
/* 2. 신규 컨텐츠 체크*/
