void Update_comp_cd(MYSQL* pCon, CMysqlCon pMysqlCon,MYSQL* pCprCon, CMysqlCon pCprMysqlCon,char* cont_gu,unsigned long uContId)
{

	infLOG(ALWAY,"Update_comp_cd start\n");

	unsigned long uSeq_no=0;

	char szQuery[10000];	memset(szQuery,0x00,sizeof(szQuery));
	char szSysErrMsg[255];	memset(szSysErrMsg,0x00,sizeof(szSysErrMsg));
	char szMgr_cd[21];		memset(szMgr_cd,0x00,sizeof(szMgr_cd));
	char szComp_cd[8];		memset(szComp_cd,0x00,sizeof(szComp_cd));
	char szMobComp_cd[8];	memset(szMobComp_cd,0x00,sizeof(szMobComp_cd));

	MYSQL_RES   *res;
	MYSQL_ROW    row;

	memset(szQuery, 0x00, sizeof(szQuery));
	sprintf(szQuery,"select id, seq_no, mgr_cd from zangsi.T_CONTENTS_CP_FILELIST where id = %lu and cont_gu = '%s' ; ",uContId,cont_gu);


	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		infLOG(ALWAY,"Update_comp_cd return 1\n");
		infLOG(ERROR, " FUPS4001 Error Info Update_comp_cd  ] (%d)(%s)\n",mysql_errno(pCon), mysql_error(pCon));
		return ;
	}
	if(!(res = mysql_store_result(pCon)))
	{
		infLOG(ALWAY,"Update_comp_cd return 2\n");
		mysql_free_result(res);
		return ;
	}

	if(mysql_num_rows(res)<=0)
	{
		infLOG(ALWAY,"Update_comp_cd Count <= 0 [  id = %lu , cont_gu = '%s' ]\n",uContId,cont_gu);
		mysql_free_result(res);
		return ;
	}

	while(row = mysql_fetch_row(res))
	{
		uSeq_no = 0;
		memset(szMgr_cd,0x00,sizeof(szMgr_cd));

		uSeq_no = (unsigned long)(getnum(row, 1));
		strcpy(szMgr_cd, getstr(row,2));

		if(strcmp(szMgr_cd,"") == 0)
		{
			continue;
		}
		else
		{
			memset(szQuery, 0x00, sizeof(szQuery));
			sprintf(szQuery," select a.comp_cd, b.comp_cd from zangsi_cpr.T_CPR_CONT_LIST a left join zangsi_cpr.T_CPR_MOB_CONT_LIST b on a.mgr_cd = b.mgr_cd "
							" where a.mgr_cd = '%s' ; "  ,szMgr_cd); // T_CPR_MOB_CONT_LIST

			MYSQL_RES   *res_cpr;
			MYSQL_ROW    row_cpr;

			if(pCprMysqlCon.MysqlQuery(pCprCon,szSysErrMsg, szQuery))
			{
				infLOG(ALWAY,"Update_comp_cd continue 1\n");
				continue;
			}
			if(!(res_cpr = mysql_store_result(pCprCon)))
			{
				infLOG(ALWAY,"Update_comp_cd continue 2\n");
				mysql_free_result(res_cpr);
				continue;
			}

			if(mysql_num_rows(res_cpr)<=0)
			{
				infLOG(ALWAY,"Update_comp_cd continue 3\n");
				mysql_free_result(res_cpr);
				continue;
			}

			if(row_cpr = mysql_fetch_row(res_cpr))
			{
				strcpy(szComp_cd, getstr(row_cpr,0));
				strcpy(szMobComp_cd, getstr(row_cpr,1));

				if(strcmp(szComp_cd,"") == 0 && strcmp(szMobComp_cd,"") != 0)
					strcpy(szComp_cd,szMobComp_cd);

				if(strcmp(szComp_cd,"")==0)
				{
					infLOG(ALWAY,"Update_comp_cd continue 4\n");
					mysql_free_result(res_cpr);
					continue;
				}
				else
				{

					infLOG(ALWAY,"Update_comp_cd szComp_cd = %s, id = %lu , uSeq_no = %lu, cont_gu = '%s' ]\n",szComp_cd,uContId,uSeq_no,cont_gu);

					memset(szQuery, 0x00, sizeof(szQuery));
					sprintf(szQuery,"update zangsi.T_CONTENTS_CP_FILELIST set comp_cd ='%s' where id = %lu and seq_no = %lu and cont_gu = '%s' ;",szComp_cd,uContId,uSeq_no,cont_gu);

					if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
					{
						infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)\n",szSysErrMsg,szQuery);
					}
				}
			}
			mysql_free_result(res_cpr);

		}
	}

	mysql_free_result(res);
}

int Check_Event_Contents(MYSQL* pCon, CMysqlCon pMysqlCon,char* cont_gu,unsigned long uContId)
{
	// 사용 안함.
	return 0;

	infLOG(ALWAY,"Chech_Event_Label start\n");

	int nEvent_no = 0;

	char szQuery[10000]; 	memset(szQuery, 0x00, sizeof(szQuery));
	char szSysErrMsg[255];	memset(szSysErrMsg,0x00,sizeof(szSysErrMsg));
	MYSQL_RES   *res;
	MYSQL_ROW    row;
	// 1. 이벤트 컨텐츠 조회

	sprintf(szQuery," select b.event_code From zangsi.T_CONTENTS_CP_FILELIST a , zangsi.N_EVENT_CONTENTS_INFO b where "
					" a.cont_gu = '%s' AND a.id = %lu and a.mgr_cd = b.cont_code limit 1 ; ",cont_gu	,uContId);

	infLOG(ALWAY,"Chech_Event_Label szQuery = %s\n",szQuery);

	if(pMysqlCon.MysqlQuery(pCon,szSysErrMsg, szQuery))
	{
		return 0;
	}
	if(!(res = mysql_store_result(pCon)))
	{
		mysql_free_result(res);
		return 0;
	}


	if(mysql_num_rows(res)<=0)
	{
		mysql_free_result(res);
		return 0;
	}

	if(row = mysql_fetch_row(res))
	{
		nEvent_no =  (unsigned int)getint(row,0);
		infLOG(ALWAY,"nEvent_no = %d\n",nEvent_no);
	}

	mysql_free_result(res);
	return nEvent_no;

}

int Chech_Event_CPContents(MYSQL* pCprCon, CMysqlCon pCprMysqlCon,char* cont_gu,unsigned long uContId)
{

	infLOG(ALWAY,"Chech_Event_Label start\n");

	int nEvent_no = 138;

	char szQuery[10000]; 	memset(szQuery, 0x00, sizeof(szQuery));
	char szSysErrMsg[255];	memset(szSysErrMsg,0x00,sizeof(szSysErrMsg));
	MYSQL_RES   *cpr_res;

	// 1. mgr_cd 값 조회

	if(strcmp(cont_gu,"WE") == 0)
	{
			sprintf(szQuery," SELECT a.comp_cd,a.price_amt FROM zangsi.T_CONTENTS_FILELIST_SUB a WHERE a.comp_cd = '010022' AND a.price_amt = 300 AND a.id = %lu; "	,uContId);
	}
	else if(strcmp(cont_gu,"FD") == 0)
	{
			sprintf(szQuery," SELECT a.comp_cd,a.price_amt FROM zangsi.T_CONTFLOG_FILELIST_SUB a WHERE a.comp_cd = '010022' AND a.price_amt = 300 AND a.id = %lu; "	,uContId);
	}
	else
	{
		return 0;
	}

	infLOG(ALWAY,"Chech_Event_Label szQuery = %s\n",szQuery);

	if(pCprMysqlCon.MysqlQuery(pCprCon,szSysErrMsg, szQuery))
	{
		return 0;
	}
	if(!(cpr_res = mysql_store_result(pCprCon)))
	{
		mysql_free_result(cpr_res);
		return 0;
	}

	if(mysql_num_rows(cpr_res)<=0)
	{
		mysql_free_result(cpr_res);
		return 0;
	}

	mysql_free_result(cpr_res);
	return nEvent_no;

}

long dcmdfups4001(int sock , LPHEADER pHeader , char* pRecvData , char* &pSendData )//CFUPS4001 pfups4001)
{
	LPCFUPS4001 pfups4001 = (LPCFUPS4001)pRecvData;

	setLogFups4001(pRecvData);

	HEADER req_header;	memcpy(&req_header , pHeader,HEADER_SIZE);

	CMysqlCon MysqlCon(m_g_clMysqlPool,m_g_clMysqlPool->GetPrimaryKey());
	bool bCloseDB = false;

	MYSQL *con=NULL;
	MYSQL_RES   *res;
	MYSQL_ROW    row;

	MYSQL_RES   *sum_res;
	MYSQL_ROW    sum_row;

	CMysqlCon MysqlCprCon(m_g_clMysqlPoolCopyRight,m_g_clMysqlPoolCopyRight->GetPrimaryKey());
	bool bCprCloseDB = false;

	MYSQL *cpr_con=NULL;
	MYSQL_RES   *cpr_res;
	MYSQL_ROW    cpr_row;

	bool bIsReqMemoSend = true;
	char szMemoInfo[5000];

	char szSysErrMsg[255];	memset(szSysErrMsg,0x00,sizeof(szSysErrMsg));
	char szQuery[10000], szQuery1[10000];
	char ErrMsg[255];    // error message
	int  ErrNum;         // error no

	long reg_seq = 1;

	unsigned long dwId=0;
	unsigned long bomul_id=0;
	unsigned long req_id=0;
	char szReqUser     [16];
	char req_title[512];
	char title[512];
	char disp_end_date [ 8+1];
	char disp_end_time [ 6+1];
	char reg_user      [12+1];
	char reg_date      [ 8+1];
	char reg_time      [ 6+1];
	char up_st_date    [ 8+1];
	char up_st_time    [ 6+1];
	char file_name2   [255+1];  // 로컬파일이름
	char cont_gu   [2+1];  // 로컬파일이름
	char item_color[16];
	char item_bold_yn[2];
	char bomul_gu[2];
	char limit_yn[2];
	char adult_yn[2];
	char adult_yn2[2];
	char sect_code[2+1];
	char sect_sub[2+1];
	char disp_end_date_45[8+1];
	char disp_end_date_90[8+1];
	char disp_end_date_360[8+1];
 	char comp_disp_end_date [ 8+1]; // T_CPR_EVENT_COMP 기준
	char comp_file_type [ 8+1];		// T_CPR_EVENT_COMP 기준
	double sum_file_size = 0;
	double file_size = 0;

	unsigned int bomul_amt = 0;
	char bomul_item_code[2];
	unsigned int bomul_prize_num = 0;
	unsigned int bomul_coupon_cnt = 0;
	unsigned int item_bomul_cnt = 0;

//	unsigned int item_bold_cnt = 0;
//	unsigned int item_color_cnt = 0;
//	unsigned int free_item_color_cnt = 0;
//	unsigned int free_item_bold_cnt = 0;

	long lTotalPriceAmt =0;
	long lTotalMobilePriceAmt =0;
	long lTotal_pc_event_amt =0;
	long lTotal_mobile_event_amt =0;
	long lRealMbcPriceAmt =0;
	long lUserPriceAmt =0;
	long lUserMobilePriceAmt =0;

	int nCompCnt = 0;
	int nDispCntInc = 0 ; // 138 : mbc 이벤트 컨텐츠

	bool bIsCprUser = false;
	bool bCheckAdult = false;
	bool bCprTrans = false;

	memset(szReqUser,0x00,sizeof(szReqUser));
	memset(req_title,0x00,sizeof(req_title));
	memset(title,0x00,sizeof(title));
	memset(ErrMsg   , 0x00, sizeof(ErrMsg   ));

	char szTempCopyright_yn[2]; memset(szTempCopyright_yn, 0x00, sizeof(szTempCopyright_yn));

	char szFileType[5+1];	memset(szFileType, 0x00, sizeof(szFileType));
	char szContType[5+1];	memset(szContType, 0x00, sizeof(szContType));

	char szMurekaCode [6];	memset(szMurekaCode,0x00,sizeof(szMurekaCode));

	char szComp_cd[8];	memset(szComp_cd, 0x00, sizeof(szComp_cd));

	bool bHaveVirus  = false;

	char szCompID[7];	memset(szCompID, 0x00, sizeof(szCompID));

	bool bisHide = false;

	char szMobServiceYn[2];	memset(szMobServiceYn,0x00,sizeof(szMobServiceYn)); // 모바일 서비스 오픈
	strcpy(szMobServiceYn,"N");

	char szMobile_chk[2];	memset(szMobile_chk,0x00,sizeof(szMobile_chk)); // 모바일만 서비스
	infLOG(ALWAY,"szMobile_chk = %s %s \n",pfups4001->reg_user,szMobile_chk);

	if (pfups4001->id == 0)
	{
		sprintf(ErrMsg, "등록번호가 없습니다..\n");
		ErrNum = -1;
		infLOG(ERROR, "fups4001-> (%d)(%s)\n",ErrNum, ErrMsg);
		goto fups4001_err;
	}

	//--------------------------------------------------------------------------
	// Main DB 연결
	//--------------------------------------------------------------------------

	con = MysqlCon.GetMysqlCon();

	if (con == NULL )
	{
		ErrNum = -400192;
		sprintf(ErrMsg, "Main DB에 접속하지 못 하였습니다.\n");

		infLOG(ERROR, "FUPS4001 | GetMysqlCon is null ]\n");

		int nRetry = 0;
		while (!(con=db_connect(OSP_DB_NAME		,OSP_DB_IP_PUB		,OSP_DB_DCMD_USER	,OSP_DB_DCMD_PASS )) && nRetry < 5 )
		{
			nRetry++;
			sleep(1);
			infLOG(ERROR, "FUPS4001 | GetMysqlCon is null (%d)(%s)\n",ErrNum, ErrMsg);
		}

		if( nRetry >= 5)
		{
			ErrNum = -1;
			sprintf(ErrMsg, "테이베이스 오류입니다[2].\n");
			infLOG(ERROR, "FUPS4001 | Cannot DB Connect \n");
			goto fups4001_err;
		}
		bCloseDB = true;

		infLOG(ERROR,"FUPS4001 | Connect DB direct\n");
	}

	//--------------------------------------------------------------------------
	// 제휴 컨텐츠 DB 연결
	//--------------------------------------------------------------------------

	cpr_con = MysqlCprCon.GetMysqlCon();

	if (cpr_con == NULL )
	{
		ErrNum = -400192;
		sprintf(ErrMsg, "제휴 컨텐츠DB에 접속하지 못 하였습니다.\n");

		infLOG(ERROR, "FUPS4001 | GetMysqlCprCon is null [ 제휴 컨텐츠DB에 접속하지 못 하였습니다. ]\n");

		int nRetry = 0;
		while (!(cpr_con=db_connect(OSP_CPR_DB_NAME		,OSP_CPR_DB_IP_PUB		,OSP_DB_DCMD_USER	,OSP_DB_DCMD_PASS )) && nRetry < 5 )
		{
			nRetry++;
			sleep(1);
			infLOG(ERROR, "FUPS4001 | (%d)(%s)\n",ErrNum, ErrMsg);
		}

		if( nRetry >= 5)
		{
			ErrNum = -1;
			sprintf(ErrMsg, "제휴 컨텐츠테이베이스 오류입니다[2].\n");
			infLOG(ERROR, "FUPS4001 | Cannot DB CPR Connect \n");
			goto fups4001_err;
		}
		bCprCloseDB = true;

		infLOG(ERROR,"FUPS4001 | GetMysqlCprCon | Connect DB direct\n");
	}

	//--------------------------------------------------------------------------
	// 1. 등록일자 얻기 및 기본 데이터 얻기
	//--------------------------------------------------------------------------
	{
		memset(szQuery,  0x00, sizeof(szQuery));
		memset(szQuery1, 0x00, sizeof(szQuery1));
		strcpyA(szQuery, "SELECT date_format(now(),'%Y%m%d')");
		strcat(szQuery, "     , date_format(now(),'%H%i%s')");

		infLOG(ALWAY,"dcmdfups4001> copyright_yn 1 = [%lu][%s]\n",pfups4001->id, pfups4001->copyright_yn);

		if( strcmp(pfups4001->copyright_yn ,"Y") == 0) //차단으로 설정 되어 잇을 경우  disp_end_date를 7일로
			strcat(szQuery, "	  , date_format(date_add(now(), INTERVAL 7 DAY),'%Y%m%d')");
		else
			strcat(szQuery, "	  , date_format(date_add(now(), INTERVAL notice_term DAY),'%Y%m%d')");

		strcat(szQuery, "     , date_format(now(),'%H%i%s')");
		strcat(szQuery, "     , reg_user   as reg_user   , reg_date   as up_st_date ");
		strcat(szQuery, "     , reg_time   as up_st_time , file_name2 as file_name2 ");
		strcat(szQuery, "     , bomul_id   as bomul_id   , req_id   as req_id   ");
		strcat(szQuery, "     , cont_gu    as cont_gu    , item_color   as item_color   ");
		strcat(szQuery, "     , item_bold_yn as item_bold_yn  , bomul_gu ,bomul_amt, bomul_item_code , bomul_prize_num  ,bomul_coupon_cnt ");
		strcat(szQuery, "     , limit_yn ,adult_yn , title, price_amt, sect_code, sect_sub ");
		strcat(szQuery, "     , date_format(date_add(now(), INTERVAL 45 DAY),'%Y%m%d') ");
		strcat(szQuery, "     , date_format(date_add(now(), INTERVAL 90 DAY),'%Y%m%d') ");
		strcat(szQuery, "     , date_format(date_add(now(), INTERVAL 360 DAY),'%Y%m%d') ");
		strcat(szQuery, "     , file_size ");
		strcat(szQuery, "  FROM zangsi.T_CONTENTS_TEMP   ");
		sprintf(szQuery1, " WHERE id  =  %lu ", pfups4001->id);
		strcat(szQuery, szQuery1);

		//infLOG(ALWAY,"[ %s ] \n",szQuery);
		if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
		{
			ErrNum = -400101;
			sprintf(ErrMsg, "등록정보 조회 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			goto fups4001_err;
		}

		if (!(res = mysql_store_result(con)))
		{
			ErrNum = -400102;
			sprintf(ErrMsg, "등록정보 추출 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));

			goto fups4001_err;
		}
		if (mysql_num_rows(res)<=0)
		{
			mysql_free_result(res);

			ErrNum = -400102;
			sprintf(ErrMsg, "검색된 등록정보가 없습니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));

			goto fups4001_err;
		}
		row = mysql_fetch_row(res);

		memset(reg_user     , 0x00, sizeof(reg_user     ));
		memset(reg_date     , 0x00, sizeof(reg_date     ));
		memset(disp_end_date, 0x00, sizeof(disp_end_date));
		memset(disp_end_time, 0x00, sizeof(disp_end_time));
		memset(reg_time     , 0x00, sizeof(reg_time     ));
		memset(up_st_date   , 0x00, sizeof(up_st_date   ));
		memset(up_st_time   , 0x00, sizeof(up_st_time   ));
		memset(file_name2   , 0x00, sizeof(file_name2   ));
		memset(&bomul_id    , 0x00, sizeof(bomul_id     ));
		memset(&req_id    , 0x00, sizeof(req_id     ));
		memset(cont_gu    , 0x00, sizeof(cont_gu     ));
		memset(item_color    , 0x00, sizeof(item_color     ));
		memset(item_bold_yn    , 0x00, sizeof(item_bold_yn     ));
		memset(bomul_gu ,0x00,sizeof(bomul_gu));
		memset(bomul_item_code ,0x00,sizeof(bomul_gu));
		memset(limit_yn ,0x00,sizeof(limit_yn));
		memset(adult_yn,0x00,sizeof(adult_yn));
		memset(adult_yn2,0x00,sizeof(adult_yn2));
		memset(title,0x00,sizeof(title));
		memset(disp_end_date_45,0x00,sizeof(disp_end_date_45));
		memset(disp_end_date_90,0x00,sizeof(disp_end_date_90));
		memset(disp_end_date_360,0x00,sizeof(disp_end_date_360));
		memset(comp_disp_end_date,0x00,sizeof(comp_disp_end_date));
		memset(comp_file_type,0x00,sizeof(comp_file_type));

		strcpyA(reg_date     , getstr(row, 0));
		strcpyA(reg_time     , getstr(row, 1));
		strcpyA(disp_end_date, getstr(row, 2));
		strcpyA(disp_end_time, getstr(row, 3));
		strcpyA(reg_user     , getstr(row, 4));
		strcpyA(up_st_date   , getstr(row, 5));
		strcpyA(up_st_time   , getstr(row, 6));
		strcpyA(file_name2   , getstr(row, 7));
		bomul_id = (unsigned long)(getnum(row, 8));
		req_id = (unsigned long)(getnum(row, 9));
		strcpyA(cont_gu   , getstr(row, 10));
		strcpyA(item_color   , getstr(row, 11));
		strcpyA(item_bold_yn   , getstr(row, 12));
		strcpyA(bomul_gu   , getstr(row, 13));
		bomul_amt   = (unsigned int)getint(row, 14);
		strcpyA(bomul_item_code   , getstr(row, 15));
		bomul_prize_num   = (unsigned int)getint(row, 16);
		bomul_coupon_cnt = (unsigned int)getint(row, 17);
		strcpyA(limit_yn ,  getstr(row, 18));
		strcpyA(adult_yn ,  getstr(row, 19));
		strcpyA(adult_yn2 ,  adult_yn);
		strcpyA( title,getstr(row,20));
		lUserPriceAmt = (long)getnum(row,21) ;
		strcpyA(sect_code, getstr(row, 22));
		strcpyA(sect_sub, getstr(row, 23));

		strcpyA(disp_end_date_45, getstr(row, 24));
		strcpyA(disp_end_date_90, getstr(row, 25));
		strcpyA(disp_end_date_360, getstr(row, 26));

		file_size = (double)getnum(row,27);

		if( lUserPriceAmt > 0 )
			lUserMobilePriceAmt = lUserPriceAmt /2; //

		mysql_free_result(res);
	} // END : 등록일자 얻기 및 기본 데이터 얻기


	//////
	// 2. upload size check
	//////

	memset(szQuery1, 0x00, sizeof(szQuery1));
	if( strcmp(cont_gu , "WE") == 0)
	{
		sprintf(szQuery1,"select if(sum(file_size) is null, 0, sum(file_size)) as file_size from zangsi.T_CONTENTS_TEMPLIST_SUB where id = %lu ", pfups4001->id);
	}
	else if( strcmp(cont_gu , "FD") == 0)
	{
		sprintf(szQuery1,"select if(sum(file_size) is null, 0, sum(file_size)) as file_size from zangsi.T_CONTFLOG_TEMPLIST_SUB where id = %lu ", pfups4001->id);
	}
	else
	{
		goto fups4001_err;
	}


	if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery1))
	{
		ErrNum = -400101;
		sprintf(ErrMsg, "upload size check error 0 ");
		goto fups4001_err;
	}

	if (!(sum_res = mysql_store_result(con)))
	{
		ErrNum = -400102;
		sprintf(ErrMsg, "upload size check error 1 ");
		goto fups4001_err;
	}
 	if (mysql_num_rows(sum_res)<=0)
 	{
		ErrNum = -400102;
		sprintf(ErrMsg, "upload size check error 2 ");
		mysql_free_result(sum_res);
		goto fups4001_err;
	}
	sum_row = mysql_fetch_row(sum_res);

	sum_file_size = (double)getnum(sum_row,0);

	if(sum_file_size != file_size)
	{
		infLOG(ALWAY,"error 4001 : file_size [%.0f] ,sum_file_size [%.0f ] \n",file_size,sum_file_size);
		goto fups4001_err;
	}

	//////

	infLOG(ALWAY,"==cfups4001 START cont_gu:[%s]--TempID:[%lu]--Price:(%d)--SectCode:[%s:%s]--copyright_yn:[%s]\n", cont_gu, pfups4001->id, lUserPriceAmt, sect_code, sect_sub,pfups4001->copyright_yn);

	//////
	// 3. wedisk list upload : 일반 컨텐츠
	//////
	if( strcmp(cont_gu , "WE") == 0)
	{
		// 1. 악성 코드 조회
		sprintf(szQuery, "select count(*) from zangsi.T_CONTENTS_TEMPLIST_MUREKA  where id = %lu and file_gubun = '4' " ,pfups4001->id);

		if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
		{
			ErrNum = -400122;
			sprintf(ErrMsg, " T_CONTENTS_TEMPLIST_MUREKA에서 악성코드 검사 중 오류가 발생하였습니다.\n");
			infLOG(ERROR, "쿼리 : ( %s ) \n",szQuery);
	 	}

		if (!(res = mysql_store_result(con)))
		{
			ErrNum = -400199;
			sprintf(ErrMsg, "악성코드 추출 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
		}

		if(row = mysql_fetch_row(res))
		{
			if( getint(row,0) > 0 )
			{
				infLOG(ALWAY,"FUPS4001 temp_id [ %lu ] 는 악성코드입니다.\n",pfups4001->id);
				bHaveVirus = true;
			}
		}
		mysql_free_result(res);
		// END : 악성 코드 조회

		// 2. 임시파일목록 정보 조회
		memset(szQuery,  0x00, sizeof(szQuery));
		sprintf(szQuery, " select file_type  from zangsi.T_CONTENTS_TEMPLIST_SUB where id = %lu and file_size > 1024*1024*10 order by file_type desc limit 1; ", pfups4001->id);
		if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
		{
			ErrNum = -400199;
			sprintf(ErrMsg, "임시파일 정보 조회 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			goto fups4001_err;
		}
		if (!(res = mysql_store_result(con)))
		{
			ErrNum = -400199;
			sprintf(ErrMsg, "임시파일 정보 추출 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			goto fups4001_err;
		}

		// MBC,SBS등 방송사 구분
		while(row = mysql_fetch_row(res))
		{
			infLOG(ALWAY,"== szContType = %s\n",getstr(row,0));

			if( strcmp(pfups4001->sect_code ,"02") == 0 ||strcmp(pfups4001->sect_code ,"03") == 0 )
			{
				if(strcmp(getstr(row,0), "2") ==0 || strcmp(getstr(row,0), "99") ==0
					|| strcmp(getstr(row,0), "1") ==0 || strcmp(getstr(row,0), "4") ==0
					|| strcmp(getstr(row,0), "-99") ==0  )
				{
					infLOG(ERROR, "error : szMurekaCode 2\n");
					strcpy(szMurekaCode, "2");
					// 로그 추가
				}
			}

			if(strcmp(getstr(row,0), "30") ==0) // IMBC = 04 ,
				strcpy(szContType, "MBC");
			else if(strcmp(getstr(row,0), "31") ==0)
				strcpy(szContType, "KBS");
			else if(strcmp(getstr(row,0), "32") ==0)
				strcpy(szContType, "SBS");
			else if(strcmp(getstr(row,0), "33") ==0)//20100804. EBS
				strcpy(szContType, "EBS");
			else if(strcmp(getstr(row,0), "34") ==0)//20110217. KBSI
				strcpy(szContType, "KBSI");
			else if(strcmp(getstr(row,0), "35") ==0)
				strcpy(szContType, "MBCP");
			else if(strcmp(getstr(row,0), "38") ==0)
				strcpy(szContType, "iMBC");
			else if(strcmp(getstr(row,0), "39") ==0)
				strcpy(szContType, "MBCM");
			else if(strcmp(getstr(row,0), "40") ==0)
				strcpy(szContType, "CJETV ");
			else if(strcmp(getstr(row,0), "41") ==0)
				strcpy(szContType, "CJENM");
			else if(strcmp(getstr(row,0), "42") ==0)
				strcpy(szContType, "MBCV");
			else if( getstr(row,0) != NULL  && strlen(getstr(row,0)) > 0 ) //cj
			{
				strcpy(szContType,getstr(row,0));
			}
		}

		mysql_free_result(res);
		// END :2. 임시파일목록 정보 조회


		// 3. 이벤트 정보 조회 및 업데이트
		char recom_yn[2];
		memset(recom_yn,0x00,sizeof(recom_yn));

		memset(szQuery,  0x00, sizeof(szQuery));
		sprintf(szQuery, " select recom_yn from zangsi.T_EVENT_CONTENTS where cont_type = '%s' and use_yn='Y' limit 1 ", szContType);

		infLOG(ALWAY,"== szQuery = %s\n",szQuery);

		if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
		{
			ErrNum = -400199;
			sprintf(ErrMsg, "이벤트 정보 조회 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			//goto fups4001_err;
		}
		else
		{
			if (!(res = mysql_store_result(con)))
			{
				ErrNum = -400199;
				sprintf(ErrMsg, "임시파일 정보 추출 오류입니다.\n");
				infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			}
			else
			{
				if (  mysql_num_rows(res)<=0 )
				{
					infLOG(ALWAY,"T_EVENT_CONTENTS 가 없습니다. [ %s ] \n",szContType);
				}
				else
				{
					row = mysql_fetch_row(res);
					strcpy(recom_yn,getstr(row,0));

				}
				mysql_free_result(res);
			}
		}

		if( strcmp(recom_yn,"N") == 0 )
		{
			memset(szQuery,  0x00, sizeof(szQuery));
			sprintf(szQuery, " update zangsi.T_EVENT_CONTENTS set recom_yn='Y' where cont_type = '%s' and use_yn='Y'  ", szContType);

			if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
			{
				ErrNum = -400199;
				sprintf(ErrMsg, "이벤트 정보 업데이트 오류입니다.\n");
				infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
				//goto fups4001_err;
			}
		}
		// END : 3. 이벤트 정보 조회 및 업데이트


		// 4. 임시파일 정보 조회
		memset(szQuery,  0x00, sizeof(szQuery));
		sprintf(szQuery, " select count(*) from zangsi.T_CONTENTS_TEMPLIST where id = %lu  ", pfups4001->id);
		if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
		{
			ErrNum = -400199;
			sprintf(ErrMsg, "임시파일 정보 조회 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			goto fups4001_err;
		}
		if (!(res = mysql_store_result(con)))
		{
			ErrNum = -400199;
			sprintf(ErrMsg, "임시파일 정보 추출 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			goto fups4001_err;
		}
		if (  mysql_num_rows(res)<=0 )
		{
			strcpy(szMurekaCode, "2");
			infLOG(ALWAY,"T_CONTENTS_TEMPLIST 가 없습니다. [ %lu ] \n",pfups4001->id);
			// 로그 추가
		}


		row = mysql_fetch_row(res);

		if( getint(row,0) <= 0 )
		{
			strcpy(szMurekaCode, "2");
			infLOG(ALWAY,"T_CONTENTS_TEMPLIST 가 없습니다. [ %lu ] \n",pfups4001->id);
			// 로그 추가
		}
		mysql_free_result(res);
		// END : 4. 임시파일 정보 조회


		// 5. 성인 카테고리가 아니고, 일반 컨텐츠일 경우 무제한 99901231 게시기간 설정
		if(strcmp(sect_code, "11") != 0 && strcmp(pfups4001->copyright_yn ,"Y") != 0)
		{
			strcpyA(disp_end_date, "99901231");
		}
		// END : 5. 성인 카테고리가 아니고, 일반 컨텐츠일 경우 무제한 99901231 기간 설정

		// 5.5 블록 리스트 있는 경우.
		int nBlockCnt = CheckBlockList(con, MysqlCon, pfups4001->id);
		if(nBlockCnt > 0)
		{
			 strcpyA(pfups4001->copyright_yn ,"B");
			 InsertHoldLog(cpr_con, MysqlCprCon, -61, pfups4001 ,reg_date, reg_time);
 			 infLOG(ALWAY, "CheckBlockList copyright_yn [ %s ] \n",pfups4001->copyright_yn);
		}

		// 6. 음악 카테고리면서 제휴 컨텐츠일 경우 체크, 저작권 쪽지 목록 생성.
		if( strcmp(pfups4001->copyright_yn ,"Y") == 0 && strcmp(pfups4001->sect_code ,"07") == 0 )
		{
			memset(szQuery,  0x00, sizeof(szQuery));
			sprintf(szQuery, "select file_name  from zangsi.T_CONTENTS_TEMPLIST_SUB where "
				" id = %lu and reg_user = '%s' and copyright_yn = 'Y' limit 10 " ,pfups4001->id  , reg_user);

			if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
			{
				strcpy(ErrMsg,"정보 조회 오류입니다.");
				infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			}
			else
			{
				if (!(res = mysql_store_result(con)))
				{
					strcpy(ErrMsg," 저작권 쪽지 목록 생성을 위한 모록 추출 오류입니다.\n");
					infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
				}
				else
				{
					if (  mysql_num_rows(res)<=0)
					{
						strcpy(ErrMsg, "저작권 쪽지 생성을 위한  목록이  없습니다.\n");
						infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",ErrMsg,szQuery);
						mysql_free_result(res);
					}
					else
					{
						int nMaxMemoLen = sizeof(szMemoInfo);
						char szFileName[512];
						int nCount = 0;
						while((row = mysql_fetch_row(res)) && nCount < 10  )
						{
							memset(szFileName , 0x00,sizeof(szFileName));
							strcpyA(szFileName , getstr(row,0));
							nMaxMemoLen = nMaxMemoLen - ( strlen(szFileName) + 2 );
							if( nMaxMemoLen <= 0 )
								break;
							ReplaceSingleToDouble(szFileName);
							strcat( szMemoInfo , szFileName );
							strcat ( szMemoInfo , "\r\n" );
							nCount++;
						}
						mysql_free_result(res);
					}
				}
			}
		}
		// END : 6. 음악 카테고리면서 제휴 컨텐츠일 경우 체크, 저작권 쪽지 목록 생성.

		// 7.요청 자료 등록일 경우 체크
		if( req_id > 0  )
		{
			memset(szQuery,  0x00, sizeof(szQuery));
			sprintf(szQuery, "select reg_user,title from zangsi.T_CONTENTS_REQ where id = %lu",req_id );
			if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
			{
				ErrNum = -400191;
				sprintf(ErrMsg, "요청자료 데이터 수집 오류입니다.\n");
				infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%d)(%s)\n",szQuery,mysql_errno(con), mysql_error(con));
				goto fups4001_err;
			}

			if (!(res = mysql_store_result(con)))
			{
				ErrNum = -400192;
				sprintf(ErrMsg, "요청자료 데이터 추출 오류입니다.\n");
				infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
				goto fups4001_err;
			}
			if (mysql_num_rows(res)<=0)
			{
				ErrNum = -400193;
				sprintf(ErrMsg, "검색된 요청자료가 없습니다.\n");
				infLOG(ERROR, " FUPS4001 Error Msg   ] [ %s ]\n",ErrMsg);
				infLOG(ERROR, " FUPS4001 Error Query ] [ %s ] \n",szQuery);
				bIsReqMemoSend = false;
			}
			else
			{
				row = mysql_fetch_row(res);
				strcpyA(szReqUser,getstr(row, 0));
				strcpyA(req_title,getstr(row, 1));
			}
			mysql_free_result(res);
		}
		// END : 7.요청 자료 등록일 경우 체크


		// 7.5 제휴 유저가 등록한 컨텐츠는 모두 심사중

		memset(szQuery, 0x00, sizeof(szQuery));
		sprintf(szQuery, " select * from zangsi.T_PERM_UPLOAD_AUTH a where a.auth_num = 'CPR' and a.user_id = '%s'; /* dcmdfup4001 */ " , reg_user);

		if (MysqlCon.MysqlQuery(con,szSysErrMsg, szQuery))
		{
			ErrNum = -400191;
			sprintf(ErrMsg, "제휴 유저가 등록한 컨텐츠는 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%d)(%s)\n",szQuery,mysql_errno(con), mysql_error(con));
			goto fups4001_err;
		}

		if (!(res = mysql_store_result(con)))
		{
			ErrNum = -400192;
			sprintf(ErrMsg, "요청자료 데이터 추출 오류입니다.\n");
			infLOG(ERROR, " FUPS4001 Error Info  ] (%s)(%s)(%d)(%s)\n",ErrMsg,szQuery,mysql_errno(con), mysql_error(con));
			goto fups4001_err;
		}
		if (mysql_num_rows(res)<=0)
		{
			// 비제휴 유저
			infLOG(ALWAY,"dcmdfups4001> copyright_yn 2 = [%lu][%s]\n",pfups4001->id, pfups4001->copyright_yn);
			infLOG(ALWAY, "reg_user [ %s ] \n",reg_user);
		}
		else
		{
			// 제휴 유저
			strcpyA(pfups4001->copyright_yn,"P"); // 심사중 처리
			infLOG(ALWAY,"dcmdfups4001> copyright_yn 3 = [%lu][%s]\n",pfups4001->id, pfups4001->copyright_yn);
			infLOG(ALWAY, "CPR reg_user [ %s ] \n",reg_user);
			InsertHoldLog(cpr_con, MysqlCprCon, -68, pfups4001 ,reg_date, reg_time);
		}
		mysql_free_result(res);


		// END : 7.5 제휴 유저가 등록한 컨텐츠는 모두 심사중


	   // 8 해당 아이디 등록대기
