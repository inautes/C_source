#ifndef	_DCMD9301_H_
#define	_DCMD9301_H_
#include "comhead.h"


typedef struct _CCOM9301_R
{
	char	szProc_date[8+1];
	char	szServer_Id[6+1];	
}CCOM9301_R, *LPCCOM9301_R;

typedef struct _DELLLIST
{
	unsigned int id         ;	// 컨텐츠ID
	double file_size        ;	// 파일크기
	char   file_path [256];	// 파일결로
	char   file_name1 [ 32];	// 파일이름
	char   del_date  [  9+1];	// 삭제예정일
	char   cont_gu   [  4];	// 서버구분
	char   folder_yn [ 2   ];
	
}DELLLIST, *LPDELLLIST;


long dcmd9301(int sock , LPHEADER pHeader , char* pRecvData , char* &pSendData);
#endif

