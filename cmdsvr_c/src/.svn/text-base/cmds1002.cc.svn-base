/******************************************************************************
 *   서브시스템 : CMD서버
 *   프로그램명 : cmds1002.cc
 *         기능 : 사용자ID롤 공유등록 자료를 검색한다.
 *         설명 :
 *       작성자 : 전봉구
 *       작성일 : 2004/02/16
 *     수정이력 :
********************************************************************************
1         2         3         4         5         6         7         8
12345678901234567890123456789012345678901234567890123456789012345678901234567890
*******************************************************************************/
#include <mysql.h>
#include <stdarg.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "apdefine.h"
#include "comcomm.h"
#include "commydb.h"
#include "cmds1002.h"

#define  MAX_ROWS	500
//#define  _DEBUG_
//******************************************************************************
//* cmds1002 main
//******************************************************************************
int cmds1002(char *pRecvHead, char *pRecvData, char* &pSendData)
{
	MYSQL     *con;
	MYSQL_RES *res;
	MYSQL_ROW  row;
	unsigned int num_fields;

	LPHEADER     p_headerr;
	CCMDS1002_R	*p_cmds1002r;

	char szQuery[10000]; // query string
	char ErrMsg[256];    // error message
	int  ErrNum;         // error no
	int  nRowcnt;        // select row count
	// input variables
	int     find_flag               ;  // 검색구분 [1]등록현황 [2]다운로드현황
	char    user_id           [12+1];  // 사용자ID

	/*--------------------------------------------------------------------*/
	/* start!!!                                                           */
	/*--------------------------------------------------------------------*/
	#ifdef _DEBUG_
	printf("cmds1002-> start...\n");
	#endif
	p_headerr   = (LPHEADER) pRecvHead;
	p_cmds1002r = (LPCCMDS1002_R) pRecvData;

	// local 변수 Clear
	memset(&ErrMsg   , 0x00, sizeof(ErrMsg   )); /* 오류메시지     */
	memset(&find_flag, 0x00, sizeof(find_flag)); /* 검색구분       */
	memset(&user_id  , 0x00, sizeof(user_id  )); /* 사용자ID       */

	find_flag   = p_cmds1002r->find_flag;
	//strcpy(user_id, p_cmds1002r->user_id);
	memcpy(user_id, p_cmds1002r->user_id,sizeof(p_cmds1002r->user_id));

	#ifdef _DEBUG_
	printf("cmds1002->find_flag=(%d)\n", find_flag);
	printf("cmds1002->user_id  =(%s)\n", user_id  );
	#endif

	if (find_flag == 1)
	{
		//컨텐츠 등록 조회
		memset (szQuery, 0x00, sizeof(szQuery ));
		sprintf(szQuery, "select b.reg_user      , a.title                     "
		                 "     , a.sect_code     , c.minor_name as sect_name   "
		                 "     , a.share_meth    , d.minor_name as share_name  "
		                 "     , b.folder_yn     , b.file_path                 "
		                 "     , b.file_name1    , b.file_name2                "
		                 "     , b.server_id     , e.server_ip                 "
		                 "     , e.server_port   , a.price_amt                 "
		                 "     , a.won_mega      , b.file_size                 "
		                 "     , b.qury_cnt      , b.down_cnt                  "
		                 "     , TO_DAYS(a.disp_end_date) - TO_DAYS(NOW()) as disp_days "
		                 "     , a.id            "
		                 "     , concat(b.reg_date,b.reg_time) as reg_dttm     "
		                 "  from T_CONTENTS_INFO a             "
		                 "     , T_CONTENTS_FILE b             "
		                 "     , T_MINOR_CODE    c             "
		                 "     , T_MINOR_CODE    d             "
		                 "     , T_SERVER_INFO   e             "
		                 " where a.reg_user   = '%s'           "
		                 "   and a.disp_stat  = 'Y'            "
		                 "   and a.id         = b.id           "
		                 "   and c.major_code = '01'           "
		                 "   and c.minor_code = a.sect_code    "
		                 "   and d.major_code = '02'           "
		                 "   and d.minor_code = a.share_meth   "
		                 "   and b.server_id  = e.server_id    "
		                 "  order by reg_dttm DESC             "
		                 ,user_id
		                 );
		              
		 #ifdef _DEBUG_
		 printf("select b.reg_user      , a.title                     \n"
		                 "     , a.sect_code     , c.minor_name as sect_name   \n"
		                 "     , a.share_meth    , d.minor_name as share_name  \n"
		                 "     , b.folder_yn     , b.file_path                 \n"
		                 "     , b.file_name1    , b.file_name2                \n"
		                 "     , b.server_id     , e.server_ip                 \n"
		                 "     , e.server_port   , a.price_amt                 \n"
		                 "     , a.won_mega      , b.file_size                 \n"
		                 "     , b.qury_cnt      , b.down_cnt                  \n"
		                 "     , TO_DAYS(a.disp_end_date) - TO_DAYS(NOW()) as disp_days \n"
		                 "     , a.id           \n "
		                 "     , concat(b.reg_date,b.reg_time) as reg_dttm    \n "
		                 "  from T_CONTENTS_INFO a           \n  "
		                 "     , T_CONTENTS_FILE b            \n "
		                 "     , T_MINOR_CODE    c            \n "
		                 "     , T_MINOR_CODE    d            \n "
		                 "     , T_SERVER_INFO   e            \n "
		                 " where a.reg_user   = '%s'           \n"
		                 "   and a.disp_stat  = 'Y'            \n"
		                 "   and a.id         = b.id           \n"
		                 "   and c.major_code = '01'           \n"
		                 "   and c.minor_code = a.sect_code    \n"
		                 "   and d.major_code = '02'           \n"
		                 "   and d.minor_code = a.share_meth   \n"
		                 "   and b.server_id  = e.server_id    \n"
		                 "  order by reg_dttm DESC            \n "
		                 ,user_id
		                 );
		 #endif
	}
	else
	{
		//컨텐츠 다운로드 목록조회
		memset (szQuery, 0x00, sizeof(szQuery ));
		sprintf(szQuery, "select b.reg_user      , z.title                     "
		                 "     , z.sect_code     , c.minor_name as sect_name   "
		                 "     , z.share_meth    , d.minor_name as share_name  "
		                 "     , b.folder_yn     , b.file_path                 "
		                 "     , b.file_name1    , b.file_name2                "
		                 "     , b.server_id     , e.server_ip                 "
		                 "     , e.server_port   , z.price_amt                 "
		                 "     , z.won_mega      , b.file_size                 "
		                 "     , ifnull(f.qury_cnt, b.qury_cnt)                "
		                 "     , ifnull(f.down_cnt, b.down_cnt)                "
		                 "     , TO_DAYS(z.deal_date) - TO_DAYS(NOW())+3 as disp_days "
		                 "     , z.id            , z.deal_no   , z.down_yn  "
		                 "     , concat(b.reg_date,b.reg_time) as reg_dttm  "
		                 "  from T_DEAL_INFO     z             "
		                 "     , T_DEAL_FILE     b left outer join "
		                 "       T_CONTENTS_FILE f             "
		                 "     , T_MINOR_CODE    c             "
		                 "     , T_MINOR_CODE    d             "
		                 "     , T_SERVER_INFO   e             "
		                 "    ON b.id         = f.id           "
		                 " where z.buy_user   = '%s'           "
		                 "   and z.del_yn     = 'N'            "
		                 "   and z.id         = b.id           "
		                 "   and c.major_code = '01'           "
		                 "   and c.minor_code = z.sect_code    "
		                 "   and d.major_code = '02'           "
		                 "   and d.minor_code = z.share_meth   "
		                 "   and b.server_id  = e.server_id    "
		                 "  order by reg_dttm DESC             "
		                 ,user_id
		                 );
		                 
	}

	// DB 연결
	
	if (!(con=db_connect("zangsi")))
	{
		
		
		ErrNum = -100201;
		sprintf(ErrMsg, "DB에 접속하지 못 하였습니다...\n");
		#ifdef _DEBUG_
		printf("cmds1002->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds1002->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
	
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
       	return(ErrNum); 
	}
	

	if (mysql_query(con, szQuery)){
		ErrNum = -100202;
		sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
		#ifdef _DEBUG_
		printf("cmds1002->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds1002->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
	
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
       	return(ErrNum); 
	}

	//임시버퍼생성
	LPCCMDS1002_S t_cmds1002s = new CCMDS1002_S[MAX_ROWS];//struct _FILEINFO;
	memset(t_cmds1002s, 0x00, (sizeof(CCMDS1002_S)*MAX_ROWS));

	//질의 결과를 얻는다
	if (!(res = mysql_store_result(con)))
	{
		delete[] t_cmds1002s;

		#ifdef _DEBUG_
		printf( "1.자료가 없습니다.\n");
		#endif
		ErrNum = -999999;
		sprintf(ErrMsg, "자료가 없습니다.\n");
	
		mysql_free_result(res);
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
       	return(ErrNum); 
	}	
 	if (mysql_num_rows(res)==0)
 	{
		delete[] t_cmds1002s;


		#ifdef _DEBUG_
		printf( "2.자료가 없습니다.\n");
		#endif
		
		ErrNum = -999999;
		sprintf(ErrMsg, "자료가 없습니다.\n");
	
		mysql_free_result(res);
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
       	return(ErrNum); 
	}
	
	nRowcnt = 0;
	while((row = mysql_fetch_row(res))) {
		#ifdef _DEBUG_
		printf("reg_user   [%d](%s)\n", nRowcnt, getstr(row, 0)); // 등록자
		printf("title      [%d](%s)\n", nRowcnt, getstr(row, 1)); // 제목
		printf("sect_code  [%d](%s)\n", nRowcnt, getstr(row, 2)); // 분류코드
		printf("sect_name  [%d](%s)\n", nRowcnt, getstr(row, 3)); // 분류명
		printf("share_meth [%d](%s)\n", nRowcnt, getstr(row, 4)); // 공유방법
		printf("share_name [%d](%s)\n", nRowcnt, getstr(row, 5)); // 공유방법명
		printf("folder_yn  [%d](%s)\n", nRowcnt, getstr(row, 6)); // 폴더여부
		printf("file_path  [%d](%s)\n", nRowcnt, getstr(row, 7)); // 파일경루
		printf("file_name1 [%d](%s)\n", nRowcnt, getstr(row, 8)); // 서버파일이름
		printf("file_name2 [%d](%s)\n", nRowcnt, getstr(row, 9)); // 로컬파일이름
		printf("server_id  [%d](%s)\n", nRowcnt, getstr(row,10)); // 서버ID
		printf("server_ip  [%d](%s)\n", nRowcnt, getstr(row,11)); // 서버IP
		printf("server_port[%d](%d)\n", nRowcnt, getint(row,12)); // 서버port
		printf("price_amt  [%d](%d)\n", nRowcnt, getint(row,13)); // 희망가격
		printf("won_mega   [%d](%d)\n", nRowcnt, getint(row,14)); // 원당메가
		printf("file_size  [%d](%15.0f)", nRowcnt, getnum(row,15)); // 희망가격
		printf("qury_cnt   [%d](%d)\n", nRowcnt, getint(row,16)); // 조회건수
		printf("qury_cnt   [%d](%d)\n", nRowcnt, getint(row,17)); // 조회건수
		printf("disp_day   [%d](%d)\n", nRowcnt, getint(row,18)); // 잔여일
		printf("id         [%d](%d)\n", nRowcnt, getint(row,19)); // 컨테츠ID
		#endif

		strcpy(t_cmds1002s[nRowcnt].reg_user    , getstr(row, 0));
		strcpy(t_cmds1002s[nRowcnt].title       , getstr(row, 1));
		strcpy(t_cmds1002s[nRowcnt].sect_code   , getstr(row, 2));
		strcpy(t_cmds1002s[nRowcnt].sect_name   , getstr(row, 3));
		strcpy(t_cmds1002s[nRowcnt].share_meth  , getstr(row, 4));
		strcpy(t_cmds1002s[nRowcnt].share_name  , getstr(row, 5));
		strcpy(t_cmds1002s[nRowcnt].folder_yn   , getstr(row, 6));
		strcpy(t_cmds1002s[nRowcnt].file_path   , getstr(row, 7));
		strcpy(t_cmds1002s[nRowcnt].file_name1  , getstr(row, 8));
		strcpy(t_cmds1002s[nRowcnt].file_name2  , getstr(row, 9));
		strcpy(t_cmds1002s[nRowcnt].server_id   , getstr(row,10));
		strcpy(t_cmds1002s[nRowcnt].server_ip   , getstr(row,11));
		       t_cmds1002s[nRowcnt].server_port = getint(row,12);
		       t_cmds1002s[nRowcnt].price_amt   = getint(row,13);
		       t_cmds1002s[nRowcnt].won_mega    = getint(row,14);
		       t_cmds1002s[nRowcnt].file_size   = getnum(row,15);
		       t_cmds1002s[nRowcnt].qury_cnt    = getint(row,16);
		       t_cmds1002s[nRowcnt].down_cnt    = getint(row,17);
		       t_cmds1002s[nRowcnt].disp_day    = getint(row,18);
		       t_cmds1002s[nRowcnt].id          = getint(row,19);
		if (find_flag == 1)
		{
			       t_cmds1002s[nRowcnt].deal_no     = 0;
			strcpy(t_cmds1002s[nRowcnt].down_yn     , "");
		}
		else
		{
			       t_cmds1002s[nRowcnt].deal_no     = getint(row,20);
			strcpy(t_cmds1002s[nRowcnt].down_yn     , getstr(row,21));
		}
		nRowcnt++;
		
		// buffer크기 보다 큰경우
		if (nRowcnt >= MAX_ROWS)
			break;
	}
	mysql_free_result(res);
	db_disconnect(con);

	if (nRowcnt < 1)
	{
		delete[] t_cmds1002s;

		ErrNum = -999999;
		sprintf(ErrMsg, "자료가 없습니다.\n");

		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
       	return(ErrNum); 
	}
	
	//전송할 버퍼생성
	int nDataSize = HEADER_SIZE + sizeof(CCMDS1002_S) * nRowcnt;
	
	HEADER headers;
	memcpy(&headers, p_headerr, HEADER_SIZE); //header	
	headers.nDataCnt  = nRowcnt;
	headers.nDataSize = sizeof(CCMDS1002_S);

	pSendData = new char[nDataSize];
	memset(pSendData, 0x00, nDataSize);
	
	memcpy(pSendData, &headers, sizeof(HEADER)); //header	
	memcpy(pSendData+HEADER_SIZE, t_cmds1002s, nDataSize - HEADER_SIZE); //body
	delete[] t_cmds1002s;

//	printf("cmds1002-> end sucess sendsize(%d)\n", nDataSize);

	return (1);
}

/*------------------------------------------------------------------------------
select b.reg_user      , a.title                     
     , a.sect_code     , c.minor_name as sect_name   
     , a.share_meth    , d.minor_name as share_name  
     , b.folder_yn     , b.file_path                 
     , b.file_name1    , b.file_name2                
     , b.server_id     , e.server_ip                 
     , e.server_port   , a.price_amt                 
     , a.won_mega      , b.file_size                 
     , b.qury_cnt                                    
     , TO_DAYS(a.disp_end_date) - TO_DAYS(NOW()) as disp_days
     , a.id                                       
     , concat(b.reg_date,b.reg_time) as reg_dttm  
  from T_CONTENTS_INFO a             
     , T_CONTENTS_FILE b             
     , T_MINOR_CODE    c             
     , T_MINOR_CODE    d             
     , T_SERVER_INFO   e             
 where b.reg_user   = 'jbk'           
   and a.disp_stat  = 'Y'            
   and a.id         = b.id           
   and c.major_code = '01'           
   and c.minor_code = a.sect_code    
   and d.major_code = '02'           
   and d.minor_code = a.share_meth   
   and b.server_id  = e.server_id    
  order by reg_dttm DESC             
------------------------------------------------------------------------------*/

