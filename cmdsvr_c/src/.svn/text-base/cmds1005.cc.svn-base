/******************************************************************************
 *   서브시스템 : CMD서버
 *   프로그램명 : cmds1005.cc
 *         기능 : 각서버군에서 적정서버를 찾아 IP와 Port를 전송한다. admin 기능
 *         설명 :
 *       작성자 : 전봉구
 *       작성일 : 2004/02/16
 *     수정이력 :
********************************************************************************
1         2         3         4         5         6         7         8
12345678901234567890123456789012345678901234567890123456789012345678901234567890
*******************************************************************************/
#include <mysql.h>
#include <stdarg.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "apdefine.h"
#include "comcomm.h"
#include "commydb.h"
#include "cmds1005.h"

#define  MAX_ROWS	100

//#define  _DEBUG_

//******************************************************************************
//* cmds1005 main
//******************************************************************************
int cmds1005(char *pRecvHead, char *pRecvData, char* &pSendData)
{
	MYSQL     *con;
	MYSQL_RES *res;
	MYSQL_ROW  row;

	LPHEADER     p_headerr;
	//CCMDS1005_R	*//p_cmds1005r;
	
	char szQuery[1000];  // query string
	char ErrMsg[256];    // error message
	int  ErrNum;         // error no
	int  nRowcnt;        // select row count

	// input variables
	int  find_flag         ;  // 검색구분 [1]WE디스크  [2]MY디스크

	/*--------------------------------------------------------------------*/
	/* start!!!                                                           */
	/*--------------------------------------------------------------------*/
	#ifdef _DEBUG_
	printf("cmds1005-> start...\n");
	#endif
	p_headerr   = (LPHEADER     ) pRecvHead;
	//p_cmds1005r = (LPCCMDS1005_R) pRecvData;

	// local 변수 Clear
	memset(&ErrMsg   , 0x00, sizeof(ErrMsg   )); /* 오류메시지     */
	
		// 서버 목록 조회 01
	memset (szQuery, 0x00, sizeof(szQuery ));
	sprintf(szQuery, "select a.server_id,   a.server_ip,                 "
	                 "       a.server_port,	a.dnsvr_port,              "
	                 "       a.upsvr_port,  a.server_gu                  "
	                 "  from T_SERVER_INFO a                    "
	                 "	where a.server_gu in('01','02','06')           "
	                 "order by a.server_id                               ");
	                 

	

	// DB 연결
	
	if (!(con=db_connect("zangsi")))
	{
		ErrNum = -100591;
		sprintf(ErrMsg, "DB에 접속하지 못 하였습니다...\n");
		#ifdef _DEBUG_
		printf("cmds1005->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds1005->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
		
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
	   	return(ErrNum); 

	}	
	
	
	
	if (mysql_query(con, szQuery)){
		ErrNum = -100502;
		sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
		#ifdef _DEBUG_
		printf("cmds1005->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds1005->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
		
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
       	return(ErrNum); 
	}

	//질의 결과를 얻는다
	if (!(res = mysql_store_result(con))) {
		ErrNum = -100503;
		sprintf(ErrMsg, "검색시 오류가 발생하였습니다.\n");
		#ifdef _DEBUG_
		printf("cmds1005->ERRMSG: [%d](%s)",ErrNum, ErrMsg);
		printf("cmds1005->DB ERR: [%d](%s)",mysql_errno(con), mysql_error(con));
		#endif
	
		db_disconnect(con);
		E_dump(ErrNum, ErrMsg, pSendData);
       	return(ErrNum); 
	}

	//임시버퍼생성
	LPCCMDS1005_S t_cmds1005s = new CCMDS1005_S[MAX_ROWS];//struct _FILEINFO;
	memset(t_cmds1005s, 0x00, (sizeof(CCMDS1005_S)*MAX_ROWS));

	nRowcnt = 0;
 	if (mysql_num_rows(res)!=0)
 	{
		while((row = mysql_fetch_row(res))) 
		{
			#ifdef _DEBUG_
			printf("t_cmds1005s[nRowcnt].server_id(%s)\n", getstr(row, 0));
			printf("t_cmds1005s[nRowcnt].server_ip(%s)\n", getstr(row, 1));
			printf("t_cmds1005s[nRowcnt].my_port  (%d)\n", getint(row, 2));
			printf("t_cmds1005s[nRowcnt].dn_port  (%d)\n", getint(row, 3));
			printf("t_cmds1005s[nRowcnt].up_port  (%d)\n", getint(row, 4));
			printf("t_cmds1005s[nRowcnt].szServerCode  (%s)\n", getstr(row, 5));
			//printf("t_cmds1005s[nRowcnt].root_path(%s)\n", getstr(row, 4));
			#endif
			
			strcpy(t_cmds1005s[nRowcnt].server_id, getstr(row, 0));
			strcpy(t_cmds1005s[nRowcnt].server_ip, getstr(row, 1));
				   t_cmds1005s[nRowcnt].my_port  = getint(row, 2);
			       t_cmds1005s[nRowcnt].dn_port  = getint(row, 3);
			       t_cmds1005s[nRowcnt].up_port  = getint(row, 4);
			strcpy(t_cmds1005s[nRowcnt].szServerCode, getstr(row, 5));
			       
			
	
			nRowcnt++;
			
			// buffer크기 보다 큰경우
			if (nRowcnt >= MAX_ROWS)
				break;
		}
	}
	mysql_free_result(res);
	db_disconnect(con);

	//전송할 버퍼생성
	int nDataSize = HEADER_SIZE + sizeof(CCMDS1005_S) * nRowcnt;
	
	HEADER headers;
	memcpy(&headers, p_headerr, HEADER_SIZE); //header	
	headers.nDataCnt  = nRowcnt;
	headers.nDataSize = sizeof(CCMDS1005_S);

	pSendData = new char[nDataSize];
	memset(pSendData, 0x00, nDataSize);
	
	memcpy(pSendData, &headers, sizeof(HEADER)); //header	
	memcpy(pSendData+HEADER_SIZE, t_cmds1005s, nDataSize - HEADER_SIZE); //body
	delete[] t_cmds1005s;

	#ifdef _DEBUG_
	printf("cmds1005-> end sucess sendsize(%d)\n", nDataSize);
	#endif

	return (1);
}


/*
select a.server_id ,  a.server_ip,
       a.upsvr_port,  a.dnsvr_port,
       concat(a.root_path, '/', date_format(now(),'%Y/%m/%d/%H')) root_path
  from T_SERVER_INFO a     
 where a.server_gu = '01'         
   and round((a.disk_use / a.disk_size) * 100) < 90 
 order by a.disk_size - a.disk_use desc limit 1                   
                 

select a.server_id ,  a.server_ip,
       a.upsvr_port,  a.dnsvr_port,
       concat(a.root_path, '/',
       if(mod(a.use_cnt,100)=0, TRUNCATE(a.use_cnt/100,0) + 1000, TRUNCATE(a.use_cnt/100,0) + 1005))
  from T_SERVER_INFO a     
 where a.server_gu = '02'         
   and round((a.disk_use / a.disk_size) * 100) < 90 
 order by a.use_cnt asc limit 1       
                
*/
