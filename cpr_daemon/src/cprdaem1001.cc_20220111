// zangsi_cpr.T_CPR_DEAL_INFO proc_yn='R' 값 다시 체크해서 업데이트 해주는데몬
int cprdaem1001_process_db_temp()
{
	printf("cprdaem1001_process_db_temp \n");
	MYSQL_RES *g_res;
	MYSQL_ROW  g_row;

	char szQuery[2048];		// query string
	char szQuery2[1024];		// query string
	int  ret;

	double dCount = 0;
	int nRowCnt = 0;

	unsigned long deal_no = 0;
	char sale_cd[4];
	char proc_yn[4];

	double comp_amt = 0;		// 회사 가격
	double sum_comp_amt = 0;
	double event_comp_amt = 0;	// 이벤트 파일 : 회사 가격
	double event_sum_comp_amt = 0;

	double cpr_amt = 0;			// 제휴사 가격
	double sum_cpr_amt = 0;
	double event_cpr_amt = 0;  // 이벤트 파일 : 제휴사 가격
	double event_sum_cpr_amt = 0;

	double event_amt =0;
	double sum_event_amt =0;
	double price_amt =0;
	double sum_price_amt = 0;

	// 회사 코드 기준 이벤트 가격
	double cp_comp_amt = 0;
	double cp_sum_comp_amt = 0;
	double cp_cpr_amt = 0;
	double cp_sum_cpr_amt = 0;

	// 회사 코드 기준 이벤트 가격
	double cm_comp_amt = 0;
	double cm_sum_comp_amt = 0;
	double cm_cpr_amt = 0;
	double cm_sum_cpr_amt = 0;

	double comp_pc_event_amt=0;
	double sum_comp_pc_event_amt=0;
	double comp_mobile_event_amt=0;
	double sum_comp_mobile_event_amt=0;

	unsigned long chi_id = 0;
	double cpr_payment_rate = 0;
	char comp_cd[7+1];
	long list_seq_no =0;
	long list_id =0;

	//data set

	MYSQL_RES *cpr_res = NULL;
	MYSQL_ROW  cpr_row;

	MYSQL_RES *res = NULL;
	MYSQL_ROW  row;

	DEALINFO deal_data;
	memset(&deal_data,0x00,sizeof(DEALINFO));
	DEALINFO_FILE deal_file[1024];
	memset(deal_file,0x00,sizeof(DEALINFO_FILE)*1024);
	int nDealFileCnt = 0;


	deal_no = Get_Start_deal_no();

	printf("deal_no %lu \n",deal_no);
	if(deal_no <= 0)
		return 0;

	//신규 로직
	while(1)
	{

		//100개씩 구매정보 읽어 들이기
		memset(&deal_data,0x00,sizeof(DEALINFO));
		memset(deal_file,0x00,sizeof(DEALINFO_FILE)*1024);
		nDealFileCnt =0;
		nRowCnt =0;
		memset (szQuery, 0x00, sizeof(szQuery));


		sprintf(szQuery, " select a.deal_no , a.sale_cd, a.proc_yn from zangsi_cpr.T_CPR_DEAL_INFO a where a.proc_yn IN('R') and a.deal_no >= %lu ORDER BY a.deal_no limit 100  ; /* cprdaem1001 */ ",deal_no);

		ZzLOG(ALWAY, "[%s]\n",szQuery);

		if (mysql_query(cpr_con, szQuery))
		{
		    ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));	return -1;
		}
		if (!(g_res = mysql_store_result(cpr_con)))
		{
			ZzLOG(ERROR, "mysql_store_result [%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));	return -1;
		}
		nRowCnt = mysql_num_rows(g_res);

		if (mysql_num_rows(g_res) <= 0)
	 	{
			mysql_free_result(g_res);
			sleep(3);
		    return 0;
		}

		g_row = mysql_fetch_row(g_res);


		while((g_row = mysql_fetch_row(g_res)))
		{
			//이미 등록되어있는지 검사
				deal_no = 0;
				nDealFileCnt =0;
				memset(deal_file,0x00,sizeof(DEALINFO_FILE)*1024);
				memset(sale_cd,0x00,sizeof(sale_cd));
				memset(proc_yn,0x00,sizeof(proc_yn));
				nDealFileCnt = 0;

				event_sum_comp_amt = 0;
				event_sum_cpr_amt = 0;

				sum_price_amt=0;
				sum_event_amt = 0;
				sum_comp_amt = 0;
				sum_cpr_amt = 0;

				deal_no =(unsigned long)getnum(g_row,0);

				//id =(unsigned long)getnum(g_row,1);
				strcpy(sale_cd,getstr(g_row,1));
				strcpy(proc_yn,getstr(g_row,2));

					//T_DEAL_MUREKA_KEY 넣기
				memset (szQuery, 0x00, sizeof(szQuery));
				sprintf(szQuery," select a.deal_no, a.cont_gu, a.id, a.list_seq, a.filtering_key  ,b.default_hash , b.file_size "
								" from zangsi.T_DEAL_INFO_MUREKA_KEY a, zangsi.T_CONTENTS_FILELIST_SUB b "
								" where a.deal_no = %lu and length(a.filtering_key) > 0 and a.list_seq = b.seq_no  ; /* cprdaem1001 */ ",deal_no);

				ZzLOG(ALWAY, "[%s]\n",szQuery);

				if( deal_no != temp_deal_no)
				{
					temp_deal_no = deal_no;
					gnType = 0;
				}
				else
				{
					gnCnt++;
				}

				if(gnCnt > 50)
				{
					return -2;
				}

				if (mysql_query(con, szQuery))
				{
					ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
				}
				else
				{
					if (!(res = mysql_store_result(con)))
					{
						ZzLOG(ERROR, "mysql_store_result [%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
						break;
					}
					else
					{
						while(row = mysql_fetch_row(res))
						{


							if ( getstr(row,5) != NULL && strlen(getstr(row,5)) > 0 )
							{

								memset(szQuery, 0x00, sizeof(szQuery));
								sprintf(szQuery, " select c.list_id"
												 " from zangsi_cpr.T_CPR_HASH_FILE a , zangsi_cpr.T_CPR_HASH_INFO b, zangsi_cpr.T_CPR_CONT_LIST c "
												 " where "
												 " a.chi_id = b.chi_id and b.list_id = c.list_id  and a.default_hash = '%s'  ; /* cprdaem1001 */ "
												 ,getstr(row,5) );

								ZzLOG(ALWAY, "[%s]\n",szQuery);

								if (mysql_query(cpr_con, szQuery))
								{
								    ZzLOG(ERROR, "cprdaem1001_deal_info: select error...\n");
									ZzLOG(ERROR, "cprdaem1001_deal_info: [%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
									ZzLOG(ERROR, "%s\n\n",szQuery);
									if((mysql_errno(cpr_con) == 2008) || (mysql_errno(cpr_con) == 2013))
										return -2;
									else
										break;
							    }
								if (!(cpr_res = mysql_store_result(cpr_con)))
								{
								    ZzLOG(ERROR, "cprdaem1001_deal_info: mysql_store_result error...\n");
									ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
									ZzLOG(ERROR, "%s\n\n",szQuery);

									break;
								}

							 	if ( mysql_num_rows(cpr_res) <= 0 )
							 	{
							 		ZzLOG(ERROR, "mysql_num_rows(cpr_res)\n");
									mysql_free_result(cpr_res);
								}
								else
								{
									cpr_row = mysql_fetch_row(cpr_res);
									unsigned long list_id =(unsigned long)getnum(cpr_row,0);
									mysql_free_result(cpr_res);

									/*sprintf(szQuery, " INSERT INTO zangsi_cpr.T_DEAL_INFO_MUREKA_KEY	"
													" (deal_no, cont_gu, id, list_seq, filtering_key ) "
									                " values ( %lu , '%s' ,%lu , %lu , '%s' ) "
									                , deal_no , getstr(row,1),(unsigned long)getnum(row,2),list_id ,getstr(row,4));
									printf ("%s\n",szQuery);
									ZzLOG(ALWAY, "[ %s ]\n",szQuery);
									if (mysql_query(cpr_real_con, szQuery))
									{
										ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(cpr_real_con), mysql_error(cpr_real_con));
										if( mysql_errno(cpr_real_con) == 1062 )
										{

										}
										else
										{
											mysql_free_result(res);
											break;
										}
									}*/
								}
							}
							else
							{
								ZzLOG(ERROR, "if ( getstr(row,5) != NULL && strlen(getstr(row,5)) > 0 )\n");
							}

						}
						mysql_free_result(res);
					}


				}
			//구매정보 가져오기
				memset (szQuery, 0x00, sizeof(szQuery));
				memset (szQuery2, 0x00, sizeof(szQuery2));
				sprintf(szQuery, " select "
				                " deal_no, cont_gu, id, "
				                " deal_date, deal_time, "
				                " '%s', sale_user, buy_user , "
				                " title, sect_code, "
				                " price_amt, sale_amt, comp_amt, "
				                " file_size, adult_yn "
				                " ,down_st_date " //20130410
								" from zangsi.T_DEAL_INFO "
								" where deal_no = %lu  ; /* cprdaem1001 */ "
								, sale_cd
								, deal_no);

				// 20140422 down_st_date = 2:모바일 구매 1:PC
				ZzLOG(ALWAY, "[%s]\n",szQuery);

				if (mysql_query(con, szQuery))
				{
					mysql_free_result(g_res);

					ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
					return -1;
				}

				if (!(res = mysql_store_result(con)))
				{
					mysql_free_result(g_res);
					ZzLOG(ERROR, "mysql_store_result [%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));

					return -1;
				}
				int nCount = mysql_num_rows(res);

				/*if (nCount <= 0)
			 	{

			 		ZzLOG(ERROR,"[%lu] 데이터가 없습니다. %s",deal_no,szQuery);
					mysql_free_result(res);

					memset(szQuery, 0x00, sizeof(szQuery));
					sprintf(szQuery, "update zangsi.T_DEAL_CPR  set proc_yn = 'F' where deal_no = %lu ", deal_no);
					//sprintf(szQuery, " delete from zangsi.T_DEAL_CPR where deal_no = %lu ", deal_no);
					if (mysql_query(con, szQuery))
					{
						mysql_free_result(g_res);
					    ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));

						return -1;
					}

				    continue;
				}*/

				row = mysql_fetch_row(res);


			/*
			zangsi.T_DEAL_CPR과 zangsi.T_DEAL_INFO의 정보와 zangsi_cpr.T_CPR_HASH_INFO의
			chi_id와 comp_cd를 zangsi_cpr.T_CPR_DEAL_INFO에 인서트
			*/

				memset(&deal_data,0x00,sizeof(DEALINFO));

				deal_data.deal_no = (unsigned long)getnum(row, 0);
				strcpy(deal_data.cont_gu, getstr(row, 1));
				deal_data.id = (unsigned long)getnum(row, 2);
				strcpy(deal_data.deal_date, getstr(row, 3));
				strcpy(deal_data.deal_time, getstr(row, 4));
				//strcpy(deal_data.sale_cd, getstr(row, 5));
			    strcpy(deal_data.sale_user, getstr(row, 6));
				strcpy(deal_data.buy_user, getstr(row, 7));
				AppendSpecialChar( getstr(row, 8) , '\\' , deal_data.title );
				strcpy(deal_data.sect_code, getstr(row, 9));
				deal_data.price_amt = getnum(row, 10);
				deal_data.sale_amt = getnum(row, 11);
				deal_data.file_size = getnum(row, 13);
				strcpy(deal_data.adult_yn, getstr(row, 14));
				strcpy(deal_data.down_st_date,getstr(row,15));//20130410
				mysql_free_result(res);



			/*
			cpr_amt 계산
			*/

			/*
			comp_cd를 읽어와 각각에 맞게 정산...
			*/



			//가격이 다른지 검사
			//T_DEAL_INFO 의 가격과 실제 row 데이터의 합산 가격을 비교

			//T_CPR_DEAL_INFO,T_CPR_DEAL_INFO_FILE insert


			//zangsi_cpr.T_CPR_HASH_INFO의 chi_id와 comp_cd 조회
			//sale_cd가 01이면 제휴 아이디
			//2008/10/22 - 정산비율을 T_CPR_HASH_INFO에서 조회

			memset(szQuery, 0x00, sizeof(szQuery));
			if( strcmp(deal_data.down_st_date,"1") == 0 ) //mobile  20130410
			{
				sprintf(szQuery, " SELECT a.chi_id, c.comp_cd, c.cpr_payment_rate, c.price_amt, c.seq_no, c.list_id, d.event_amt "
								" FROM zangsi_cpr.T_CPR_CONT_MAP_SUB a, zangsi_cpr.T_CPR_HASH_INFO b, zangsi_cpr.T_CPR_CONT_LIST c "
								" LEFT OUTER JOIN zangsi_cpr.T_CPR_EVENT_CONT_LIST d ON  c.list_id = d.list_id and d.use_yn = 'Y' "
								" WHERE a.id =  %lu  AND a.cont_gu = '%s' AND a.chi_id = b.chi_id AND b.list_id = c.list_id AND b.proc_stat = 'C' AND c.apply_yn = 'Y'  ; /* cprdaem1001 */ "
								 , deal_data.id, deal_data.cont_gu);

			}
			else
			{
				sprintf(szQuery, " SELECT a.chi_id, c.comp_cd, c.cpr_payment_rate, c.price_amt,c.seq_no,c.list_id, d.event_amt "
								" FROM zangsi_cpr.T_CPR_CONT_MAP_SUB a, zangsi_cpr.T_CPR_HASH_INFO b, zangsi_cpr.T_CPR_MOB_CONT_LIST c "
								" LEFT OUTER JOIN zangsi_cpr.T_CPR_EVENT_CONT_LIST d ON  c.list_id = d.list_id and d.use_yn = 'Y' "
								" WHERE a.id = %lu AND a.cont_gu = '%s' AND a.chi_id = b.chi_id AND b.list_id = c.list_id AND b.proc_stat ='C'  AND c.apply_yn = 'Y'  ; /* cprdaem1001 */ "
								 , deal_data.id, deal_data.cont_gu);
			}

			//printf("=== %s \n",szQuery);
			//ZzLOG(ALWAY, "[%s]\n",szQuery);

			ZzLOG(ALWAY,"########### st_date = %s [%s]\n",	deal_data.down_st_date,szQuery);//20130410
			if (mysql_query(cpr_con, szQuery))
			{

			    ZzLOG(ERROR, "cprdaem1001_deal_info: select error...\n");
				ZzLOG(ERROR, "cprdaem1001_deal_info: [%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
				// ZzLOG(ERROR, "%s\n\n",szQuery);
				mysql_free_result(g_res);

				return -1;
		    }
			if (!(cpr_res = mysql_store_result(cpr_con)))
			{

			    ZzLOG(ERROR, "cprdaem1001_deal_info: mysql_store_result error...\n");
				ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
				ZzLOG(ERROR, "%s\n\n",szQuery);
				mysql_free_result(g_res);

				return -1;
			}


		 	if ( mysql_num_rows(cpr_res) <= 0 )
		 	{

				mysql_free_result(cpr_res);

				memset(szQuery, 0x00, sizeof(szQuery));
				sprintf(szQuery, " select 0, comp_cd , 0, %.0f ,0 ,0 "
								 " from zangsi_cpr.T_CPR_USER_INFO   "
								 " where user_id = '%s'   ; /* cprdaem1001 */ "
								 , deal_data.price_amt, deal_data.sale_user);

				if (mysql_query(cpr_con, szQuery))
				{
					ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));
					mysql_free_result(g_res);
					return -1;
			    }
			    if (!(cpr_res = mysql_store_result(cpr_con)))
			    {
					ZzLOG(ERROR, "mysql_store_result [%s][%d](%s)\n",szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));
					mysql_free_result(g_res);
					return -1;
			    }
			 	if ( mysql_num_rows(cpr_res) <= 0 )
			 	{
					printf("맵핑 데이터가 없습니다------------------\n");
			 		ZzLOG(ERROR, "맵핑 데이터가 없습니다.[%s][%d](%s)\n",szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));
			 		memset(szQuery, 0x00, sizeof(szQuery));
					//sprintf(szQuery, " delete from zangsi.T_DEAL_CPR where deal_no = %lu ", deal_data.deal_no);
					sprintf(szQuery, "update zangsi.T_DEAL_CPR  set proc_yn = 'G' where deal_no = %lu ", deal_data.deal_no);
					//if (mysql_query(con, szQuery))
					//{
					//	mysql_free_result(g_res);
					  //  ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
						//return -1;
					//}

					continue;
			 	}
			}


			while(cpr_row = mysql_fetch_row(cpr_res))
			{

				cpr_amt =0;
				comp_amt = 0;
				price_amt = 0;
				event_amt = 0;
				cp_cpr_amt = 0;
				cp_comp_amt = 0;
				cm_cpr_amt = 0;
				cm_comp_amt = 0;

				event_comp_amt = 0;
				event_cpr_amt = 0;
				comp_pc_event_amt=0;
				comp_mobile_event_amt=0;

				chi_id = 0;
				cpr_payment_rate = 0;
				list_seq_no =0;
				list_id =0;
				memset(comp_cd, 0x00, sizeof(comp_cd));

				chi_id = (unsigned long)getnum(cpr_row, 0);
				strcpy(comp_cd, getstr(cpr_row, 1));
				cpr_payment_rate = atof(getstr(cpr_row, 2));
				price_amt = getnum(cpr_row, 3);
				list_seq_no = (unsigned long)getnum(cpr_row,4);
				list_id = (unsigned long)getnum(cpr_row,5);
				event_amt = getnum(cpr_row, 6);
				comp_pc_event_amt= getnum(cpr_row, 7);
				comp_mobile_event_amt= getnum(cpr_row, 8);

				sum_event_amt = sum_event_amt + event_amt;
				sum_price_amt = sum_price_amt + price_amt;

				sum_comp_pc_event_amt = sum_comp_pc_event_amt + comp_pc_event_amt;
				sum_comp_mobile_event_amt = sum_comp_mobile_event_amt + comp_mobile_event_amt;

				if(cpr_payment_rate > 0)
				{
					cpr_payment_rate = cpr_payment_rate * 0.01;
				}
				else
				{
					MYSQL_RES *l_res;
					MYSQL_ROW  l_row;

					//제휴사 요율
					memset (szQuery, 0x00, sizeof(szQuery));
					sprintf(szQuery, " select minor_name from zangsi_cpr.T_MINOR_CODE where major_code = '82' and minor_code = '%s'  ; /* cprdaem1001 */ ", comp_cd);

					if (mysql_query(cpr_con, szQuery))
					{
					    ZzLOG(ERROR, "cprdaem1001_deal_info: select T_MINOR_CODE error...\n");
						ZzLOG(ERROR, "cprdaem1001_deal_info: [%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
						ZzLOG(ERROR, "%s\n\n",szQuery);
						mysql_free_result(cpr_res);
						mysql_free_result(g_res);
						return -1;
					}
					if (!(l_res = mysql_store_result(cpr_con)))
					{
						ZzLOG(ERROR, "cprdaem1001_deal_info: mysql_store_result T_MINOR_CODE error...\n");
						ZzLOG(ERROR, "cprdaem1001_deal_info: [%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
						ZzLOG(ERROR, "%s\n\n",szQuery);
						mysql_free_result(cpr_res);
						mysql_free_result(g_res);
						return -1;
					}
					if ( mysql_num_rows(l_res) <= 0 )
					{
					    mysql_free_result(l_res);
					    mysql_free_result(cpr_res);
						mysql_free_result(g_res);
						return -1;
					}

					l_row = mysql_fetch_row(l_res);

					char szRate[2];
					memset(szRate, 0x00, sizeof(szRate));

					strcpy(szRate, getstr(l_row,0));
					cpr_payment_rate = atof(szRate);

					cpr_payment_rate = cpr_payment_rate * 0.01;

					//ZzLOG(ALWAY,"cpr_payment_rate [ %.0f ] \n",cpr_payment_rate);
					mysql_free_result(l_res);


				}

				// price_amt - sale_amt - cpr_amt = comp_amt
				// price_amt * cpr_payment_rate = cpr_amt
				// 업로더 수익 빼야하는데. 안빼고 계산중이네.... event_amt
				printf("nDealFileCnt = %d\n",nDealFileCnt);
				//일반
				if(strcmp(sale_cd, "00") == 0)
				{
					cpr_amt  = price_amt * cpr_payment_rate;
					sum_cpr_amt = sum_cpr_amt + cpr_amt;

					comp_amt = (price_amt - cpr_amt);// - (price_amt * 0.05);
					sum_comp_amt = sum_comp_amt + comp_amt;

					// 파일기준 이벤트 컨텐츠
					event_cpr_amt  = event_amt * cpr_payment_rate;
					event_sum_cpr_amt  = event_sum_cpr_amt + event_cpr_amt;

					event_comp_amt = (event_amt - event_cpr_amt); //  - (event_amt * 0.05);
					event_sum_comp_amt = event_sum_comp_amt + event_comp_amt;

					// 회사 기준 PC 이벤트 지원
					cp_cpr_amt  = comp_pc_event_amt * cpr_payment_rate;
					cp_sum_cpr_amt = cp_sum_cpr_amt + cp_cpr_amt;

					cp_comp_amt = (comp_pc_event_amt - cp_cpr_amt);
					cp_sum_comp_amt = cp_sum_comp_amt + cp_comp_amt;

					// 회사 기준 MO 이벤트 지원
					cm_cpr_amt  = comp_mobile_event_amt * cpr_payment_rate;
					cm_sum_cpr_amt = cm_sum_cpr_amt + cm_cpr_amt;

					cm_comp_amt = (comp_mobile_event_amt - cp_cpr_amt);
					cm_sum_comp_amt = cm_sum_comp_amt + cm_comp_amt;

				}
				else
				{
					//제휴아이디일 경우 소수점이 나오면 제휴사는 절사.
					double dSubCprAmt  = price_amt * cpr_payment_rate;
					cpr_amt = floor(dSubCprAmt);
					sum_cpr_amt = sum_cpr_amt + cpr_amt;

					comp_amt = price_amt - cpr_amt;
					sum_comp_amt = sum_comp_amt + comp_amt;

					// 파일기준 이벤트 컨텐츠
					double event_dSubCprAmt  = event_amt * cpr_payment_rate;
					event_cpr_amt = floor( event_dSubCprAmt);
					event_sum_cpr_amt =  event_sum_cpr_amt +  event_cpr_amt;

					event_comp_amt =  event_amt - event_cpr_amt;
					event_sum_comp_amt =  event_sum_comp_amt +  event_comp_amt;

					//
					double cp_event_dSubCprAmt  = comp_pc_event_amt * cpr_payment_rate;
					cp_cpr_amt = floor( cp_event_dSubCprAmt);
					cp_sum_cpr_amt = cp_sum_cpr_amt + cp_cpr_amt;

					cp_comp_amt = (comp_pc_event_amt - cp_cpr_amt);
					cp_sum_comp_amt = cp_sum_comp_amt + cp_comp_amt;

					//
					double cm_event_dSubCprAmt  = comp_mobile_event_amt * cpr_payment_rate;
					cm_cpr_amt = floor( cm_event_dSubCprAmt );
					cm_sum_cpr_amt = cm_sum_cpr_amt + cm_cpr_amt;

					cm_comp_amt = (comp_mobile_event_amt - cp_cpr_amt);
					cm_sum_comp_amt = cm_sum_comp_amt + cm_comp_amt;

				}

				deal_file[nDealFileCnt].deal_no = deal_data.deal_no;
				deal_file[nDealFileCnt].id = deal_data.id;
				deal_file[nDealFileCnt].chi_id = chi_id;
				deal_file[nDealFileCnt].list_id = list_id ;
				deal_file[nDealFileCnt].list_seq_no = list_seq_no;
				deal_file[nDealFileCnt].list_id = list_id ;

				nDealFileCnt++;


			}

			mysql_free_result(cpr_res);



			//업로더 수익
			if(sum_comp_amt >= 0)
				deal_data.comp_amt = sum_comp_amt - deal_data.sale_amt ;


			// 2014.04.24 추가 : 이벤트 가격 비교
			// deal_data.price_amt 결재 금액
			// sum_price_amt 컨텐츠 금액

			if(sum_price_amt == deal_data.price_amt)
			{	// 일반 컨텐츠 등록가격 , 결재 가격 비교
				ZzLOG(ALWAY, "정상 OK = deal_data.deal_no [ %lu ]\n",deal_data.deal_no);
				strcpy(proc_yn, "N"); // 정상

			}
			else
			{	// 가격이 틀리므로 이벤트 컨텐츠인가 확인.
				if(strcmp(deal_data.down_st_date,"1")==0) // PC 가격
				{
					if(sum_event_amt == deal_data.price_amt)
					{
						deal_data.comp_amt = event_sum_comp_amt - deal_data.sale_amt ;
						sum_cpr_amt = event_sum_cpr_amt;
						strcpy(proc_yn, "N"); // 정상
					}
					else
					{
						if(sum_comp_pc_event_amt == deal_data.price_amt)
						{
							deal_data.comp_amt = cp_sum_comp_amt - deal_data.sale_amt ;
							sum_cpr_amt = cp_sum_cpr_amt;
							strcpy(proc_yn, "N"); // 정상
							printf("\n [COMP EVENT PC] Price");
						}
						else
						{
							strcpy(proc_yn, "R"); // 보류
						}
					}
					printf("\nEVENT PC = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);

				}
				else if(strcmp(deal_data.down_st_date,"2")==0) // 모바일 가격
				{
					if(sum_event_amt == deal_data.price_amt)
					{
						deal_data.comp_amt = event_sum_comp_amt - deal_data.sale_amt ;
						sum_cpr_amt = event_sum_cpr_amt;
						strcpy(proc_yn, "N"); // 정상
					}
					else
					{
						if(sum_comp_mobile_event_amt == deal_data.price_amt)
						{
							deal_data.comp_amt = cm_sum_comp_amt - deal_data.sale_amt ;
							sum_cpr_amt = cm_sum_cpr_amt;
							strcpy(proc_yn, "N"); // 정상
							printf("\n [COMP EVENT Mobile] Price");
						}
						else
						{
							strcpy(proc_yn, "R"); // 보류
						}
					}

					ZzLOG(ALWAY, "\nEVENT Mob = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);

				}
				else
				{
					ZzLOG(ALWAY, "deal_data.down_st_date ERROR [ %s ]\n",deal_data.down_st_date);
					printf ("deal_data.down_st_date ERROR [ %s ]\n",deal_data.down_st_date);
					strcpy(proc_yn, "R"); // 보류
					printf("\nETC = %s\n",proc_yn);
				}
			}


			//cpr tran begin
			if (tran_begin(cpr_real_con)!=0)
			{
				ZzLOG(ERROR, "tran_begin [%d](%s)\n",mysql_errno(cpr_real_con), mysql_error(cpr_real_con));
				return -1;
			}


			if(strcmp(deal_data.sale_user , "cjdrama") == 0)
			{
				ZzLOG(ALWAY,"====== sDealInfo.szSaleUser = %s ,proc_yn = 'N' \n",deal_data.sale_user);
				strcpy(proc_yn, "N"); // 정상
			}


			memset(szQuery, 0x00, sizeof(szQuery));
			sprintf(szQuery, " update zangsi_cpr.T_CPR_DEAL_INFO "
							 " set proc_yn='%s', price_amt=%.0f, sale_amt=%.1f, comp_amt=%.1f, cpr_amt=%.1f "
							 " where deal_no=%lu and id=%d and comp_cd=%s and chi_id =%lu  ; /* cprdaem1001 */ "
 							 , proc_yn, deal_data.price_amt, deal_data.sale_amt, deal_data.comp_amt, sum_cpr_amt
							 , deal_data.deal_no,  deal_data.id, comp_cd, chi_id);

			//printf("결재 정보 [ %s ] \n",szQuery);
			//ZzLOG(ALWAY, "[%lu]\n",deal_data.deal_no);
			ZzLOG(ALWAY, "[%s]\n",szQuery);

			if (mysql_query(cpr_real_con, szQuery))
			{
				ZzLOG(ALWAY, "error tran_rollback\n",szQuery);
				mysql_free_result(g_res);
			    ZzLOG(ALWAY, "error [%s][%d](%s)\n",szQuery,mysql_errno(cpr_real_con), mysql_error(cpr_real_con));
			    tran_rollback(cpr_real_con);
				tran_end(cpr_real_con);
				return -1;
		    }
			tran_end(cpr_real_con);

			dCount	++;
		}

		mysql_free_result(g_res);

	}

	return 0;
}


/*****************************************************************************
* 프로그램 시작루틴
* 전역변수 초기화 및 데이타베이스 연결
* (I) void
* (R) int : 정상(0)/오류(-1)
*****************************************************************************/
int cprdaem1001_process_init_temp(int argc, char **argv)
{
	char stemp[128];
    /*
    ** 전역변수 초기화
    */
    ZzInitGlobalVariable2("cprdaem1001_temp", "/logs/daemon");



    // 파라미터 값 설정 및 초기화
	if(argc == 3)
    {
		gl_start_no = atoi(argv[1]);
		printf ("%lu\n",gl_start_no);
		gl_stop_no = atoi(argv[2]);
		printf ("%lu\n",gl_stop_no);
		gnType = NUMBER;
	}
	else if(argc == 2)
    {
		/* 처리일자 */
		memset(gst_date, 0x00, sizeof(gst_date));
		strcpy(gst_date, "00000000");
		gnType = NORMAL;
	}
	else
	{
    	goto arg_error;
	}


	//--------------------------------------------------------------------------
	// DB 연결
	//--------------------------------------------------------------------------

    return (0);

arg_error:
    ZzLOG(ERROR, "usage : %s YYYYMMDD\n", argv[0]);
    ZzLOG(ERROR, "        YYYYMMDD : 처리일자(00000000:시스템일자)\n");

    ZzPRT(ERROR, "usage : %s 00000000\n", argv[0]);
    return -1;
}



