int cprdaem1001_process()
{
	MYSQL_RES *res;
	MYSQL_ROW  row;

	if (!(con=db_connect_to_main("zangsi")))
	{
		ZzLOG(ERROR, "zangsi DB에 접속하지 못 하였습니다...\n");
	   	return(-10);
	}

	if (!(cpr_con=db_connect_cprbckdb("zangsi_cpr")))
	{
		ZzLOG(ERROR, "zangsi_cpr bckDB에 접속하지 못 하였습니다...\n");
		db_disconnect(con);
	   	return(-10);
	}
	if (!(cpr_real_con=db_connect_cprdb("zangsi_cpr")))
	{
		ZzLOG(ERROR, "zangsi_cpr DB에 접속하지 못 하였습니다...\n");
		db_disconnect(con);
		db_disconnect(cpr_con);
	   	return(-10);
	}

	char szQuery[1000];	memset(szQuery, 0x00, sizeof(szQuery));

	// 처리일자가 "00000000"일때는 시스템일자 -1을 한다.
	if (strcmp(gst_date, "00000000") == 0)
	{
		gbIsUserDate = false;
		strcpy(szQuery, "SELECT date_format(now(),'%Y%m%d') , date_format(now(),'%H%i%s') ; /* cprdaem1001 */");

		if (mysql_query(con, szQuery))
		{
			ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
			return -1;
		}

		if (!(res = mysql_store_result(con)))
		{
		    ZzLOG(ERROR, "mysql_store_result [%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
			return -1;
		}
	 	if (mysql_num_rows(res)==0)
	 	{
	 		ZzLOG(ERROR, "mysql_num_rows[0] [%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
			return -1;
		}
		row = mysql_fetch_row(res);
		memset(gst_date, 0x00, sizeof(gst_date));
		strcpy(gst_date,   getstr(row, 0));
		strcpy(gst_time,   getstr(row, 1));
		mysql_free_result(res);
	}
	else
	{
		gbIsUserDate=true;
	}

	bool bIsSuccess = true;
	int nResult = cprdaem1001_process_db();

	if( nResult !=0)
	{
		bIsSuccess = false;
	}

	if(nResult == -2)
	{
		return -2 ; // exit(1);
	}

	if(bIsSuccess)
		return 0;
	else
		return -1;
}


int cprdaem1001_sendpay(unsigned long ulID, unsigned long ulDealNo, char* pBuyUser, char* pDealDateTime) // 사용 안하는 함수 20150713
{
	MYSQL_RES *res=NULL;
	MYSQL_ROW  row=NULL;
	char szQuery[2048];	memset(szQuery, 0x00, sizeof(szQuery));
	char szConnIP[16];	memset(szConnIP, 0x00, sizeof(szConnIP));

	strcpy(szConnIP , "127.0.0.1");
	sprintf(szQuery , " select if(b.video_hash is null or length(b.video_hash) = 0, concat( upper(md5(b.default_hash)),'2',b.file_size ) ,  b.video_hash) ,b.file_name , b.file_size  from zangsi.T_CONTENTS_FILELIST_SUB b"
					" where b.id = %lu and ( ( b.file_type is not null and length(b.file_type) > 0 ) or  (b.video_hash is not null and length(b.video_hash) > 0) )  ; /* cprdaem1001 */ " , ulID );

	if (mysql_query(con, szQuery))
	{
		ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
		return -1;
	}

	if (!(res = mysql_store_result(con)))
	{
		ZzLOG(ERROR, "mysql_store_result [%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
		return -1;
	}

	char szHash[100];memset(szHash,0x00,sizeof(szHash));

	while(row = mysql_fetch_row(res))
	{
		strcpy(szHash,getstr(row, 0));
		char szEmpty[2048];	memset(szEmpty,0x00,sizeof(szEmpty));
		sprintf( szEmpty,"/home/ezwon/wedisk_linux_cmc_down_pay/send_hash/send_hash.bin \"%s\" \"%s\" \"%s\" \"%s\" \"%s\" ",szHash,pBuyUser, "Y",szConnIP ,pDealDateTime);
		system(	szEmpty );
		//ZzLOG(ALWAY, "%s\n", szEmpty);
	}
	mysql_free_result(res);
	return 0;
}
int GetTitleAndFileSize(unsigned long ulID, char* pTitle, double dFileSize)
{
	MYSQL_RES *res1;
	MYSQL_ROW  row1;

	char szQuery[10000];
	memset(szQuery, 0x00, sizeof(szQuery));

	char szDefaultHash[35];
	memset(szDefaultHash, 0x00, sizeof(szDefaultHash));

	sprintf(szQuery, "select default_hash, file_size from zangsi.T_CONTENTS_FILELIST_SUB where id = %lu order by file_size desc limit 1  ; /* cprdaem1001 */ ", ulID);

	if (mysql_query(con, szQuery))
	{
	    ZzLOG(ERROR, "GetTitleAndFileSize: mysql_query error...\n");
		ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(con), mysql_error(con));
		ZzLOG(ERROR, "(%s)\n", szQuery);
		return -1;
	}

	if (!(res1 = mysql_store_result(con)))
	{
	    ZzLOG(ERROR, "GetTitleAndFileSize: mysql_store_result error...\n");
		ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(con), mysql_error(con));
		return -1;
	}
	int nCount = mysql_num_rows(res1);
	if (nCount <= 0)
 	{
		mysql_free_result(res1);
	    strcpy(pTitle, " ");
	    dFileSize = 0;
	    return 0;
	}

	row1 = mysql_fetch_row(res1);

	strcpy(szDefaultHash, getstr(row1,0));

	dFileSize = getnum(row1,1);

	mysql_free_result(res1);


	memset(szQuery, 0x00, sizeof(szQuery));
	sprintf(szQuery, " select a.title, sum(b.file_size) from zangsi_cpr.T_CPR_HASH_INFO a, zangsi_cpr.T_CPR_HASH_FILE b "
					 " where a.chi_id = b.chi_id and b.default_hash = '%s' and b.file_size = %15.0f "
					 " group by a.chi_id  ; /* cprdaem1001 */ "
					, szDefaultHash, dFileSize);

	if (mysql_query(cpr_con, szQuery))
	{
	    ZzLOG(ERROR, "GetTitleAndFileSize: mysql_query error...\n");
		ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
		ZzLOG(ERROR, "(%s)\n", szQuery);
		return -1;
	}

	if (!(res1 = mysql_store_result(cpr_con)))
	{
	    ZzLOG(ERROR, "GetTitleAndFileSize: mysql_store_result error...\n");
		ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
		return -1;
	}
	nCount = mysql_num_rows(res1);
	if (nCount <= 0)
 	{
		mysql_free_result(res1);
	    strcpy(pTitle, " ");
	    dFileSize = 0;
	    return 0;
	}

	row1 = mysql_fetch_row(res1);

	strcpy(pTitle, getstr(row1,0));

	dFileSize = getnum(row1,1);

	mysql_free_result(res1);

	return 0;
}
char* AppendSpecialChar(char* strSrcString, char cReplace,char* pResult)
{
	char strResult[13000];
	memset(strResult,0x00,sizeof(strResult));
	int cTemp;
	int nSpecialCount=0;
	int nFileLen = strlen(strSrcString);
	int cOldTemp ;
	int cNextTemp=0;

	for(unsigned long i=0; i<nFileLen ; i++)
	{
		if( i > 0 )
		{
			cOldTemp = strSrcString[i-1];
		}
		cTemp = strSrcString[i];

		//if( cTemp == '\'' && cOldTemp != '\\' )
		if( cTemp == '\'' )
		{
			strResult[nSpecialCount] = (char)cReplace;
			nSpecialCount++;
			strResult[nSpecialCount] = (char)cTemp;
		}
		else if( cTemp == '\\' )
		{
			strResult[nSpecialCount] = (char)cReplace;
			nSpecialCount++;
			strResult[nSpecialCount] = (char)cTemp;
		}
		else
		{
			if(cTemp<0)//한글 (is korean)
			{
				char* pHan = &strSrcString[i];
				memcpy(&strResult[nSpecialCount] ,pHan,2);
				nSpecialCount++;
				i=i+1;
			}
			else
			{
				strResult[nSpecialCount] = (char)cTemp;
			}
		}
		nSpecialCount++;
	}
	strcpy(pResult,strResult);
	return pResult;
}

/*****************************************************************************
* DB 에서 시간 알아오기
* 전역변수 초기화 및 데이타베이스 연결
* (I)
* (R) int : 정상(0)/오류(-1)
*****************************************************************************/
int cprdaem1001_gettime(char* pCurTime)
{
	MYSQL_RES *res;
	MYSQL_ROW  row;

	char szQuery[1000];
	strcpy(szQuery, "SELECT date_format(now(),'%H%i%s')  ; /* cprdaem1001 */ ");


	if (mysql_query(con, szQuery))
	{
	    ZzLOG(ERROR, "cprdaem1001_gettime: mysql_query error...\n");
		ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(con), mysql_error(con));
		ZzLOG(ERROR, "(%s)\n", szQuery);
		return -1;
	}

	if (!(res = mysql_store_result(con)))
	{
	    ZzLOG(ERROR, "cprdaem1001_gettime: mysql_store_result error...\n");
		ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(con), mysql_error(con));
		return -1;
	}
 	if (mysql_num_rows(res)==0)
 	{
	    ZzLOG(ERROR, "cprdaem1001_gettime: mysql_num_rows error...\n");
		ZzLOG(ERROR, "[%d](%s)\n",mysql_errno(con), mysql_error(con));
		return -1;
	}
	row = mysql_fetch_row(res);
	strcpy(pCurTime,   getstr(row, 0));
	mysql_free_result(res);

	return 0;
}

/*****************************************************************************
* 프로그램 시작루틴
* 전역변수 초기화 및 데이타베이스 연결
* (I) void
* (R) int : 정상(0)/오류(-1)
*****************************************************************************/
int cprdaem1001_process_init(int argc, char **argv)
{
	char stemp[128];
    /*
    ** 전역변수 초기화
    */
    ZzInitGlobalVariable2("cprdaem1001", "/logs/daemon");



    // 파라미터 값 설정 및 초기화
	if(argc == 3)
    {
		gl_start_no = atoi(argv[1]);
		gl_stop_no = atoi(argv[2]);
		gnType = NUMBER;
	}
	else if(argc == 2)
    {
		/* 처리일자 */
		memset(gst_date, 0x00, sizeof(gst_date));
		strcpy(gst_date, "00000000");
		gnType = NORMAL;
	}
	else
	{
    	goto arg_error;
	}


	//--------------------------------------------------------------------------
	// DB 연결
	//--------------------------------------------------------------------------

    return (0);

arg_error:
    ZzLOG(ERROR, "usage : %s YYYYMMDD\n", argv[0]);
    ZzLOG(ERROR, "        YYYYMMDD : 처리일자(00000000:시스템일자)\n");

    ZzPRT(ERROR, "usage : %s 00000000\n", argv[0]);
    return -1;
}

/***************************************************************************
* 프로그램 종료루틴
* 데이터베이스 종료 및 처리결과를 로그파일에 정의
* (I) void
* (R) int : 정상(0)/오류(-1)
****************************************************************************/
int cprdaem1001_process_term()
{
    // DB close
	ZzLOG(ERROR, "cprdaem1001_process_term\n");
	db_disconnect(con);
	db_disconnect(cpr_con);
	db_disconnect(cpr_real_con);
	con =NULL;
	cpr_con =NULL;
	cpr_real_con =NULL;

    return (0);
}

/*****************************************************************************
* 프로그램 시그널 처리
* (I) void
* (R) void
*****************************************************************************/
void  cprdaem1001_signal(int nSignal)
{
    cprdaem1001_process_term();
}

//******************************************************************************
//* cprdaem1001 db 처리로직
//******************************************************************************
int cprdaem1001_process_db()
{
	MYSQL_RES *g_res;
	MYSQL_ROW  g_row;

	/*
	zangis.T_DEAL_CPR에서 deal_no를 zangsi.T_DEAL_INFO와 조인하여 데이터를 가져옴.
	가져온 데이터와 zangsi_cpr.T_CPR_HASH_INFO의 chi_id와 comp_cd를 읽어와 zangsi_cpr.T_CPR_DEAL_INFO에 저장
	*/
	char szQuery[2048];		// query string
	char szQuery2[1024];		// query string
	char cont_type[6]; 	//  zangsi_cpr.T_CPR_DEAL_INFO_FILE 의 cont_type 가져오기

	int  ret;

	double dCount = 0;
	int nRowCnt = 0;

	//data set
	unsigned long deal_no = 0;
	//unsigned long id = 0;
	char sale_cd[4];
	char proc_yn[4];
	//data set

	//data set
	double comp_amt = 0;
	double sum_comp_amt = 0;
	double cpr_amt = 0;
	double sum_cpr_amt = 0;

	// 파일 기준 이벤트 가격
	double event_comp_amt = 0;
	double event_sum_comp_amt = 0;
	double event_cpr_amt = 0;
	double event_sum_cpr_amt = 0;

	// 회사 코드 기준 이벤트 가격
	double cp_comp_amt = 0;
	double cp_sum_comp_amt = 0;
	double cp_cpr_amt = 0;
	double cp_sum_cpr_amt = 0;

	// 회사 코드 기준 이벤트 가격
	double cm_comp_amt = 0;
	double cm_sum_comp_amt = 0;
	double cm_cpr_amt = 0;
	double cm_sum_cpr_amt = 0;

	//
	double event_amt =0;
	double sum_event_amt =0;
	double price_amt =0;
	double sum_price_amt = 0;
	double comp_pc_event_amt=0;
	double sum_comp_pc_event_amt=0;
	double comp_mobile_event_amt=0;
	double sum_comp_mobile_event_amt=0;

	unsigned long chi_id = 0;
	double cpr_payment_rate = 0;
	char comp_cd[7+1];
	long list_seq_no =0;
	long list_id =0;

	//data set

	MYSQL_RES *cpr_res = NULL;
	MYSQL_RES *cpr_res2 = NULL;
	MYSQL_ROW  cpr_row;

	MYSQL_RES *res = NULL;
	MYSQL_ROW  row;

	DEALINFO deal_data;
	memset(&deal_data,0x00,sizeof(DEALINFO));
	DEALINFO_FILE deal_file[1024];
	memset(deal_file,0x00,sizeof(DEALINFO_FILE)*1024);
	int nDealFileCnt = 0;

	//신규 로직
	while(1)
	{

		//100개씩 구매정보 읽어 들이기
		memset(&deal_data,0x00,sizeof(DEALINFO));
		memset(deal_file,0x00,sizeof(DEALINFO_FILE)*1024);
		nDealFileCnt =0;
		nRowCnt =0;
		memset (szQuery, 0x00, sizeof(szQuery));
		sprintf(szQuery, " select deal_no, id, sale_cd, proc_yn from zangsi.T_DEAL_CPR where proc_yn  in( 'N','B') and deal_no > %lu order by deal_no limit 100  ; /* cprdaem1001 */ ",deal_no);

		ZzLOG(ALWAY, "[%s]\n",szQuery);

		if (mysql_query(con, szQuery))
		{
		    ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));	return -1;
		}
		if (!(g_res = mysql_store_result(con)))
		{
			ZzLOG(ERROR, "mysql_store_result [%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));	return -1;
		}
		nRowCnt = mysql_num_rows(g_res);

		if (mysql_num_rows(g_res) <= 0)
	 	{
			mysql_free_result(g_res);
			sleep(3);
		    return 0;
		}

		while((g_row = mysql_fetch_row(g_res)))
		{
			//이미 등록되어있는지 검사
				deal_no = 0;
				nDealFileCnt =0;
				memset(deal_file,0x00,sizeof(DEALINFO_FILE)*1024);
				memset(sale_cd,0x00,sizeof(sale_cd));
				memset(proc_yn,0x00,sizeof(proc_yn));
				nDealFileCnt = 0;

				event_sum_comp_amt = 0;
				event_sum_cpr_amt = 0;

				sum_price_amt=0;
				sum_event_amt = 0;
				sum_comp_amt = 0;
				sum_cpr_amt = 0;

				deal_no =(unsigned long)getnum(g_row,0);
				//id =(unsigned long)getnum(g_row,1);
				strcpy(sale_cd,getstr(g_row,2));
				strcpy(proc_yn,getstr(g_row,3));

				//read cpr deal
				memset(szQuery, 0x00, sizeof(szQuery));
				sprintf(szQuery, " select deal_no from zangsi_cpr.T_CPR_DEAL_INFO where deal_no = %lu  ; /* cprdaem1001 */ ", deal_no);
				ZzLOG(ALWAY, "[%s]\n",szQuery);

				if (mysql_query(cpr_con, szQuery))
				{
					mysql_free_result(g_res);
					ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery, mysql_errno(cpr_con), mysql_error(cpr_con));
					return -1;
			    }
				if (!(cpr_res = mysql_store_result(cpr_con)))
				{
					mysql_free_result(g_res);
					ZzLOG(ERROR, "mysql_store_result [%s][%d](%s)\n",szQuery,mysql_errno(cpr_con), mysql_error(cpr_con));
					return -1;
				}
			 	if ( mysql_num_rows(cpr_res) > 0 )
			 	{
			 		//이미 등록되어 있음.
					mysql_free_result(cpr_res);

					memset(szQuery, 0x00, sizeof(szQuery));
					sprintf(szQuery, " delete from zangsi.T_DEAL_CPR where deal_no = %lu  ; /* cprdaem1001 */ ", deal_no);
					
					ZzLOG(ALWAY, "[%s]\n",szQuery);

					if (mysql_query(con, szQuery))
					{
						mysql_free_result(g_res);
					    ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
						return -1;
					}
