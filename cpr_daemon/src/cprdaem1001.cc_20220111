				comp_amt = 0;
				event_cpr_amt = 0;
				event_comp_amt = 0;
				cp_cpr_amt = 0;
				cp_comp_amt = 0;
				cm_cpr_amt = 0;
				cm_comp_amt = 0;

				// 판매금액
				price_amt = 0;
				event_amt = 0;
				comp_pc_event_amt=0;
				comp_mobile_event_amt=0;

				chi_id = 0;
				cpr_payment_rate = 0;
				list_seq_no =0;
				list_id =0;
				memset(comp_cd, 0x00, sizeof(comp_cd));
				memset(cont_type, 0x00, sizeof(cont_type));

