					//제휴사 요율
					memset (szQuery, 0x00, sizeof(szQuery));
					sprintf(szQuery, " select minor_name from zangsi_cpr.T_MINOR_CODE where major_code = '82' and minor_code = '%s'  ; /* cprdaem1001 */ ", comp_cd);
					ZzLOG(ALWAY, "6. szQuery = %s \n",szQuery);

					if (mysql_query(cpr_con, szQuery))
					{
					    ZzLOG(ERROR, "cprdaem1001_deal_info: select T_MINOR_CODE error...\n");
						ZzLOG(ERROR, "cprdaem1001_deal_info: [%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
						ZzLOG(ERROR, "%s\n\n",szQuery);
						mysql_free_result(cpr_res);
						mysql_free_result(g_res);
						return -1;
					}
					if (!(l_res = mysql_store_result(cpr_con)))
					{
						ZzLOG(ERROR, "cprdaem1001_deal_info: mysql_store_result T_MINOR_CODE error...\n");
						ZzLOG(ERROR, "cprdaem1001_deal_info: [%d](%s)\n",mysql_errno(cpr_con), mysql_error(cpr_con));
						ZzLOG(ERROR, "%s\n\n",szQuery);
						mysql_free_result(cpr_res);
						mysql_free_result(g_res);
						return -1;
					}
					if ( mysql_num_rows(l_res) <= 0 )
					{

					    mysql_free_result(l_res);
					    mysql_free_result(cpr_res);
						mysql_free_result(g_res);
						return -1;
					}

					l_row = mysql_fetch_row(l_res);

					char szRate[2];
					memset(szRate, 0x00, sizeof(szRate));

					strcpy(szRate, getstr(l_row,0));
					cpr_payment_rate = atof(szRate);

					cpr_payment_rate = cpr_payment_rate * 0.01;

					//ZzLOG(ALWAY,"cpr_payment_rate [ %.0f ] \n",cpr_payment_rate);
					mysql_free_result(l_res);


				}

				// price_amt - sale_amt - cpr_amt = comp_amt
				// price_amt * cpr_payment_rate = cpr_amt
				// 업로더 수익 빼야하는데. 안빼고 계산중이네.... event_amt
				printf("nDealFileCnt = %d\n",nDealFileCnt);
				//일반
				if(strcmp(sale_cd, "00") == 0)
				{
					cpr_amt  = price_amt * cpr_payment_rate;
					sum_cpr_amt = sum_cpr_amt + cpr_amt;

					comp_amt = (price_amt - cpr_amt);// - (price_amt * 0.05);
					sum_comp_amt = sum_comp_amt + comp_amt;

					//
					event_cpr_amt  = event_amt * cpr_payment_rate;
					event_sum_cpr_amt  = event_sum_cpr_amt + event_cpr_amt;

					event_comp_amt = (event_amt - event_cpr_amt); //  - (event_amt * 0.05);
					event_sum_comp_amt = event_sum_comp_amt + event_comp_amt;

					// 회사 기준 PC 이벤트 지원
					cp_cpr_amt  = comp_pc_event_amt * cpr_payment_rate;
					cp_sum_cpr_amt = cp_sum_cpr_amt + cp_cpr_amt;

					cp_comp_amt = (comp_pc_event_amt - cp_cpr_amt);
					cp_sum_comp_amt = cp_sum_comp_amt + cp_comp_amt;

					// 회사 기준 MO 이벤트 지원
					cm_cpr_amt  = comp_mobile_event_amt * cpr_payment_rate;
					cm_sum_cpr_amt = cm_sum_cpr_amt + cm_cpr_amt;

					cm_comp_amt = (comp_mobile_event_amt - cp_cpr_amt);
					cm_sum_comp_amt = cm_sum_comp_amt + cm_comp_amt;

				}
				else
				{
					//제휴아이디일 경우 소수점이 나오면 제휴사는 절사.

					double dSubCprAmt  = price_amt * cpr_payment_rate;
					cpr_amt = floor(dSubCprAmt);
					sum_cpr_amt = sum_cpr_amt + cpr_amt;

					comp_amt = price_amt - cpr_amt;
					sum_comp_amt = sum_comp_amt + comp_amt;

										//
					double event_dSubCprAmt  = event_amt * cpr_payment_rate;
					event_cpr_amt = floor( event_dSubCprAmt);
					event_sum_cpr_amt =  event_sum_cpr_amt +  event_cpr_amt;

					event_comp_amt =  event_amt - event_cpr_amt;
					event_sum_comp_amt =  event_sum_comp_amt +  event_comp_amt;

					//
					double cp_event_dSubCprAmt  = comp_pc_event_amt * cpr_payment_rate;
					cp_cpr_amt = floor( cp_event_dSubCprAmt);
					cp_sum_cpr_amt = cp_sum_cpr_amt + cp_cpr_amt;

					cp_comp_amt = (comp_pc_event_amt - cp_cpr_amt);
					cp_sum_comp_amt = cp_sum_comp_amt + cp_comp_amt;

					//
					double cm_event_dSubCprAmt  = comp_mobile_event_amt * cpr_payment_rate;
					cm_cpr_amt = floor( cm_event_dSubCprAmt );
					cm_sum_cpr_amt = cm_sum_cpr_amt + cm_cpr_amt;

					cm_comp_amt = (comp_mobile_event_amt - cp_cpr_amt);
					cm_sum_comp_amt = cm_sum_comp_amt + cm_comp_amt;

				}

				deal_file[nDealFileCnt].deal_no = deal_data.deal_no;
				deal_file[nDealFileCnt].id = deal_data.id;
				deal_file[nDealFileCnt].chi_id = chi_id;
				deal_file[nDealFileCnt].list_id = list_id ;
				deal_file[nDealFileCnt].list_seq_no = list_seq_no;

				strcpy(deal_file[nDealFileCnt].cont_type , cont_type);

				nDealFileCnt++;


			}

			mysql_free_result(cpr_res);



			//업로더 수익
			if(sum_comp_amt >= 0)
				deal_data.comp_amt = sum_comp_amt - deal_data.sale_amt ;


			// 2014.04.24 추가 : 이벤트 가격 비교
			// deal_data.price_amt 결재 금액
			// sum_price_amt 컨텐츠 금액

			// 2015.04.15 추가 : PC, 모바일 구분

			ZzLOG(ALWAY, "deal_data.price_amt [ %2.f ]\n",deal_data.price_amt);
			if(sum_price_amt == deal_data.price_amt)
			{	// 일반 컨텐츠 등록가격 , 결재 가격 비교
				ZzLOG(ALWAY, "정상 OK = deal_data.deal_no [ %lu ]\n",deal_data.deal_no);
				strcpy(proc_yn, "N"); // 정상

			}
			else
			{	// 가격이 틀리므로 이벤트 컨텐츠인가 확인.
				if(strcmp(deal_data.down_st_date,"1")==0) // PC 가격
				{
//					strcpy(deal_file[nDealFileCnt].cont_type , cont_type);

					if(sum_event_amt == deal_data.price_amt)
					{
						deal_data.comp_amt = event_sum_comp_amt - deal_data.sale_amt ;
						sum_cpr_amt = event_sum_cpr_amt;
						strcpy(proc_yn, "N"); // 정상
						printf("\nEVENT PC OK = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);
						ZzLOG(ALWAY, "\nEVENT PC OK = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);
					}
					else
					{
						if(sum_comp_pc_event_amt == deal_data.price_amt)
						{
							deal_data.comp_amt = cp_sum_comp_amt - deal_data.sale_amt ;
							sum_cpr_amt = cp_sum_cpr_amt;
							strcpy(proc_yn, "N"); // 정상
							printf("\nEVENT PC COMP OK = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_comp_pc_event_amt);
							ZzLOG(ALWAY, "\nEVENT PC COMP OK = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_comp_pc_event_amt);
						}
						else
						{
							strcpy(proc_yn, "R"); // 보류
							printf("\nEVENT PC NO= %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);
							ZzLOG(ALWAY, "\nEVENT PC NO= %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);
						}
					}


				}
				else if(strcmp(deal_data.down_st_date,"2")==0) // 모바일 가격
				{
					if(sum_event_amt == deal_data.price_amt)
					{
						deal_data.comp_amt = event_sum_comp_amt - deal_data.sale_amt ;
						sum_cpr_amt = event_sum_cpr_amt;
						strcpy(proc_yn, "N"); // 정상
						printf("\n EVENT Mobile OK = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);
						ZzLOG(ALWAY, "\n EVENT Mobile OK = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);
					}
					else
					{
						if(sum_comp_mobile_event_amt == deal_data.price_amt)
						{
							deal_data.comp_amt = cm_sum_comp_amt - deal_data.sale_amt ;
							sum_cpr_amt = cm_sum_cpr_amt;
							strcpy(proc_yn, "N"); // 정상
							printf("\n EVENT Mobile COMP OK = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_comp_mobile_event_amt);
							ZzLOG(ALWAY, "\n EVENT Mobile COMP OK = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_comp_mobile_event_amt);
						}
						else
						{
							strcpy(proc_yn, "R"); // 보류
							printf("\nEVENT Mobile NO = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);
							ZzLOG(ALWAY, "\nEVENT Mobile NO = %s , d = %2.f , e= %2.f\n",proc_yn,deal_data.price_amt,sum_event_amt);
						}
					}
				}
				else
				{
					ZzLOG(ALWAY, "deal_data.down_st_date ERROR [ %s ]\n",deal_data.down_st_date);
					printf ("deal_data.down_st_date ERROR [ %s ]\n",deal_data.down_st_date);
					strcpy(proc_yn, "R"); // 보류
					printf("\nETC = %s\n",proc_yn);
				}
			}





			// 결재 정보의 컨텐츠 ID 로 MGR 코드를 구해와
			// 이벤트 테이블에 있는지 정보를 조회하여 가격을 가져온다.
			// 이벤트 테이블에 MGR 코드가 있으면 이벤트 가격으로 비교
			// 없으면 제휴 컨텐츠 가격으로 비교
			// 일반, 모바일 이벤트 테이블 구분한다. deal_data.down_st_date : 이벤트 가격 다른지 확인.
			// T_CPR_DEAL_INFO 의 결재 정보와 어떤 테이블이랑 조인해서  mgr_cd 가져올지 확인.
			// 이벤트 가격 가져와서 T_CPR_ENVENT_CONT_LIST . mgr_cd 가 있다면 event_amt 가격과 비교. use_yn = 'Y' 것들 중에서
			// deal_data.down_st_date==1 일때 : select a.event_amt from T_CPR_ENVENT_CONT_LIST a, zangsi_cpr.T_CPR_CONT_LIST b where a.mgr_cd = b.mgr_cd and a.use_yn = 'Y' ;
			// deal_data.down_st_date==2 일때 : select a.event_amt from T_CPR_ENVENT_CONT_LIST a, zangsi_cpr.T_CPR_MOB_CONT_LIST b where a.mgr_cd = b.mgr_cd and a.use_yn = 'Y' ;
			// 같으면 'N' , 다르면 'R'

			//cpr tran begin
			if (tran_begin(cpr_real_con)!=0)
			{
				ZzLOG(ERROR, "tran_begin [%d](%s)\n",mysql_errno(cpr_real_con), mysql_error(cpr_real_con));
				return -1;
			}

			if(deal_data.price_amt == 0 )
				strcpy(proc_yn, "R"); // 보류

			memset(szQuery, 0x00, sizeof(szQuery));
			sprintf(szQuery, " insert into zangsi_cpr.T_CPR_DEAL_INFO "
							 " (cont_cd, deal_no, op_deal_no,  cont_gu, id, comp_cd, chi_id, "
							 "  deal_date, deal_time, "
							 "  sale_cd, sale_user, buy_user, title, sect_code, "
							 "  price_amt, sale_amt, comp_amt, cpr_amt, "
							 "  file_size, adult_yn, proc_yn, reg_date, reg_time, approval_yn,service_gu )"
							 " values "
							 " ('00', %lu, 0, '%s', %lu, '%s', %lu, "
							 "  '%s', '%s', "
							 "  '%s', '%s', '%s', '%s', '%s', "
							 "  %.0f, %.1f, %.1f, %.1f, "
							 "  %.0f, '%s', '%s', '%s', '%s', 'Y','%s' )  ; /* cprdaem1001 */ "
							 , deal_data.deal_no, deal_data.cont_gu, deal_data.id, comp_cd, chi_id
							 , deal_data.deal_date, deal_data.deal_time
							 , sale_cd, deal_data.sale_user, deal_data.buy_user, deal_data.title, deal_data.sect_code
							 , deal_data.price_amt, deal_data.sale_amt, deal_data.comp_amt, sum_cpr_amt
							 , deal_data.file_size, deal_data.adult_yn, proc_yn, gst_date, gst_time,deal_data.down_st_date);//20130410

			//printf("결재 정보 [ %s ] \n",szQuery);
			//ZzLOG(ALWAY, "[%lu]\n",deal_data.deal_no);
			ZzLOG(ALWAY, "[%s]\n",szQuery);

			if (mysql_query(cpr_real_con, szQuery))
			{
				mysql_free_result(g_res);
			    ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(cpr_real_con), mysql_error(cpr_real_con));
			    tran_rollback(cpr_real_con);
				tran_end(cpr_real_con);
				return -1;
		    }

	    	for(int i=0 ;i < nDealFileCnt ; i++)
	    	{
		    	//ZzLOG(ALWAY,"====== [%d][%d] ======\n",i,nDealFileCnt);
				//T_CPR_CONT_INFO_FILE
				memset(szQuery, 0x00, sizeof(szQuery));
				sprintf(szQuery, " insert into zangsi_cpr.T_CPR_DEAL_INFO_FILE                   "
								 " ( deal_no , id , chi_id , list_id , list_seq_no , service_gu , cont_type "
								 ") "
								 " values "
								 " ( %lu , %lu , %lu , %lu , %lu ,'%s' , '%s' "
								 " )  ; /* cprdaem1001 */ "
								 , deal_file[i].deal_no, deal_file[i].id, deal_file[i].chi_id,deal_file[i].list_id,deal_file[i].list_seq_no ,deal_data.down_st_date, deal_file[i].cont_type //20130410
								 );

				ZzLOG(ALWAY, "[%s]\n",szQuery);
				if (mysql_query(cpr_real_con, szQuery))
				{
					//mysql_free_result(g_res);
				    ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(cpr_real_con), mysql_error(cpr_real_con));
					//tran_rollback(cpr_real_con);
					//tran_end(cpr_real_con);
					//return -1;
			    }
			}
			if (tran_commit(cpr_real_con)!=0)
			{
				ZzLOG(ERROR, "cpr_real_con [%d](%s)\n",mysql_errno(cpr_real_con), mysql_error(cpr_real_con));
				tran_rollback(cpr_real_con);
				tran_end(cpr_real_con);
				return -1;
			}
			tran_end(cpr_real_con);

		    //tran_end



			memset(szQuery, 0x00, sizeof(szQuery));
			sprintf(szQuery, " delete from zangsi.T_DEAL_CPR where deal_no = %lu  ; /* cprdaem1001 */ ", deal_no);
			if (mysql_query(con, szQuery))
			{
				mysql_free_result(g_res);
			    ZzLOG(ERROR, "[%s][%d](%s)\n",szQuery,mysql_errno(con), mysql_error(con));
				return -1;
			}

			//tran end
			/*
			char szDealDateTime[15];
			memset(szDealDateTime, 0x00, sizeof(szDealDateTime));
			sprintf(szDealDateTime, "%s%s", deal_data.deal_date, deal_data.deal_time);
			cprdaem1001_sendpay(deal_data.id, deal_data.deal_no, deal_data.buy_user, szDealDateTime);
			*/
			dCount	++;


		}

		mysql_free_result(g_res);

	}



	return 0;
}


/*****************************************************************************
*  프로그램 메인
*****************************************************************************/
int main(int argc, char **argv)
{
	char    szTemp[1024];
	int     rc;

	/*
	** SIGNAL 정의
	*/
	signal(SIGTERM, SIG_IGN);
	signal(SIGINT,  SIG_IGN);
	signal(SIGQUIT, SIG_IGN);
	signal(SIGKILL, SIG_IGN);
	signal(SIGPIPE, SIG_IGN);
	signal(SIGTTIN, SIG_IGN);
	signal(SIGTTOU, SIG_IGN);
	signal(SIGCHLD, SIG_IGN);
	signal(SIGHUP,  SIG_IGN);

//	복구시 사용함.
//	cprdaem1001_process_init_temp(argc, argv) ;
//	memset(gst_date, 0x00, sizeof(gst_date));
//	strcpy(gst_date, "00000000");
//	cprdaem1001_process();
//	cprdaem1001_process_db_temp();
//	return 1;
//

	if ( cprdaem1001_process_init(argc, argv) == 0 )
	{
		/* 프로그램 메인루틴 */
		for(;;)
		{
			memset(gst_date, 0x00, sizeof(gst_date));
			strcpy(gst_date, "00000000");

			rc = cprdaem1001_process();

			if(rc == -1)
				return 0;

			if(gnCnt > 50)
			{
				ZzLOG(ERROR, "Exit : gnCnt [%d]\n",gnCnt);
				return 0;
			}

			if(rc == -10)
			{
				sleep(10);
			}
			else
			{
				if(rc < 0)
				{
					sleep(10);
				}

				cprdaem1001_process_term();

			}
			sleep(3);
		}
		/* 프로그램 종료루틴 */
	}
	return(0);
}
