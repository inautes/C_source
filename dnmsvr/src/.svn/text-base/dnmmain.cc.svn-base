unsigned long int ChangeEndian(unsigned long int uiInput)
{
    return ( uiInput >> 24 ) | ( ( uiInput >> 8 ) & 0x0000FF00 ) \
       | ( ( uiInput <<  8 ) & 0x00FF0000 ) | ( uiInput << 24 );
}

